*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak-*

# local data / temp
.cache/
tmp/

# LLM-as-judge eval run artifacts (npm run eval) — local-only
eval/

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
.gstack/

# Compiled Apple Vision OCR binary — machine-specific, rebuild with
# `npm run setup:vision` (macOS only).
scripts/vision-ocr

# v0.5 Phase C: slide photos uploaded via Telegram bot live here.
# Curator-private by default. To publish slides on the live site, comment
# this out and commit the files explicitly (per CLAUDE.md staging rules).
data/slide-photos/

# v0.5 Phase E: symlink to data/slide-photos for local preview
public/slides

# v0.8 PR2: full-text PDFs filed into the Obsidian vault. LOCAL-ONLY by
# constraint — copyrighted material is never published. The daily .md notes
# (data/obsidian/*.md) stay committed (public-safe summaries); only the
# papers/ subtree is gitignored. No public/ symlink exists for these, so they
# never enter the Astro build.
data/obsidian/papers/

# v0.30 build resume cache (derived digest data, safe to delete)
data/.cache/
