---
import Base from '../layouts/Base.astro';
import TagFilterRail from '../components/TagFilterRail.astro';
import Sparkline from '../components/Sparkline.astro';
import {
  listDigests,
  listConferenceSummaries,
  listRecentStudies,
  listSiteSummaries,
  stripStudyNamePrefix,
} from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';
import { DISEASE_SITES, getDiseaseSite } from '../lib/disease-sites.ts';
import { verdictMetaFor } from '../lib/verdict.ts';
import { buildShareUrl } from '../lib/share-url.ts';
import { studyDataTags } from '../lib/study-data-tags.ts';
import { buildFilterRailOptions } from '../lib/tag-foundations.ts';
import {
  buildTagActivity,
  listTagSummaries,
  resolveTagDisplay,
} from '../lib/tag-index.ts';

const digests = listDigests();
const conferences = listConferenceSummaries();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'onc brain';
// Latest digest takes over the hero spot — that's what a returning reader cares
// about most. First-time framing lives on /about.
const latest = digests[0];

// Disease-site nav bar. Populated chips lead so a phone reader sees the
// covered sites above the fold (the 9-row chip cloud pushed the hero TL;DR
// below the fold on iPhone SE); empty chips collapse under a <details> so
// the full taxonomy stays one click away.
const summaries = listSiteSummaries();
const countBySlug = new Map(summaries.map((s) => [s.disease_site, s.occurrences.length]));
const navSites = DISEASE_SITES.map((s) => ({
  ...s,
  count: countBySlug.get(s.slug) ?? 0,
}));
const navPopulated = navSites.filter((s) => s.count > 0);
const navEmpty = navSites.filter((s) => s.count === 0);

// v0.11 PR-2: the home right gutter now hosts the TagFilterRail. The
// disease-site nav lives in the top chip row below the hero (already
// present on every viewport), so readers keep their cross-corpus
// navigation surface; the right rail offers "narrow this feed" — the
// tighter affordance for a returning reader.

// Studies as a flat feed: every study in date-desc order, no date headers.
// At current scale (low tens) we show the full archive on home; pagination
// is a deferred concern (see TODOS.md when the archive grows past ~100).
const feed = listRecentStudies(Number.MAX_SAFE_INTEGER);

// v0.11 PR-2: per-namespace filter options scoped to the studies that
// will actually render on this page. Empty namespaces (no studies
// carry that tag type) are dropped by buildFilterRailOptions; the
// component additionally drops empty namespaces at render time.
const filterOptions = buildFilterRailOptions(
  feed.map((r) => ({
    study: r.study,
    conferenceSlug: r.conference?.slug ?? null,
    conferenceLabel: r.conference?.name ?? null,
  })),
);

// v0.10 home page surfaces (design pass 1 + pass 4 locks):
//   1. 30-day tag activity histogram: top-5 tags by recency-weighted study
//      count with inline sparkline + count + trend arrow. Lives just above
//      the chip row so a returning reader sees "what's trending" at a glance.
//   2. TAGS chip row: every populated tag, sorted by count desc, plain text
//      meta-line. Tertiary navigation per design pass 1 — placed AFTER the
//      recent feed so the reader's primary scan (hero TL;DR → recent feed)
//      isn't displaced.
const tagActivity = buildTagActivity(digests, { limit: 5, window: 30 });
const tagSummaries = listTagSummaries(digests);
// All populated tag slugs sorted by occurrence count desc, capped at 20 so
// the row stays a discovery surface rather than a chip cloud. The full
// per-namespace browse lives at /tags/.
const TAG_CHIP_ROW_CAP = 20;
const tagChipRow = Array.from(tagSummaries.entries())
  .map(([slug, occurrences]) => {
    const display = resolveTagDisplay(slug, occurrences);
    return display ? { slug, label: display.label, count: occurrences.length } : null;
  })
  .filter((c): c is { slug: string; label: string; count: number } => c !== null)
  .sort((a, b) => (b.count - a.count) || (a.label < b.label ? -1 : a.label > b.label ? 1 : 0))
  .slice(0, TAG_CHIP_ROW_CAP);
---

<Base title={siteName} description="Curated AI-summarized digests of oncology updates.">
  {digests.length > 0 && (
    <TagFilterRail
      modality={filterOptions.modality}
      intent={filterOptions.intent}
      methodology={filterOptions.methodology}
      verdict={filterOptions.verdict}
      meeting={filterOptions.meeting}
      totalCount={feed.length}
    />
  )}
  {digests.length > 0 && (
    <nav class="site-nav" aria-label="Browse by disease site">
      {navPopulated.length > 0 && (
        <ul class="nav-row">
          {navPopulated.map((s) => (
            <li>
              <a
                class="nav-chip"
                href={`/sites/${s.slug}/`}
                title={`${s.label}: ${s.rationale}`}
              >
                <span class="nav-emoji" aria-hidden="true">{s.emoji}</span>
                <span class="nav-label">{s.label}</span>
                <span class="nav-count">{s.count}</span>
              </a>
            </li>
          ))}
        </ul>
      )}
      {navEmpty.length > 0 && (
        <details class="nav-empty-toggle">
          <summary>+{navEmpty.length} sites not yet covered</summary>
          <ul class="nav-row nav-row-empty">
            {navEmpty.map((s) => (
              <li>
                <span
                  class="nav-chip nav-chip-empty"
                  title={`${s.label}: ${s.rationale} (not yet covered)`}
                >
                  <span class="nav-emoji" aria-hidden="true">{s.emoji}</span>
                  <span class="nav-label">{s.label}</span>
                </span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </nav>
  )}

  {latest ? (
    <section class="hero-tldr" aria-label="Latest digest summary">
      <div class="hero-meta">
        <span class="hero-date">{latest.date}</span>
        {latest.conference && (
          <span class="hero-conf">{latest.conference.name}</span>
        )}
      </div>
      {latest.digest.top_line && (
        <p class="hero-topline" set:html={linkifyCitations(latest.digest.top_line)} />
      )}
      <p class="hero-body" set:html={linkifyCitations(latest.digest.tldr)} />
      <a class="hero-cta" href={`/${latest.date}/`}>read the full digest →</a>
    </section>
  ) : (
    <p style="font-size:1.05rem;color:var(--fg-muted);margin-top:0">
      Daily curated digests of the most impactful oncology updates on X,
      organized by topic and AI-summarized. More frequent during major meetings.
    </p>
  )}

  {digests.length === 0 && (
    <p style="margin-top:2rem;color:var(--fg-muted)">
      No digests yet — check back soon.
    </p>
  )}

  {conferences.length > 0 && (
    <section class="conf-section">
      <h2 class="section-label">Conferences</h2>
      <ul class="conf-list">
        {conferences.map((conf) => (
          <li>
            <a class="conf-chip" href={`/conferences/${conf.slug}/`}>
              {conf.name} <span class="conf-meta">· {conf.dates.length}d</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {feed.length > 0 && (
    <section class="recent-section">
      <h2 class="section-label">Studies · {feed.length}<span class="recent-new-total" aria-live="polite"></span></h2>
      <ul class="recent-list">
        {feed.map((r) => {
          const meta = getDiseaseSite(r.disease_site);
          const tldr = stripStudyNamePrefix(r.study.tldr, r.study.name);
          const teaser = tldr.length > 200 ? tldr.slice(0, 199).trimEnd() + '…' : tldr;
          const shareUrl = buildShareUrl({ site: r.disease_site, date: r.date, slug: r.slug });
          const dataTags = studyDataTags(r.study, r.disease_site, r.conference?.slug ?? null);
          // T1-A: feed verdict glyph is practice-changing ONLY (a rarity flag).
          // Other verdicts read as UI controls or collide with site emoji when
          // shown bare in a dense row (see design review 2026-06-10).
          const practiceMeta =
            r.study.verdict?.soc_implication === 'practice-changing'
              ? verdictMetaFor('practice-changing')
              : null;
          // T2: stable per-study id for the "new since last visit" marker.
          const studyId = `${r.date}#${r.slug}`;
          return (
            <li class="recent-li" data-study-id={studyId} data-tags={dataTags || undefined}>
              <a class="recent-card" href={`/${r.date}/#${r.slug}`}>
                <div class="recent-meta">
                  <span class="recent-new-pill">New</span>
                  {practiceMeta && (
                    <span class="verdict-flag">
                      <span aria-hidden="true">{practiceMeta.emoji}</span>
                      <span class="sr-only">{practiceMeta.label}</span>
                    </span>
                  )}
                  <span class="recent-emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
                  <span class="recent-site">{meta.label}</span>
                  <span class="recent-dot" aria-hidden="true">·</span>
                  <span class="recent-date">{r.date}</span>
                  {r.conference && (
                    <span class="recent-conf">{r.conference.name}</span>
                  )}
                </div>
                <div class="recent-name">{r.study.name}</div>
                <div class="recent-tldr" set:html={linkifyCitations(teaser)} />
              </a>
              {shareUrl && (
                <Fragment>
                  <button
                    type="button"
                    class="recent-share"
                    data-share-url={shareUrl}
                    data-share-title={r.study.name}
                    aria-label={`Share link to ${r.study.name}`}
                    title="Share"
                  ><svg class="share-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg></button>
                  <span class="sr-share-status" aria-live="polite"></span>
                  <input
                    type="text"
                    class="share-recovery"
                    readonly
                    tabindex={-1}
                    aria-label="Copy this URL manually"
                  />
                </Fragment>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {/* v0.10 home page tag surfaces. Both live BELOW the recent-studies feed
       per design pass 1 lock — the reader's primary scan (disease-site nav →
       hero TL;DR → recent feed) is preserved, and tag discovery surfaces
       are tertiary: readers scroll to them when curious, not encounter them
       mid-scan. Empty-state copy renders when no tags carry studies yet
       (fresh corpus pre-backfill or pre-first-digest). */}
  {digests.length > 0 && tagActivity.length > 0 && (
    <section class="tag-activity-section" aria-labelledby="tag-activity-heading">
      <h2 class="section-label" id="tag-activity-heading">Active tags · {tagActivity[0]!.counts.length}d window</h2>
      <ul class="tag-activity-list">
        {tagActivity.map((row) => {
          const arrow = row.trend === 'up' ? '↑' : row.trend === 'down' ? '↓' : '→';
          return (
            <li class="tag-activity-row">
              <a href={`/tags/${row.slug}/`} class="tag-activity-name">{row.label}</a>
              <Sparkline counts={row.counts} label={row.label} trend={row.trend} />
              <span class="tag-activity-count">{row.totalRecent}</span>
              <span class="tag-activity-arrow" aria-hidden="true">{arrow}</span>
            </li>
          );
        })}
      </ul>
    </section>
  )}
  {digests.length > 0 && tagActivity.length === 0 && (
    <section class="tag-activity-section" aria-labelledby="tag-activity-heading">
      <h2 class="section-label" id="tag-activity-heading">Active tags</h2>
      <p class="tag-empty">Tag activity will appear after the next digest.</p>
    </section>
  )}

  {tagChipRow.length > 0 && (
    <section class="tag-chip-section" aria-labelledby="tag-chip-row-heading">
      <h2 class="section-label" id="tag-chip-row-heading">Tags · {tagChipRow.length}{tagChipRow.length === TAG_CHIP_ROW_CAP && '+'}</h2>
      <p class="tag-chip-row">
        {tagChipRow.map((c, i) => (
          <Fragment>
            {i > 0 && <span class="tag-chip-sep" aria-hidden="true">·</span>}
            <a class="tag-chip-link" href={`/tags/${c.slug}/`}>{c.label}</a>
          </Fragment>
        ))}
        {/* "more →" only when the displayable count was actually capped — not
            when the cap matched the natural population. Codex review caught
            the misleading link case. */}
        {tagChipRow.length === TAG_CHIP_ROW_CAP && tagSummaries.size > TAG_CHIP_ROW_CAP && (
          <Fragment>
            <span class="tag-chip-sep" aria-hidden="true">·</span>
            <a class="tag-chip-link tag-chip-more" href="/tags/">more →</a>
          </Fragment>
        )}
      </p>
    </section>
  )}
</Base>

<style>
  /* Disease-site nav bar — top of page. Populated chips lead; empty chips
     hidden behind a <details> so mobile fold isn't dominated by greyed-out
     inventory. Touch targets meet the 44px iOS HIG floor. */
  .site-nav {
    margin: 0 0 1.5rem;
  }
  /* v0.11 PR-2: kept visible at every viewport. Pre-v0.11 the desktop
     left rail (TriageRail) carried the disease-site nav and the top
     chip row was hidden ≥1200px to avoid duplication. Now the left
     rail is the TagFilterRail (filter, not site nav), so the chip row
     becomes the only disease-site navigation surface on desktop too.
     Both reviewers caught the regression where desktop home lost
     site nav entirely. */
  .nav-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 44px;
    padding: 0.45rem 0.85rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg);
    text-decoration: none;
    line-height: 1.2;
  }
  .nav-chip:hover { border-color: var(--accent); }
  .nav-emoji { font-size: 1.05rem; line-height: 1; }
  .nav-label { font-weight: 500; }
  .nav-count {
    color: var(--fg-muted);
    font-size: 0.75rem;
    margin-left: 0.15rem;
  }
  .nav-chip-empty {
    color: var(--fg-muted);
    opacity: 0.6;
    cursor: default;
  }
  .nav-chip-empty:hover { border-color: var(--border); }
  .nav-chip-empty .nav-label { font-weight: 400; }
  /* Desaturate the emoji on muted chips so the populated/empty split reads
     instantly at scanning speed. */
  .nav-chip-empty .nav-emoji {
    filter: saturate(0.25) grayscale(0.55);
  }

  /* Collapsible empty-sites section. */
  .nav-empty-toggle {
    margin-top: 0.5rem;
  }
  .nav-empty-toggle summary {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0.35rem 0.7rem;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    list-style: none;
    border: 1px dashed var(--border);
    border-radius: 999px;
    user-select: none;
  }
  .nav-empty-toggle summary::-webkit-details-marker { display: none; }
  .nav-empty-toggle summary:hover { color: var(--fg); border-color: var(--accent); }
  .nav-empty-toggle[open] summary { color: var(--fg); }
  .nav-row-empty { margin-top: 0.5rem; }

  /* Hero TL;DR callout — unchanged from previous version. */
  .hero-tldr {
    margin: 0 0 1.5rem;
    padding: 1.1rem 1.25rem 1rem;
    background: var(--accent-bg);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 6px;
  }
  /* Hero meta is supporting metadata — date + optional conference badge.
     Headline is the top_line below; meta should not compete with it. */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.55rem;
  }
  .hero-date { font-weight: 500; }
  .hero-conf {
    padding: 0.05rem 0.45rem;
    background: var(--bg-card);
    color: var(--accent);
    border-radius: 999px;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .hero-topline {
    margin: 0 0 0.55rem;
    font-size: 1.12rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--fg);
  }
  .hero-body {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--fg);
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.55rem 1rem;
    margin: 0.85rem -1rem -0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .hero-cta:hover { text-decoration: underline; }

  /* Section labels reused across conferences + recent. */
  .section-label {
    margin: 0 0 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* Conferences strip. */
  .conf-section { margin-top: 2rem; }
  .conf-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .conf-chip {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--fg);
  }
  .conf-chip:hover { border-color: var(--accent); }
  .conf-meta { color: var(--fg-muted); }

  /* Recent N studies list. */
  .recent-section { margin-top: 2.5rem; }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  /* Each feed item is a <li class="recent-li"> so the absolutely-positioned
     share button (sibling of the <a>) can use the li as its containing block.
     Button-in-anchor would be invalid HTML, hence the sibling layout. */
  .recent-li { position: relative; }
  .recent-card {
    display: block;
    min-height: 44px;
    /* Extra bottom padding so the TL;DR text doesn't run under the absolutely
       positioned share button at bottom-right. */
    padding: 0.9rem 1.05rem 2.2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
  }
  /* Card border stays accent while cursor is anywhere over the li OR keyboard
     focus lands on either the link or the share button — avoids the visual
     "card disconnect" when the cursor moves from card body to the absolutely-
     positioned share button (which is outside the <a>'s hover region). */
  .recent-li:hover .recent-card,
  .recent-card:focus-within { border-color: var(--accent); }
  .recent-li:focus-within .recent-card { border-color: var(--accent); }
  .recent-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    color: var(--fg-muted);
    margin-bottom: 0.25rem;
  }
  .recent-emoji { font-size: 0.95rem; }
  .recent-site { font-weight: 600; color: var(--fg); }
  .recent-dot { opacity: 0.55; }
  .recent-conf {
    margin-left: auto;
    padding: 0.05rem 0.45rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .recent-name {
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--fg);
    margin-bottom: 0.2rem;
  }
  .recent-tldr {
    color: var(--fg-muted);
    font-size: 0.93rem;
    line-height: 1.45;
  }

  /* T1-A: practice-changing feed flag (🚀). Sits at the head of the meta row,
     a touch larger than the site emoji so the rare flag reads as the row's
     priority signal. Only renders for practice-changing studies. */
  .verdict-flag { font-size: 1.0rem; line-height: 1; }

  /* T2: "new since last visit". The pill ships in markup hidden by default and
     is revealed by the .is-new class the client script adds to the <li> — never
     via inline display (the empty-inline-reveal footgun bit this codebase
     twice). Text pill at .section-label typography, NEUTRAL color, so it can't
     collide with the emoji vocabulary or imply a verdict. */
  .recent-new-pill {
    display: none;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.04rem 0.32rem;
    line-height: 1.5;
    align-self: center;
  }
  .recent-li.is-new .recent-new-pill { display: inline-block; }

  /* "N new overall" total beside the Studies heading. Hidden until the script
     fills it and adds .is-shown (same class-toggle reveal, no inline display). */
  .recent-new-total {
    display: none;
    margin-left: 0.45rem;
    font-weight: 400;
    color: var(--fg-muted);
    text-transform: none;
    letter-spacing: 0;
  }
  .recent-new-total.is-shown { display: inline; }

  /* Visually-hidden label so the bare 🚀 flag is announced ("Practice-changing")
     to screen readers instead of an emoji name. Same clip pattern as
     .sr-share-status. */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Share affordance: absolute bottom-right overlay, sibling of the link
     (button-in-anchor is invalid HTML). Hidden until share-script.ts confirms
     navigator.share or navigator.clipboard is available. .is-flipped is added
     during the Copied / Couldn't copy window for the accent-color flash. */
  .recent-share {
    display: none;
    align-items: center;
    justify-content: center;
    position: absolute;
    bottom: 0.5rem;
    right: 0.6rem;
    z-index: 2;
    background: none;
    border: none;
    padding: 0.5rem;
    color: var(--fg-muted);
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
  }
  .recent-share:hover { color: var(--accent); }
  .recent-share.is-flipped { color: var(--accent); }
  .recent-share .share-icon { display: block; }

  /* Screen-reader-only live region for state announcements. Visible label
     change is the sighted user's signal; this announces the same text to
     screen readers because mutating button textContent doesn't fire reliably
     across NVDA / JAWS / VoiceOver. */
  .sr-share-status {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Inline URL recovery: appears above the share button (rare path — when
     clipboard.writeText rejects). Pre-selected for Cmd+A/Cmd+C. Auto-hides
     after 10s. */
