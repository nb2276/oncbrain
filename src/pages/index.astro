---
import Base from '../layouts/Base.astro';
import SearchBox from '../components/SearchBox.astro';
import {
  listDigests,
  listConferenceSummaries,
  listRecentStudies,
  listSiteSummaries,
} from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';
import { DISEASE_SITES, getDiseaseSite } from '../lib/disease-sites.ts';

const digests = listDigests();
const conferences = listConferenceSummaries();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'onc brain';
// Latest digest takes over the hero spot — that's what a returning reader cares
// about most. First-time framing lives on /about.
const latest = digests[0];

// Disease-site nav bar. Populated chips lead so a phone reader sees the
// covered sites above the fold (the 9-row chip cloud pushed the hero TL;DR
// below the fold on iPhone SE); empty chips collapse under a <details> so
// the full taxonomy stays one click away.
const summaries = listSiteSummaries();
const countBySlug = new Map(summaries.map((s) => [s.disease_site, s.occurrences.length]));
const navSites = DISEASE_SITES.map((s) => ({
  ...s,
  count: countBySlug.get(s.slug) ?? 0,
}));
const navPopulated = navSites.filter((s) => s.count > 0);
const navEmpty = navSites.filter((s) => s.count === 0);

// Recent N studies as a flat list — replaces the previous "list of dates" so
// the reader sees the last things added without one indirection layer.
const RECENT_COUNT = 10;
const recent = listRecentStudies(RECENT_COUNT);
const totalDates = digests.length;
---

<Base title={siteName} description="Curated AI-summarized digests of oncology updates.">
  {digests.length > 0 && (
    <nav class="site-nav" aria-label="Browse by disease site">
      {navPopulated.length > 0 && (
        <ul class="nav-row">
          {navPopulated.map((s) => (
            <li>
              <a
                class="nav-chip"
                href={`/sites/${s.slug}/`}
                title={`${s.label}: ${s.rationale}`}
              >
                <span class="nav-emoji" aria-hidden="true">{s.emoji}</span>
                <span class="nav-label">{s.label}</span>
                <span class="nav-count">{s.count}</span>
              </a>
            </li>
          ))}
        </ul>
      )}
      {navEmpty.length > 0 && (
        <details class="nav-empty-toggle">
          <summary>+{navEmpty.length} sites not yet covered</summary>
          <ul class="nav-row nav-row-empty">
            {navEmpty.map((s) => (
              <li>
                <span
                  class="nav-chip nav-chip-empty"
                  title={`${s.label}: ${s.rationale} (not yet covered)`}
                >
                  <span class="nav-emoji" aria-hidden="true">{s.emoji}</span>
                  <span class="nav-label">{s.label}</span>
                </span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </nav>
  )}

  {latest ? (
    <section class="hero-tldr" aria-label="Latest digest summary">
      <div class="hero-meta">
        <span class="hero-date">{latest.date}</span>
        {latest.conference && (
          <span class="hero-conf">{latest.conference.name}</span>
        )}
      </div>
      {latest.digest.top_line && (
        <p class="hero-topline" set:html={linkifyCitations(latest.digest.top_line)} />
      )}
      <p class="hero-body" set:html={linkifyCitations(latest.digest.tldr)} />
      <a class="hero-cta" href={`/${latest.date}/`}>read the full digest →</a>
    </section>
  ) : (
    <p style="font-size:1.05rem;color:var(--fg-muted);margin-top:0">
      Daily curated digests of the most impactful oncology updates on X,
      organized by topic and AI-summarized. More frequent during major meetings.
    </p>
  )}

  {digests.length > 0 && <SearchBox />}

  {digests.length === 0 && (
    <p style="margin-top:2rem;color:var(--fg-muted)">
      No digests yet — check back soon.
    </p>
  )}

  {conferences.length > 0 && (
    <section class="conf-section">
      <h2 class="section-label">Conferences</h2>
      <ul class="conf-list">
        {conferences.map((conf) => (
          <li>
            <a class="conf-chip" href={`/conferences/${conf.slug}/`}>
              {conf.name} <span class="conf-meta">· {conf.dates.length}d</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {recent.length > 0 && (
    <section class="recent-section">
      <h2 class="section-label">Recent · {recent.length} latest studies</h2>
      <ul class="recent-list">
        {recent.map((r) => {
          const meta = getDiseaseSite(r.disease_site);
          const teaser = r.study.tldr.length > 200
            ? r.study.tldr.slice(0, 199).trimEnd() + '…'
            : r.study.tldr;
          return (
            <li>
              <a class="recent-card" href={`/${r.date}/#${r.slug}`}>
                <div class="recent-meta">
                  <span class="recent-emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
                  <span class="recent-site">{meta.label}</span>
                  <span class="recent-dot" aria-hidden="true">·</span>
                  <span class="recent-date">{r.date}</span>
                  {r.conference && (
                    <span class="recent-conf">{r.conference.name}</span>
                  )}
                </div>
                <div class="recent-name">{r.study.name}</div>
                <div class="recent-tldr" set:html={linkifyCitations(teaser)} />
              </a>
            </li>
          );
        })}
      </ul>
      {totalDates > 1 && (
        <p class="recent-tail">
          {recent.length === RECENT_COUNT && `Showing the latest ${RECENT_COUNT} studies across ${totalDates} day${totalDates === 1 ? '' : 's'}.`}
          {' '}
          <a href={`/${digests[digests.length - 1].date}/`}>browse older digests →</a>
        </p>
      )}
    </section>
  )}
</Base>

<style>
  /* Disease-site nav bar — top of page. Populated chips lead; empty chips
     hidden behind a <details> so mobile fold isn't dominated by greyed-out
     inventory. Touch targets meet the 44px iOS HIG floor. */
  .site-nav {
    margin: 0 0 1.5rem;
  }
  .nav-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 44px;
    padding: 0.45rem 0.85rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg);
    text-decoration: none;
    line-height: 1.2;
  }
  .nav-chip:hover { border-color: var(--accent); }
  .nav-emoji { font-size: 1.05rem; line-height: 1; }
  .nav-label { font-weight: 500; }
  .nav-count {
    color: var(--fg-muted);
    font-size: 0.75rem;
    margin-left: 0.15rem;
  }
  .nav-chip-empty {
    color: var(--fg-muted);
    opacity: 0.6;
    cursor: default;
  }
  .nav-chip-empty:hover { border-color: var(--border); }
  .nav-chip-empty .nav-label { font-weight: 400; }
  /* Desaturate the emoji on muted chips so the populated/empty split reads
     instantly at scanning speed. */
  .nav-chip-empty .nav-emoji {
    filter: saturate(0.25) grayscale(0.55);
  }

  /* Collapsible empty-sites section. */
  .nav-empty-toggle {
    margin-top: 0.5rem;
  }
  .nav-empty-toggle summary {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0.35rem 0.7rem;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    list-style: none;
    border: 1px dashed var(--border);
    border-radius: 999px;
    user-select: none;
  }
  .nav-empty-toggle summary::-webkit-details-marker { display: none; }
  .nav-empty-toggle summary:hover { color: var(--fg); border-color: var(--accent); }
  .nav-empty-toggle[open] summary { color: var(--fg); }
  .nav-row-empty { margin-top: 0.5rem; }

  /* Hero TL;DR callout — unchanged from previous version. */
  .hero-tldr {
    margin: 0 0 1.5rem;
    padding: 1.1rem 1.25rem 1rem;
    background: var(--accent-bg);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 6px;
  }
  /* Hero meta is supporting metadata — date + optional conference badge.
     Headline is the top_line below; meta should not compete with it. */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.55rem;
  }
  .hero-date { font-weight: 500; }
  .hero-conf {
    padding: 0.05rem 0.45rem;
    background: var(--bg-card);
    color: var(--accent);
    border-radius: 999px;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .hero-topline {
    margin: 0 0 0.55rem;
    font-size: 1.12rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--fg);
  }
  .hero-body {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--fg);
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.55rem 1rem;
    margin: 0.85rem -1rem -0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .hero-cta:hover { text-decoration: underline; }

  /* Section labels reused across conferences + recent. */
  .section-label {
    margin: 0 0 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* Conferences strip. */
  .conf-section { margin-top: 2rem; }
  .conf-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .conf-chip {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--fg);
  }
  .conf-chip:hover { border-color: var(--accent); }
  .conf-meta { color: var(--fg-muted); }

  /* Recent N studies list. */
  .recent-section { margin-top: 2.5rem; }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .recent-card {
    display: block;
    min-height: 44px;
    padding: 0.9rem 1.05rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
  }
  .recent-card:hover { border-color: var(--accent); }
  .recent-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    color: var(--fg-muted);
    margin-bottom: 0.25rem;
  }
  .recent-emoji { font-size: 0.95rem; }
  .recent-site { font-weight: 600; color: var(--fg); }
  .recent-dot { opacity: 0.55; }
  .recent-conf {
    margin-left: auto;
    padding: 0.05rem 0.45rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .recent-name {
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--fg);
    margin-bottom: 0.2rem;
  }
  .recent-tldr {
    color: var(--fg-muted);
    font-size: 0.93rem;
    line-height: 1.45;
  }
  .recent-tail {
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  .recent-tail a { color: var(--accent); text-decoration: none; }
  .recent-tail a:hover { text-decoration: underline; }
</style>
