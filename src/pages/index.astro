---
import Base from '../layouts/Base.astro';
import SearchBox from '../components/SearchBox.astro';
import { listDigests, listConferenceSummaries } from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';

const digests = listDigests();
const conferences = listConferenceSummaries();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'onc brain';
// Latest digest takes over the hero spot — that's what a returning reader cares
// about most. First-time framing lives on /about.
const latest = digests[0];
---

<Base title={siteName} description="Curated AI-summarized digests of oncology updates.">
  {latest ? (
    <section class="hero-tldr" aria-label="Latest digest summary">
      <div class="hero-meta">
        <span class="hero-date">{latest.date}</span>
        {latest.conference && (
          <span class="hero-conf">{latest.conference.name}</span>
        )}
      </div>
      {latest.digest.top_line && (
        <p class="hero-topline" set:html={linkifyCitations(latest.digest.top_line)} />
      )}
      <p class="hero-body" set:html={linkifyCitations(latest.digest.tldr)} />
      <a class="hero-cta" href={`/${latest.date}/`}>read the full digest →</a>
    </section>
  ) : (
    <p style="font-size:1.05rem;color:var(--fg-muted);margin-top:0">
      Daily curated digests of the most impactful oncology updates on X,
      organized by topic and AI-summarized. More frequent during major meetings.
    </p>
  )}

  {digests.length > 0 && <SearchBox />}

  {digests.length === 0 && (
    <p style="margin-top:2rem;color:var(--fg-muted)">
      No digests yet — check back soon.
    </p>
  )}

  <section style="margin-top:2rem">
    <h2 style="margin:0;font-size:0.78rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--fg-muted);font-family:var(--font-sans)">Browse</h2>
    <ul style="list-style:none;padding:0;margin:0.75rem 0 0;display:flex;flex-wrap:wrap;gap:0.5rem">
      <li>
        <a href="/sites/" style="display:inline-block;padding:0.4rem 0.9rem;background:var(--accent-bg);border:1px solid var(--border);border-radius:999px;font-size:0.9rem;font-family:var(--font-sans);color:var(--accent);text-decoration:none">By disease site →</a>
      </li>
      {conferences.map((conf) => (
        <li>
          <a
            href={`/conferences/${conf.slug}/`}
            style="display:inline-block;padding:0.4rem 0.9rem;background:var(--bg-card);border:1px solid var(--border);border-radius:999px;font-size:0.9rem;font-family:var(--font-sans);text-decoration:none"
          >{conf.name} <span style="color:var(--fg-muted)">· {conf.dates.length}d</span></a>
        </li>
      ))}
    </ul>
  </section>

  {digests.length > 0 && (
    <section style="margin-top:2.5rem">
      <h2 style="margin:0 0 1rem;font-size:0.78rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--fg-muted)">Recent</h2>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.85rem">
        {digests.map((d) => (
          <li>
            <a
              href={`/${d.date}/`}
              style="display:block;padding:1rem 1.25rem;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;text-decoration:none"
            >
              <div style="display:flex;justify-content:space-between;align-items:baseline;gap:0.75rem;flex-wrap:wrap">
                <strong style="color:var(--fg)">{d.date}</strong>
                {d.conference && (
                  <span style="color:var(--accent);font-size:0.82rem;padding:0.1rem 0.5rem;background:var(--accent-bg);border-radius:999px">{d.conference.name}</span>
                )}
              </div>
              <div style="margin-top:0.55rem;color:var(--fg);font-size:0.98rem;line-height:1.45;font-weight:500">
                {(d.digest.top_line || d.digest.tldr).slice(0, 220)}{(d.digest.top_line || d.digest.tldr).length > 220 ? '…' : ''}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .hero-tldr {
    margin: 0 0 1.5rem;
    padding: 1.1rem 1.25rem 1rem;
    background: var(--accent-bg);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 6px;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.55rem;
  }
  .hero-date { font-weight: 700; }
  .hero-conf {
    padding: 0.05rem 0.45rem;
    background: var(--bg-card);
    border-radius: 999px;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .hero-topline {
    margin: 0 0 0.55rem;
    font-size: 1.12rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--fg);
  }
  .hero-body {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--fg);
  }
  .hero-cta {
    display: inline-block;
    margin-top: 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .hero-cta:hover { text-decoration: underline; }
</style>
