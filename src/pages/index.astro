---
import Base from '../layouts/Base.astro';
import Sparkline from '../components/Sparkline.astro';
import RecentFeed from '../components/RecentFeed.astro';
import SiteNav from '../components/SiteNav.astro';
import {
  listDigests,
  listConferenceSummaries,
  listRecentStudies,
} from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';
import {
  buildTagActivity,
  listTagSummaries,
  resolveTagDisplay,
} from '../lib/tag-index.ts';

const digests = listDigests();
const conferences = listConferenceSummaries();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'onc brain';
// Latest digest takes over the hero spot — that's what a returning reader cares
// about most. First-time framing lives on /about.
const latest = digests[0];

// Disease-site nav bar lives in <SiteNav /> (shared with /studies, v0.14.3).

// v0.14 T3: the home shows the latest HOME_FEED_LIMIT studies as a what's-new
// slice; the full filterable index moved to /studies (with the TagFilterRail).
// The disease-site nav stays in the top chip row for cross-corpus wayfinding.

// Full corpus, date-desc. The home renders a slice (HOME_FEED_LIMIT) and links
// to /studies, but passes the full id list to RecentFeed so the "new since last
// visit" count + seen-set cover every study, not just the rendered slice.
const feed = listRecentStudies(Number.MAX_SAFE_INTEGER);
const HOME_FEED_LIMIT = 12;

// v0.10 home page surfaces (design pass 1 + pass 4 locks):
//   1. 30-day tag activity histogram: top-5 tags by recency-weighted study
//      count with inline sparkline + count + trend arrow. Lives just above
//      the chip row so a returning reader sees "what's trending" at a glance.
//   2. TAGS chip row: every populated tag, sorted by count desc, plain text
//      meta-line. Tertiary navigation per design pass 1 — placed AFTER the
//      recent feed so the reader's primary scan (hero TL;DR → recent feed)
//      isn't displaced.
const tagActivity = buildTagActivity(digests, { limit: 5, window: 30 });
const tagSummaries = listTagSummaries(digests);
// All populated tag slugs sorted by occurrence count desc, capped at 20 so
// the row stays a discovery surface rather than a chip cloud. The full
// per-namespace browse lives at /tags/.
const TAG_CHIP_ROW_CAP = 20;
const tagChipRow = Array.from(tagSummaries.entries())
  .map(([slug, occurrences]) => {
    const display = resolveTagDisplay(slug, occurrences);
    return display ? { slug, label: display.label, count: occurrences.length } : null;
  })
  .filter((c): c is { slug: string; label: string; count: number } => c !== null)
  .sort((a, b) => (b.count - a.count) || (a.label < b.label ? -1 : a.label > b.label ? 1 : 0))
  .slice(0, TAG_CHIP_ROW_CAP);
---

<Base title={siteName} description="Curated AI-summarized digests of oncology updates." wide={true}>
  {digests.length > 0 && <SiteNav />}

  <div class="home-grid">
    <div class="home-main">
  {latest ? (
    <section class="hero-tldr" aria-label="Latest digest summary">
      <div class="hero-meta">
        <span class="hero-date">{latest.date}</span>
        {latest.conference && (
          <span class="hero-conf">{latest.conference.name}</span>
        )}
      </div>
      {latest.digest.top_line && (
        <p class="hero-topline" set:html={linkifyCitations(latest.digest.top_line)} />
      )}
      <p class="hero-body" set:html={linkifyCitations(latest.digest.tldr)} />
      <a class="hero-cta" href={`/${latest.date}/`}>read the full digest →</a>
    </section>
  ) : (
    <p style="font-size:1.05rem;color:var(--fg-muted);margin-top:0">
      Daily curated digests of the most impactful oncology updates on X,
      organized by topic and AI-summarized. More frequent during major meetings.
    </p>
  )}

  {digests.length === 0 && (
    <p style="margin-top:2rem;color:var(--fg-muted)">
      No digests yet — check back soon.
    </p>
  )}

  {feed.length > 0 && (
    <RecentFeed
      items={feed.slice(0, HOME_FEED_LIMIT)}
      totalCount={feed.length}
      allIds={feed.map((r) => `${r.date}#${r.slug}`)}
      siteById={Object.fromEntries(feed.map((r) => [`${r.date}#${r.slug}`, r.disease_site]))}
      browseAll={feed.length > HOME_FEED_LIMIT
        ? { href: '/studies/', label: `Browse all ${feed.length} studies` }
        : null}
    />
  )}
    </div>

    <aside class="home-aside" aria-label="Browse and activity">
  {conferences.length > 0 && (
    <section class="conf-section">
      <h2 class="section-label">Conferences</h2>
      <ul class="conf-list">
        {conferences.map((conf) => (
          <li>
            <a class="conf-chip" href={`/conferences/${conf.slug}/`}>
              {conf.name} <span class="conf-meta">· {conf.dates.length}d</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* v0.10 home page tag surfaces. Both live BELOW the recent-studies feed
       per design pass 1 lock — the reader's primary scan (disease-site nav →
       hero TL;DR → recent feed) is preserved, and tag discovery surfaces
       are tertiary: readers scroll to them when curious, not encounter them
       mid-scan. Empty-state copy renders when no tags carry studies yet
       (fresh corpus pre-backfill or pre-first-digest). */}
  {digests.length > 0 && tagActivity.length > 0 && (
    <section class="tag-activity-section" aria-labelledby="tag-activity-heading">
      <h2 class="section-label" id="tag-activity-heading">Active tags · {tagActivity[0]!.counts.length}d window</h2>
      <ul class="tag-activity-list">
        {tagActivity.map((row) => {
          const arrow = row.trend === 'up' ? '↑' : row.trend === 'down' ? '↓' : '→';
          return (
            <li class="tag-activity-row">
              <a href={`/tags/${row.slug}/`} class="tag-activity-name">{row.label}</a>
              <Sparkline counts={row.counts} label={row.label} trend={row.trend} />
              <span class="tag-activity-count">{row.totalRecent}</span>
              <span class="tag-activity-arrow" aria-hidden="true">{arrow}</span>
            </li>
          );
        })}
      </ul>
    </section>
  )}
  {digests.length > 0 && tagActivity.length === 0 && (
    <section class="tag-activity-section" aria-labelledby="tag-activity-heading">
      <h2 class="section-label" id="tag-activity-heading">Active tags</h2>
      <p class="tag-empty">Tag activity will appear after the next digest.</p>
    </section>
  )}

  {tagChipRow.length > 0 && (
    <section class="tag-chip-section" aria-labelledby="tag-chip-row-heading">
      <h2 class="section-label" id="tag-chip-row-heading">Tags · {tagChipRow.length}{tagChipRow.length === TAG_CHIP_ROW_CAP && '+'}</h2>
      <p class="tag-chip-row">
        {tagChipRow.map((c, i) => (
          <Fragment>
            {i > 0 && <span class="tag-chip-sep" aria-hidden="true">·</span>}
            <a class="tag-chip-link" href={`/tags/${c.slug}/`}>{c.label}</a>
          </Fragment>
        ))}
        {/* "more →" only when the displayable count was actually capped — not
            when the cap matched the natural population. Codex review caught
            the misleading link case. */}
        {tagChipRow.length === TAG_CHIP_ROW_CAP && tagSummaries.size > TAG_CHIP_ROW_CAP && (
          <Fragment>
            <span class="tag-chip-sep" aria-hidden="true">·</span>
            <a class="tag-chip-link tag-chip-more" href="/tags/">more →</a>
          </Fragment>
        )}
      </p>
    </section>
  )}
    </aside>
  </div>
</Base>

<style>
  /* v0.14.8: desktop editorial layout. The home was one narrow column marooned
     in empty side margin on wide screens; now the primary scan (hero + studies
     feed) fills a wide main column and the secondary surfaces (conferences, tag
     activity, tag chips) sit in a sticky right sidebar. Mobile stays a single
     stacked column (main first, then the sidebar content). */
  .home-grid { display: block; }
  .home-main { min-width: 0; }
  .home-aside { min-width: 0; }
  @media (min-width: 1024px) {
    .home-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 3rem;
      align-items: start;
    }
    .home-aside {
      position: sticky;
      top: 1.5rem;
    }
    /* Top-align the sidebar with the main column. */
    .home-aside > :first-child { margin-top: 0; }
    /* Keep the hero callout from stretching uncomfortably wide in the roomier
       main column; the feed rows below can use the full width. */
    .hero-tldr { max-width: 760px; }
  }

  /* Hero TL;DR callout. */
  .hero-tldr {
    margin: 0 0 1.5rem;
    padding: 1.1rem 1.25rem 1rem;
    background: var(--accent-bg);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 6px;
  }
  /* Hero meta is supporting metadata — date + optional conference badge.
     Headline is the top_line below; meta should not compete with it. */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.55rem;
  }
  .hero-date { font-weight: 500; }
  .hero-conf {
    padding: 0.05rem 0.45rem;
    background: var(--bg-card);
    color: var(--accent);
    border-radius: 999px;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .hero-topline {
    margin: 0 0 0.55rem;
    font-size: 1.12rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--fg);
  }
  .hero-body {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--fg);
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.55rem 1rem;
    margin: 0.85rem -1rem -0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .hero-cta:hover { text-decoration: underline; }

  /* Section labels reused across conferences + recent. */
  .section-label {
    margin: 0 0 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* Conferences strip. */
  .conf-section { margin-top: 2rem; }
  .conf-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .conf-chip {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--fg);
  }
  .conf-chip:hover { border-color: var(--accent); }
  .conf-meta { color: var(--fg-muted); }

  /* ── v0.10 30-day tag activity histogram. Tufte-restrained one-off:
       inline sparkline (Sparkline.astro) + count + trend arrow per row.
       Five rows max (top-N by recency-weighted count). Lives just above the
       recent feed so a returning reader sees "what's trending" at a glance.
       No semantic color on the arrow per design pass 4 (verdict pill owns
       the 6-emoji color vocabulary). ── */
  .tag-activity-section {
    margin: 2.5rem 0 0;
  }
  .tag-activity-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .tag-activity-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.7;
  }
  .tag-activity-name {
    color: var(--fg);
    text-decoration: none;
    flex: 0 0 auto;
    min-width: 6.5rem;
  }
  .tag-activity-name:hover { color: var(--accent); }
  .tag-activity-row .sparkline {
    flex: 0 0 auto;
  }
  .tag-activity-count {
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .tag-activity-arrow {
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1;
  }
  .tag-empty {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ── v0.10 mobile TAGS chip row. Plain text meta-line per DESIGN.md
       "cards earn their existence": no border, no fill, no uppercase.
       --font-sans 0.78rem --fg-muted matches SearchBox result-meta and
       StudyCard chip row. flex-wrap so long lists become multi-line on
       narrow viewports rather than overflowing. Lives at the bottom of
       the home page per design pass 1 ("tertiary navigation; readers scroll
       to it"). The "more →" link points at the full /tags/ index when the
       cap kicks in. ── */
  .tag-chip-section {
    margin: 2.5rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .tag-chip-row {
    margin: 0.5rem 0 0;
    padding: 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    line-height: 1.6;
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.5rem;
    align-items: baseline;
  }
  .tag-chip-link {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .tag-chip-link:hover { color: var(--accent); }
  .tag-chip-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .tag-chip-more {
    color: var(--accent);
  }
  .tag-chip-sep {
    color: var(--fg-muted);
    user-select: none;
  }
</style>
