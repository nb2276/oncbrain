<script>
  // Wire the share buttons + the "new since last visit" marker on this page.
  // Astro hoists + dedupes identical inline scripts across pages.
  import { initShareButtons } from '../lib/share-script.ts';
  import { initWhatsNew } from '../lib/whats-new.ts';
  function init() {
    initShareButtons();
    initWhatsNew();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
