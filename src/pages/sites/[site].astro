---
import Base from '../../layouts/Base.astro';
import { listSiteSummaries, type SiteSummary } from '../../lib/digest-data.ts';
import { getDiseaseSite } from '../../lib/disease-sites.ts';
import { linkifyCitations } from '../../lib/extract.ts';
import { isSafeImageUrl } from '../../lib/vision-ocr.ts';

export async function getStaticPaths() {
  return listSiteSummaries().map((s) => ({
    params: { site: s.disease_site },
    props: { summary: s },
  }));
}

interface Props {
  summary: SiteSummary;
}

const { summary } = Astro.props as Props;
const meta = getDiseaseSite(summary.disease_site);

// Group occurrences by date so the page reads as a reverse-chronological
// stack with date headers, like a per-site journal.
const byDate = new Map<string, typeof summary.occurrences>();
for (const occ of summary.occurrences) {
  if (!byDate.has(occ.date)) byDate.set(occ.date, []);
  byDate.get(occ.date)!.push(occ);
}
const dates = Array.from(byDate.keys());
---

<Base title={`${meta.label} — oncbrain`} description={`Studies aggregated for ${meta.label} across all digest dates.`}>
  <nav class="crumb">
    <a href="/">← all dates</a>
    <a href="/sites/">browse by site</a>
  </nav>

  <header class="site-header">
    <h2>
      <span class="emoji" aria-hidden="true">{meta.emoji}</span>
      {meta.label}
    </h2>
    <p class="meta">
      {summary.occurrences.length} stud{summary.occurrences.length === 1 ? 'y' : 'ies'} across
      {dates.length} date{dates.length === 1 ? '' : 's'}
    </p>
  </header>

  {dates.map((date) => {
    const occurrences = byDate.get(date)!;
    const conf = occurrences[0]!.conference;
    return (
      <section class="date-block">
        <h3 class="date-heading">
          <a href={`/${date}/`}>{date}</a>
          {conf && <span class="conf-pill">{conf.name}</span>}
        </h3>
        {occurrences.map((occ) => (
          <div class="study">
            <h4 class="study-name">
              {occ.study.name}
              {occ.study.nct && (
                <a class="citation study-nct" href={`https://clinicaltrials.gov/study/${occ.study.nct}`} target="_blank" rel="noopener">{occ.study.nct}</a>
              )}
            </h4>
            <p class="study-tldr" set:html={linkifyCitations(occ.study.tldr)} />
            {occ.study.key_figure_url && isSafeImageUrl(occ.study.key_figure_url) && (
              <figure class="study-figure">
                <img
                  src={occ.study.key_figure_url}
                  alt={typeof occ.study.key_figure_caption === 'string' ? occ.study.key_figure_caption : occ.study.name}
                  loading="lazy"
                />
                {typeof occ.study.key_figure_caption === 'string' && (
                  <figcaption>{occ.study.key_figure_caption}</figcaption>
                )}
                {occ.study.key_figure_caption && typeof occ.study.key_figure_caption !== 'string' && (
                  <figcaption>
                    <div class="study-table-wrap caption-table-wrap">
                      <table class="study-table">
                        <thead>
                          <tr>
                            {occ.study.key_figure_caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                          </tr>
                        </thead>
                        <tbody>
                          {occ.study.key_figure_caption.rows.map((row) => (
                            <tr>
                              {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </figcaption>
                )}
              </figure>
            )}
            {occ.study.details.length > 0 && (
              <ul class="study-details">
                {occ.study.details.map((d) => {
                  if (typeof d === 'string') {
                    return <li set:html={linkifyCitations(d)} />;
                  }
                  if ('table' in d) {
                    return (
                      <li>
                        <span set:html={linkifyCitations(d.text)} />
                        <div class="study-table-wrap">
                          <table class="study-table">
                            <thead>
                              <tr>
                                {d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                              </tr>
                            </thead>
                            <tbody>
                              {d.table.rows.map((row) => (
                                <tr>
                                  {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </li>
                    );
                  }
                  return (
                    <li>
                      <span set:html={linkifyCitations(d.text)} />
                      {d.subdetails.length > 0 && (
                        <ul class="study-subdetails">
                          {d.subdetails.map((s) => (<li set:html={linkifyCitations(s)} />))}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            )}
            {(() => {
              const papersList = occ.papers ?? [];
              const slidesList = occ.slides ?? [];
              const total = occ.bookmarks.length + papersList.length + slidesList.length;
              if (total === 0) return null;
              const badges: string[] = [];
              if (occ.bookmarks.length > 0) badges.push(`🐦 ${occ.bookmarks.length} tweet${occ.bookmarks.length === 1 ? '' : 's'}`);
              if (papersList.length > 0) badges.push(`📄 ${papersList.length} paper${papersList.length === 1 ? '' : 's'}`);
              if (slidesList.length > 0) badges.push(`🩻 ${slidesList.length} slide${slidesList.length === 1 ? '' : 's'}`);
              const toSlideUrl = (fp: string) =>
                fp.startsWith('data/slide-photos/') ? '/slides/' + fp.slice('data/slide-photos/'.length) : fp;
              return (
                <details class="sources">
                  <summary>📚 Sources · {badges.join(' · ')}</summary>
                  <div class="source-stack">
                    {occ.bookmarks.map((b) => {
                      if (b.html) {
                        return (
                          <div class="tw-wrap">
                            <Fragment set:html={b.html} />
                            {b.note && <div class="source-note">📝 {b.note}</div>}
                          </div>
                        );
                      }
                      return (
                        <div class="source-fallback">
                          <div class="source-meta">
                            <span>{b.author_name || b.author_handle || 'unknown'}</span>
                            <a href={b.url} target="_blank" rel="noopener">view on X →</a>
                          </div>
                          <div class="source-text" set:html={linkifyCitations(b.text)} />
                          {b.note && <div class="source-note">📝 {b.note}</div>}
                        </div>
                      );
                    })}
                    {papersList.map((p) => (
                      <div class="source-paper">
                        <div class="source-meta">
                          <span class="source-type-pill">📄 PAPER</span>
                          <span>{p.authors.slice(0, 3).join('; ')}{p.authors.length > 3 ? ' et al.' : ''}</span>
                          {p.journal && (
                            <span class="paper-journal">
                              · <em>{p.journal}</em>{p.pub_date ? ` (${p.pub_date.slice(0, 7)})` : ''}
                            </span>
                          )}
                        </div>
                        <div class="paper-title">{p.title}</div>
                        <div class="paper-links">
                          <a href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener">PMID {p.pmid} →</a>
                          {p.doi && <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">doi</a>}
                          {p.pmc_id && (
                            <a href={`https://www.ncbi.nlm.nih.gov/pmc/articles/${p.pmc_id}/`} target="_blank" rel="noopener">full text (PMC)</a>
                          )}
                        </div>
                        {p.abstract && (
                          <details class="paper-abstract">
                            <summary>Abstract</summary>
                            <div class="paper-abstract-body" set:html={linkifyCitations(p.abstract.replace(/\n/g, '<br/>'))} />
                          </details>
                        )}
                        {p.note && <div class="source-note">📝 {p.note}</div>}
                      </div>
                    ))}
                    {slidesList.map((slide) => (
                      <div class="source-slide">
                        <div class="source-meta">
                          <span class="source-type-pill">🩻 SLIDE</span>
                          {slide.source_label && <span>{slide.source_label}</span>}
                        </div>
                        <img
                          src={toSlideUrl(slide.file_path)}
                          alt={slide.source_label ?? 'Slide photograph'}
                          loading="lazy"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
                        />
                        <div class="slide-fallback" style="display:none">
                          (Slide image not published — curator-private.)
                        </div>
                        {slide.note && <div class="source-note">📝 {slide.note}</div>}
                      </div>
                    ))}
                  </div>
                </details>
              );
            })()}
          </div>
        ))}
      </section>
    );
  })}
</Base>

<style>
  .crumb {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--fg-muted);
  }
  .crumb a { color: var(--fg-muted); text-decoration: none; margin-right: 0.5rem; }
  .crumb a + a::before { content: '· '; margin-right: 0.25rem; color: var(--border); }
  .crumb a:hover { color: var(--accent); }

  .site-header h2 {
    margin: 0;
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex; align-items: baseline; gap: 0.55rem;
  }
  .emoji { font-size: 1.8rem; }
  .meta {
    margin: 0.35rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .date-block {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .date-heading {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.55rem;
  }
  .date-heading a {
    color: inherit;
    text-decoration: none;
    font-family: var(--font-sans);
    letter-spacing: 0.01em;
  }
  .date-heading a:hover { color: var(--accent); }
  .conf-pill {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 500;
    padding: 0.12rem 0.55rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
  }

  /* Per-study card — shared with [date].astro visually but inlined here for
     section scope. */
  .study {
    margin: 0 0 1.1rem;
    padding: 0.95rem 1.1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
  }
  .study-name {
    margin: 0 0 0.35rem;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
  }
  .study-nct {
    font-size: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .study-tldr {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    line-height: 1.45;
  }
  .study-details {
    margin: 0;
    padding-left: 1.2rem;
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .study-details li { margin: 0.25rem 0; }
  .study-subdetails {
    margin: 0.2rem 0 0.4rem;
    padding-left: 1.1rem;
    list-style: none;
  }
  .study-subdetails li {
    margin: 0.15rem 0;
    font-size: 0.92rem;
    position: relative;
    padding-left: 0.7rem;
  }
  .study-subdetails li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .study-table-wrap {
    margin: 0.4rem 0 0.6rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-card);
  }
  .study-table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.88rem;
    font-family: var(--font-sans);
    line-height: 1.4;
  }
  .study-table th,
  .study-table td {
    padding: 0.45rem 0.7rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .study-table tbody tr:last-child td { border-bottom: none; }
  .study-table th {
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--fg-muted);
    background: var(--bg-card);
  }
  @media (max-width: 600px) {
    .study-table th:first-child,
    .study-table td:first-child {
      position: sticky;
      left: 0;
      background: var(--bg-card);
      border-right: 1px solid var(--border);
      z-index: 1;
    }
  }

  .study-figure { margin: 0.55rem 0 0.75rem; padding: 0; }
  .study-figure img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .study-figure figcaption {
    margin-top: 0.4rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .caption-table-wrap {
    margin-top: 0.4rem;
  }
  .caption-table-wrap .study-table {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
  }

  .sources { margin-top: 0.85rem; }
  .sources summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
  }
  .source-stack {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .tw-wrap :global(.twitter-tweet) { margin: 0 !important; }
  .tw-wrap :global(iframe) { max-width: 100% !important; }
  .source-fallback {
    background: var(--citation-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }
  .source-text { line-height: 1.5; white-space: pre-wrap; }
  .source-note {
    margin-top: 0.45rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-style: italic;
  }
  .source-paper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    font-size: 0.92rem;
  }
  .source-type-pill {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 3px;
    margin-right: 0.4rem;
    vertical-align: 1px;
  }
  .paper-title {
    margin: 0.35rem 0 0.4rem;
    font-family: var(--font-serif);
    font-weight: 600;
    line-height: 1.35;
  }
  .paper-journal { color: var(--fg-muted); font-family: var(--font-sans); font-size: 0.82rem; }
  .paper-links {
    display: flex; flex-wrap: wrap; gap: 0.8rem;
    font-family: var(--font-sans); font-size: 0.82rem; margin-bottom: 0.4rem;
  }
  .paper-links a { color: var(--accent); }
  .paper-abstract { margin-top: 0.4rem; }
  .paper-abstract summary {
    cursor: pointer; font-family: var(--font-sans); font-size: 0.82rem;
    color: var(--fg-muted); padding: 0.25rem 0;
  }
  .paper-abstract summary:hover { color: var(--accent); }
  .paper-abstract-body { margin-top: 0.4rem; line-height: 1.5; color: var(--fg); }
  .source-slide {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-slide img {
    display: block; max-width: 100%; height: auto;
    border-radius: 4px; border: 1px solid var(--border);
    margin-top: 0.5rem;
  }
  .slide-fallback {
    margin-top: 0.5rem; padding: 0.5rem 0.7rem;
    background: var(--bg); border: 1px dashed var(--border);
    border-radius: 4px;
    font-family: var(--font-sans); font-size: 0.82rem;
    color: var(--fg-muted); text-align: center;
  }

  @media (max-width: 600px) {
    .site-header h2 { font-size: 1.25rem; }
    .emoji { font-size: 1.5rem; }
    .study { padding: 0.8rem 0.9rem; }
  }
</style>
