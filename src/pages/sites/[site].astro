---
import Base from '../../layouts/Base.astro';
import StudyCard from '../../components/StudyCard.astro';
import TriageRail from '../../components/TriageRail.astro';
import TagFilterRail from '../../components/TagFilterRail.astro';
import { listSiteSummaries, type SiteSummary } from '../../lib/digest-data.ts';
import { getDiseaseSite } from '../../lib/disease-sites.ts';
import { railEmojiForStudy } from '../../lib/verdict.ts';
import { studyDataTags } from '../../lib/study-data-tags.ts';
import { buildFilterRailOptions } from '../../lib/tag-foundations.ts';
import {
  buildSiblingPreviews,
  listDigestsStrict,
  studyKeyString,
  studyTagChips,
} from '../../lib/tag-index.ts';

export async function getStaticPaths() {
  return listSiteSummaries().map((s) => ({
    params: { site: s.disease_site },
    props: { summary: s },
  }));
}

interface Props {
  summary: SiteSummary;
}

const { summary } = Astro.props as Props;
const meta = getDiseaseSite(summary.disease_site);

// v0.10: tag chip + sibling helpers. Sibling map computed ONCE over the full
// corpus and looked up per-occurrence (NOT per-render-call inside the map
// callback — that would be O(N²) in the corpus).
const siblingPreviews = buildSiblingPreviews(listDigestsStrict());

// Group occurrences by date so the page reads as a reverse-chronological
// stack with date headers, like a per-site journal.
const byDate = new Map<string, typeof summary.occurrences>();
for (const occ of summary.occurrences) {
  if (!byDate.has(occ.date)) byDate.set(occ.date, []);
  byDate.get(occ.date)!.push(occ);
}
const dates = Array.from(byDate.keys());

// Stable per-occurrence anchor (date-prefixed so the same trial across dates
// doesn't collide) — used for both the card id and the triage-rail jump link.
const anchorByOcc = new Map<(typeof summary.occurrences)[number], string>();
for (const occ of summary.occurrences) {
  // Use the COLLISION-RESOLVED slug (assignSlugsForDate, computed by
  // listSiteSummaries), not a bare deriveSlug. Inbound share/deep links from
  // the date page + home feed are built with the resolved slug (e.g. "-2"); a
  // bare slug here would emit duplicate ids and a "#...-2" link that lands on
  // the wrong card / nowhere when two studies on a date share a base slug.
  anchorByOcc.set(occ, `${occ.date}-${occ.resolvedSlug}`);
}
const railItems = summary.occurrences.map((occ) => ({
  href: `#${anchorByOcc.get(occ)}`,
  name: occ.study.name,
  verdictEmoji: railEmojiForStudy(occ.study),
}));

// v0.11 PR-2: filter options scoped to this site's studies.
const filterOptions = buildFilterRailOptions(
  summary.occurrences.map((occ) => ({
    study: occ.study,
    conferenceSlug: occ.conference?.slug ?? null,
    conferenceLabel: occ.conference?.name ?? null,
  })),
);
---

<Base title={`${meta.label} — oncbrain`} description={`Studies aggregated for ${meta.label} across all digest dates.`} wide={true} ogImage={`/og/sites/${summary.disease_site}.png`}>
  <TagFilterRail
    modality={filterOptions.modality}
    intent={filterOptions.intent}
    methodology={filterOptions.methodology}
    verdict={filterOptions.verdict}
    meeting={filterOptions.meeting}
    totalCount={summary.occurrences.length}
  />
  <TriageRail items={railItems} wide={true} />
  <nav class="crumb">
    <a href="/">← all dates</a>
    <a href="/sites/">browse by site</a>
  </nav>

  <header class="site-header">
    <h2>
      <span class="emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
      {meta.label}
    </h2>
    <p class="meta">
      {summary.occurrences.length} stud{summary.occurrences.length === 1 ? 'y' : 'ies'} across
      {dates.length} date{dates.length === 1 ? '' : 's'}
    </p>
  </header>

  {dates.map((date) => {
    const occurrences = byDate.get(date)!;
    const conf = occurrences[0]!.conference;
    return (
      <section class="date-block">
        <h3 class="date-heading">
          <a href={`/${date}/`}>{date}</a>
          {conf && <span class="conf-pill">{conf.name}</span>}
        </h3>
        {occurrences.map((occ) => {
          const siblingKey = studyKeyString({ date: occ.date, resolvedSlug: occ.resolvedSlug });
          return (
            <StudyCard
              study={occ.study}
              anchorId={anchorByOcc.get(occ)}
              bookmarks={occ.bookmarks}
              papers={occ.papers ?? []}
              slides={occ.slides ?? []}
              shareUrl={`/sites/${summary.disease_site}/#${anchorByOcc.get(occ)}`}
              tagChips={studyTagChips(occ.study, occ.conference)}
              siblings={siblingPreviews.get(siblingKey) ?? []}
              dataTags={studyDataTags(occ.study, summary.disease_site, occ.conference?.slug ?? null)}
            />
          );
        })}
      </section>
    );
  })}
</Base>

<style>
  /* Pinned to the top while scrolling a long site list so the nav stays
     reachable. Solid page-colored background + bottom border so cards scroll
     under it. */
  .crumb {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0 0 0.75rem;
    padding: 0.55rem 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--fg-muted);
  }
  .crumb a { color: var(--fg-muted); text-decoration: none; margin-right: 0.5rem; }
  .crumb a + a::before { content: '· '; margin-right: 0.25rem; color: var(--border); }
  .crumb a:hover { color: var(--accent); }

  .site-header h2 {
    margin: 0;
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex; align-items: baseline; gap: 0.55rem;
  }
  .emoji { font-size: 1.8rem; }
  .meta {
    margin: 0.35rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .date-block {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .date-heading {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.55rem;
  }
  .date-heading a {
    color: inherit;
    text-decoration: none;
    font-family: var(--font-sans);
    letter-spacing: 0.01em;
  }
  .date-heading a:hover { color: var(--accent); }
  .conf-pill {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 500;
    padding: 0.12rem 0.55rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
  }

  @media (max-width: 600px) {
    .site-header h2 { font-size: 1.25rem; }
    .emoji { font-size: 1.5rem; }
  }
</style>
