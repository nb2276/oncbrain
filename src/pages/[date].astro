---
import Base from '../layouts/Base.astro';
import StudyCard from '../components/StudyCard.astro';
import TriageRail from '../components/TriageRail.astro';
import {
  listDigests,
  type DigestArtifact,
  type DigestStudy,
  type DigestSourceRef,
  type DigestArtifactPaper,
  type DigestArtifactSlide,
} from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';
import { getDiseaseSite } from '../lib/disease-sites.ts';
import { assignSlugsForDate } from '../lib/slug-resolve.ts';
import { verdictMetaFor } from '../lib/verdict.ts';

export async function getStaticPaths() {
  return listDigests().map((artifact) => ({
    params: { date: artifact.date },
    props: { artifact },
  }));
}

interface Props {
  artifact: DigestArtifact;
}

const { artifact } = Astro.props as Props;
const { date, conference, digest, bookmarks, generated_at } = artifact;

const bookmarksById = new Map(bookmarks.map((b) => [b.id, b]));
const papersById = new Map((artifact.papers ?? []).map((p) => [p.id, p]));
const slidesById = new Map((artifact.slides ?? []).map((s) => [s.id, s]));
const generatedDate = new Date(generated_at).toISOString().slice(0, 10);
const title = conference ? `${conference.name} — ${date}` : date;

// Per-date slug resolution: walk every study on this date in render order and
// disambiguate collisions from the deriveSlug() fallback. Indexed by study
// reference identity (the same DigestStudy object is rendered below).
const allStudiesOnDate = digest.sites.flatMap((s) => s.studies);
const resolvedSlugs = assignSlugsForDate(allStudiesOnDate);
const slugByStudy = new Map<DigestStudy, string>();
allStudiesOnDate.forEach((s, i) => slugByStudy.set(s, resolvedSlugs[i]!));

// Desktop triage rail: one jump-link per study, in render order, marked with
// its verdict emoji (neutral dot when a study carries no verdict).
const railItems = allStudiesOnDate.map((study) => ({
  href: `#${slugByStudy.get(study)}`,
  name: study.name,
  verdictEmoji: verdictMetaFor(study.verdict?.soc_implication)?.emoji ?? '·',
}));

// Per-study render data precomputed so the template stays a single expression
// per study (Astro's parser dislikes multi-statement arrow bodies in JSX):
// the "Sourced from" author list and the study's resolved source arrays.
// Authors carry their source type so the card styles tweet @handles
// (monospace) differently from paper attributions (italic surname).
type StudyAuthor = { name: string; kind: 'tweet' | 'paper' };
type SourceArrays = {
  bookmarks: DigestArtifact['bookmarks'];
  papers: DigestArtifactPaper[];
  slides: DigestArtifactSlide[];
};
const authorsByStudy = new Map<DigestStudy, StudyAuthor[]>();
const sourcesByStudy = new Map<DigestStudy, SourceArrays>();
for (const study of allStudiesOnDate) {
  // v0.5: typed refs preferred; tweet_ids is the back-compat fallback.
  const refs: DigestSourceRef[] = study.source_ids ?? study.tweet_ids.map((id) => ({ type: 'tweet' as const, id }));

  const authors: StudyAuthor[] = [];
  const seen = new Set<string>();
  for (const ref of refs) {
    let candidate: StudyAuthor | null = null;
    if (ref.type === 'tweet') {
      const b = bookmarksById.get(ref.id);
      const name = b?.author_handle ?? b?.author_name ?? null;
      if (name) candidate = { name, kind: 'tweet' };
    } else if (ref.type === 'paper') {
      const p = papersById.get(ref.id);
      const first = p?.authors?.[0];
      // "Siva" reads as a partial citation; "Siva et al." reads as a proper
      // attribution. Append the suffix when there's more than one author.
      if (first) {
        const name = (p?.authors?.length ?? 0) > 1 ? `${first} et al.` : first;
        candidate = { name, kind: 'paper' };
      }
    }
    if (candidate && !seen.has(candidate.name)) {
      seen.add(candidate.name);
      authors.push(candidate);
    }
  }
  authorsByStudy.set(study, authors);

  sourcesByStudy.set(study, {
    bookmarks: refs
      .filter((r) => r.type === 'tweet')
      .map((r) => bookmarksById.get(r.id))
      .filter((b): b is DigestArtifact['bookmarks'][number] => Boolean(b)),
    papers: refs
      .filter((r) => r.type === 'paper')
      .map((r) => papersById.get(r.id))
      .filter((p): p is DigestArtifactPaper => Boolean(p)),
    slides: refs
      .filter((r) => r.type === 'slide')
      .map((r) => slidesById.get(r.id))
      .filter((s): s is DigestArtifactSlide => Boolean(s)),
  });
}
---

<Base title={title} description={digest.top_line || digest.tldr} wide={true}>
  <TriageRail items={railItems} wide={true} />
  <nav class="crumb">
    <a href="/">← all dates</a>
    {conference && <a href={`/conferences/${conference.slug}/`}>{conference.name}</a>}
    <a href="/sites/">browse by site</a>
  </nav>

  <header class="day-header">
    <h2>
      {date}
      {conference && <span class="conf-pill">{conference.name}</span>}
    </h2>
    <p class="meta">digest generated {generatedDate}</p>
  </header>

  <section class="topline" aria-label="Top line">
    <div class="topline-body" set:html={linkifyCitations(digest.top_line)} />
  </section>

  <section class="tldr">
    <div class="section-label">TL;DR</div>
    <div set:html={linkifyCitations(digest.tldr)} />
  </section>

  {digest.sites.map((site) => {
    const meta = getDiseaseSite(site.disease_site);
    return (
      <article class="site">
        <h3 class="site-heading">
          <a href={`/sites/${meta.slug}/`} class="site-anchor">
            <span class="site-emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
            <span class="site-label">{meta.label}</span>
          </a>
        </h3>
        {site.intro && (
          <p class="site-intro" set:html={linkifyCitations(site.intro)} />
        )}

        {site.studies.map((study) => (
          <StudyCard
            study={study}
            anchorId={slugByStudy.get(study)}
            authors={authorsByStudy.get(study)}
            bookmarks={sourcesByStudy.get(study)!.bookmarks}
            papers={sourcesByStudy.get(study)!.papers}
            slides={sourcesByStudy.get(study)!.slides}
            showOpenQuestions={true}
          />
        ))}

        {!site.studies.some((s) => s.open_questions && s.open_questions.length > 0) &&
          site.open_questions &&
          site.open_questions.length > 0 && (
            <div class="open-questions">
              <div class="section-label">Open questions</div>
              <ul>
                {site.open_questions.map((q) => (<li set:html={linkifyCitations(q)} />))}
              </ul>
            </div>
          )}
      </article>
    );
  })}

  {digest.meta && (digest.meta.dropped.length > 0 || !digest.meta.ocr_available) && (
    <section class="disclosure" aria-label="Build disclosures">
      <div class="section-label">Build disclosures</div>
      <p>
        {digest.meta.studies_analyzed} of {digest.meta.clusters_total} study cluster{digest.meta.clusters_total === 1 ? '' : 's'} analyzed successfully.
        {!digest.meta.ocr_available && ' On-device OCR was unavailable for this build — figure captions omitted.'}
      </p>
      {digest.meta.dropped.length > 0 && (
        <details class="dropped">
          <summary>{digest.meta.dropped.length} cluster{digest.meta.dropped.length === 1 ? '' : 's'} dropped</summary>
          <ul>
            {digest.meta.dropped.map((d) => (
              <li><strong>{d.name}</strong> <span class="dropped-slug">({d.slug})</span><br /><span class="dropped-reason">{d.reason}</span></li>
            ))}
          </ul>
        </details>
      )}
    </section>
  )}
</Base>

<style>
  /* ── Breadcrumb / header ───────────────────────────────── */
  /* Pinned to the top while scrolling a long digest so the nav stays reachable.
     Solid page-colored background + bottom border so cards scroll under it. */
  .crumb {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0 0 0.75rem;
    padding: 0.55rem 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-family: var(--font-sans);
  }
  .crumb a { color: var(--fg-muted); text-decoration: none; margin-right: 0.5rem; }
  .crumb a + a::before { content: '· '; color: var(--border); margin-right: 0.25rem; }
  .crumb a:hover { color: var(--accent); }

  .day-header h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem;
  }
  .conf-pill {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.15rem 0.6rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .meta {
    margin: 0.35rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ── Top line ──────────────────────────────────────────── */
  .topline { margin-top: 2rem; }
  .topline-body {
    font-family: var(--font-serif);
    font-size: 1.65rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--fg);
  }

  /* ── TL;DR ─────────────────────────────────────────────── */
  .tldr {
    margin-top: 1.5rem;
    padding: 0.25rem 0 0.25rem 1.1rem;
    border-left: 3px solid var(--accent);
  }
  .tldr > div:not(.section-label) { line-height: 1.55; color: var(--fg-muted); }
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }

  /* ── Site sections ─────────────────────────────────────── */
  .site {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .site-heading {
    margin: 0 0 0.6rem;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .site-anchor {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
  }
  .site-anchor:hover .site-label { color: var(--accent); text-decoration: underline; }
  .site-emoji { font-size: 1.55rem; line-height: 1; }
  .site-intro {
    margin: 0.5rem 0 1.25rem;
    color: var(--fg-muted);
    line-height: 1.5;
    font-size: 0.95rem;
  }

  /* ── Disclosure (dropped clusters / OCR availability) ──── */
  .disclosure {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--border);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }
  .disclosure .section-label { margin-bottom: 0.4rem; }
  .disclosure p { margin: 0; }
  .dropped {
    margin-top: 0.6rem;
  }
  .dropped summary {
    cursor: pointer;
    padding: 0.25rem 0;
  }
  .dropped summary:hover { color: var(--accent); }
  .dropped ul { margin: 0.5rem 0 0; padding-left: 1.2rem; }
  .dropped li { margin: 0.4rem 0; }
  .dropped-slug { color: var(--border); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.78rem; }
  .dropped-reason { font-style: italic; }

  /* ── Open questions (site-level fallback) ──────────────── */
  .open-questions {
    margin-top: 1.5rem;
    padding: 0.85rem 1.1rem;
    background: var(--citation-bg);
    border-radius: 4px;
  }
  .open-questions ul { margin: 0; padding-left: 1.2rem; line-height: 1.55; }
  .open-questions li { margin: 0.25rem 0; }

  @media (max-width: 600px) {
    .topline-body { font-size: 1.18rem; }
    .site-heading { font-size: 1.1rem; }
    .site-emoji { font-size: 1.35rem; }
  }
</style>
