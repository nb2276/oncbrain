---
import Base from '../layouts/Base.astro';
import { listDigests, type DigestArtifact } from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';

export async function getStaticPaths() {
  return listDigests().map((artifact) => ({
    params: { date: artifact.date },
    props: { artifact },
  }));
}

interface Props {
  artifact: DigestArtifact;
}

const { artifact } = Astro.props as Props;
const { date, conference, digest, bookmarks, generated_at } = artifact;

const bookmarksById = new Map(bookmarks.map((b) => [b.id, b]));
const generatedDate = new Date(generated_at).toISOString().slice(0, 10);
const title = conference ? `${conference.name} — ${date}` : date;
---

<Base title={title} description={digest.top_line || digest.tldr}>
  <nav class="crumb">
    <a href="/">← all dates</a>
    {conference && <a href={`/conferences/${conference.slug}/`}>{conference.name}</a>}
  </nav>

  <header class="day-header">
    <h2>
      {date}
      {conference && <span class="conf-pill">{conference.name}</span>}
    </h2>
    <p class="meta">digest generated {generatedDate}</p>
  </header>

  <section class="topline" aria-label="Top line">
    <div class="topline-body" set:html={linkifyCitations(digest.top_line)} />
  </section>

  <section class="tldr">
    <div class="section-label">TL;DR</div>
    <div set:html={linkifyCitations(digest.tldr)} />
  </section>

  {digest.clusters.map((cluster) => (
    <article class="cluster">
      <h3>
        <span class="cluster-emoji" aria-hidden="true">{cluster.emoji}</span>
        <span class="cluster-topic">{cluster.topic}</span>
      </h3>

      <div class="imrd">
        <div class="block intro">
          <div class="block-label">🧪 Intro</div>
          <div set:html={linkifyCitations(cluster.intro)} />
        </div>

        {cluster.methods && (
          <div class="block methods">
            <div class="block-label">📐 Methods</div>
            <div set:html={linkifyCitations(cluster.methods)} />
          </div>
        )}

        <div class="block results">
          <div class="block-label">📊 Results</div>
          <ul>
            {cluster.results.map((r) => (
              <li set:html={linkifyCitations(r)} />
            ))}
          </ul>
        </div>

        {cluster.discussion && cluster.discussion.length > 0 && (
          <div class="block discussion">
            <div class="block-label">💭 Discussion</div>
            <ul>
              {cluster.discussion.map((d) => (
                <li set:html={linkifyCitations(d)} />
              ))}
            </ul>
          </div>
        )}
      </div>

      {cluster.tweet_ids.length > 0 && (
        <details class="sources">
          <summary>📚 Sources ({cluster.tweet_ids.length})</summary>
          <ul class="source-list">
            {cluster.tweet_ids.map((id) => {
              const b = bookmarksById.get(id);
              if (!b) return null;
              return (
                <li class="source-card">
                  <div class="source-meta">
                    <span class="source-who">
                      {b.author_name || b.author_handle || 'unknown'}
                      {b.author_handle && b.author_name && <span class="source-handle"> · {b.author_handle}</span>}
                    </span>
                    <a href={b.url} target="_blank" rel="noopener" class="source-link">view on X →</a>
                  </div>
                  <div class="source-text" set:html={linkifyCitations(b.text)} />
                  {b.note && <div class="source-note">📝 {b.note}</div>}
                </li>
              );
            })}
          </ul>
        </details>
      )}
    </article>
  ))}
</Base>

<style>
  /* ── Breadcrumb / header ───────────────────────────────────── */
  .crumb {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
  }
  .crumb a {
    color: var(--fg-muted);
    text-decoration: none;
    margin-right: 0.5rem;
  }
  .crumb a + a::before {
    content: '· ';
    color: var(--border);
    margin-right: 0.25rem;
  }
  .crumb a:hover {
    color: var(--accent);
  }
  .day-header h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
  }
  .conf-pill {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.15rem 0.55rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
  }
  .meta {
    margin: 0.35rem 0 0;
    font-size: 0.825rem;
    color: var(--fg-muted);
  }

  /* ── Top line (the lede) ────────────────────────────────────────
     Hero treatment: large serif, no chrome. This is the headline
     the reader screenshots and sends to a colleague. Should read
     like a journal title, not a callout card. */
  .topline {
    margin-top: 2rem;
    padding: 0;
  }
  .topline-body {
    font-family: var(--font-serif);
    font-size: 1.65rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--fg);
  }

  /* ── TL;DR ──────────────────────────────────────────────────────
     Subordinate to top_line but distinct from cluster bodies. Light
     left rule, no full card. */
  .tldr {
    margin-top: 1.5rem;
    padding: 0.25rem 0 0.25rem 1.1rem;
    border-left: 3px solid var(--accent);
    background: transparent;
  }
  .tldr > div:not(.section-label) {
    line-height: 1.55;
    color: var(--fg-muted);
  }
  /* Universal label: small caps, sans, tracked. Used on TL;DR + every
     cluster sub-section. Consistency removes one decision-point for
     the scanning reader. */
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }

  /* ── Cluster card ──────────────────────────────────────────── */
  .cluster {
    margin-top: 2.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .cluster h3 {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .cluster-emoji {
    font-size: 1.5rem;
    line-height: 1;
  }
  .cluster-topic {
    flex: 1;
  }

  /* ── IMRD blocks ───────────────────────────────────────────────────
     Intent: Results is THE block that needs a card (it carries the
     effect sizes the reader is scanning for). Intro / Methods /
     Discussion read as prose with a small uppercase label, so the
     cluster flows top-to-bottom like a journal paragraph instead of
     a 4-card dashboard. */
  .imrd {
    margin-top: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .block {
    /* Default: no card chrome. Just label + content. */
    padding: 0;
  }
  .block-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }
  .block > div:not(.block-label),
  .block > ul {
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
  }
  .block ul {
    padding-left: 1.25rem;
  }
  .block li {
    margin: 0.4rem 0;
  }
  /* Results is THE block. Carded, accent-tinted, slightly heavier label. */
  .block.results {
    background: var(--accent-bg);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    padding: 0.9rem 1.1rem;
  }
  .block.results .block-label {
    color: var(--accent);
  }

  /* ── Sources (collapsed by default) ────────────────────────── */
  .sources {
    margin-top: 1rem;
  }
  .sources summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-size: 0.85rem;
    padding: 0.4rem 0;
  }
  .sources summary:hover {
    color: var(--accent);
  }
  .source-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .source-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    font-size: 0.8rem;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .source-who {
    font-weight: 500;
  }
  .source-handle {
    color: var(--fg-muted);
    font-weight: 400;
  }
  .source-link {
    color: var(--accent);
    white-space: nowrap;
  }
  .source-text {
    white-space: pre-wrap;
    line-height: 1.5;
  }
  .source-note {
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .topline-body { font-size: 1.08rem; }
    .cluster h3 { font-size: 1.08rem; }
    .cluster-emoji { font-size: 1.35rem; }
    .block { padding: 0.75rem 0.85rem; }
  }
</style>
