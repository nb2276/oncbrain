---
import Base from '../layouts/Base.astro';
import { listDigests, type DigestArtifact } from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';
import { getDiseaseSite } from '../lib/disease-sites.ts';
import { isSafeImageUrl } from '../lib/vision-ocr.ts';
import { assignSlugsForDate } from '../lib/slug-resolve.ts';

export async function getStaticPaths() {
  return listDigests().map((artifact) => ({
    params: { date: artifact.date },
    props: { artifact },
  }));
}

interface Props {
  artifact: DigestArtifact;
}

const { artifact } = Astro.props as Props;
const { date, conference, digest, bookmarks, generated_at } = artifact;

const bookmarksById = new Map(bookmarks.map((b) => [b.id, b]));
const papersById = new Map((artifact.papers ?? []).map((p) => [p.id, p]));
const slidesById = new Map((artifact.slides ?? []).map((s) => [s.id, s]));
const generatedDate = new Date(generated_at).toISOString().slice(0, 10);
const title = conference ? `${conference.name} — ${date}` : date;

// v0.5: resolve a study's source list. Prefer source_ids (typed) when present;
// fall back to tweet_ids (legacy v0.4 artifacts).
type SourceRef = { type: 'tweet' | 'paper' | 'slide'; id: number };
function resolveSources(study: typeof digest.sites[number]['studies'][number]): SourceRef[] {
  if (study.source_ids && study.source_ids.length > 0) return study.source_ids;
  return study.tweet_ids.map((id) => ({ type: 'tweet' as const, id }));
}

// "data/slide-photos/<date>/<uuid>.jpg" → "/slides/<date>/<uuid>.jpg"
function toSlideUrl(filePath: string): string {
  if (filePath.startsWith('data/slide-photos/')) {
    return '/slides/' + filePath.slice('data/slide-photos/'.length);
  }
  return filePath;
}

// Per-date slug resolution: walk every study on this date in render order
// and disambiguate collisions from the deriveSlug() fallback. Indexed by
// study reference identity (the same DigestStudy object is rendered below).
const allStudiesOnDate = digest.sites.flatMap((s) => s.studies);
const resolvedSlugs = assignSlugsForDate(allStudiesOnDate);
const slugByStudy = new Map<typeof allStudiesOnDate[number], string>();
allStudiesOnDate.forEach((s, i) => slugByStudy.set(s, resolvedSlugs[i]!));
---

<Base title={title} description={digest.top_line || digest.tldr}>
  <nav class="crumb">
    <a href="/">← all dates</a>
    {conference && <a href={`/conferences/${conference.slug}/`}>{conference.name}</a>}
    <a href="/sites/">browse by site</a>
  </nav>

  <header class="day-header">
    <h2>
      {date}
      {conference && <span class="conf-pill">{conference.name}</span>}
    </h2>
    <p class="meta">digest generated {generatedDate}</p>
  </header>

  <section class="topline" aria-label="Top line">
    <div class="topline-body" set:html={linkifyCitations(digest.top_line)} />
  </section>

  <section class="tldr">
    <div class="section-label">TL;DR</div>
    <div set:html={linkifyCitations(digest.tldr)} />
  </section>

  {digest.sites.map((site) => {
    const meta = getDiseaseSite(site.disease_site);
    return (
      <article class="site">
        <h3 class="site-heading">
          <a href={`/sites/${meta.slug}/`} class="site-anchor">
            <span class="site-emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
            <span class="site-label">{meta.label}</span>
          </a>
        </h3>
        {site.intro && (
          <p class="site-intro" set:html={linkifyCitations(site.intro)} />
        )}

        {site.studies.map((study) => (
          <div class="study" id={slugByStudy.get(study)}>
            <h4 class="study-name">
              {study.name}
              {study.nct && (
                <a class="citation study-nct" href={`https://clinicaltrials.gov/study/${study.nct}`} target="_blank" rel="noopener">{study.nct}</a>
              )}
            </h4>
            <p class="study-tldr" set:html={linkifyCitations(study.tldr)} />
            {study.key_figure_url && isSafeImageUrl(study.key_figure_url) && (
              <figure class="study-figure">
                <img
                  src={study.key_figure_url}
                  alt={typeof study.key_figure_caption === 'string' ? study.key_figure_caption : study.name}
                  loading="lazy"
                />
                {typeof study.key_figure_caption === 'string' && (
                  <figcaption>{study.key_figure_caption}</figcaption>
                )}
                {study.key_figure_caption && typeof study.key_figure_caption !== 'string' && (
                  <figcaption>
                    <div class="study-table-wrap caption-table-wrap">
                      <table class="study-table">
                        <thead>
                          <tr>
                            {study.key_figure_caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                          </tr>
                        </thead>
                        <tbody>
                          {study.key_figure_caption.rows.map((row) => (
                            <tr>
                              {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </figcaption>
                )}
              </figure>
            )}
            {study.details.length > 0 && (
              <ul class="study-details">
                {study.details.map((d) => {
                  if (typeof d === 'string') {
                    return <li set:html={linkifyCitations(d)} />;
                  }
                  if ('table' in d) {
                    return (
                      <li>
                        <span set:html={linkifyCitations(d.text)} />
                        <div class="study-table-wrap">
                          <table class="study-table">
                            <thead>
                              <tr>
                                {d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                              </tr>
                            </thead>
                            <tbody>
                              {d.table.rows.map((row) => (
                                <tr>
                                  {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </li>
                    );
                  }
                  return (
                    <li>
                      <span set:html={linkifyCitations(d.text)} />
                      {d.subdetails.length > 0 && (
                        <ul class="study-subdetails">
                          {d.subdetails.map((s) => (<li set:html={linkifyCitations(s)} />))}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            )}
            {(() => {
              const sources = resolveSources(study);
              const tweetSrcs = sources.filter((s) => s.type === 'tweet');
              const paperSrcs = sources.filter((s) => s.type === 'paper');
              const slideSrcs = sources.filter((s) => s.type === 'slide');
              const total = tweetSrcs.length + paperSrcs.length + slideSrcs.length;
              if (total === 0) return null;
              const badges: string[] = [];
              if (tweetSrcs.length > 0) badges.push(`🐦 ${tweetSrcs.length} tweet${tweetSrcs.length === 1 ? '' : 's'}`);
              if (paperSrcs.length > 0) badges.push(`📄 ${paperSrcs.length} paper${paperSrcs.length === 1 ? '' : 's'}`);
              if (slideSrcs.length > 0) badges.push(`🩻 ${slideSrcs.length} slide${slideSrcs.length === 1 ? '' : 's'}`);
              return (
                <details class="sources">
                  <summary>📚 Sources · {badges.join(' · ')}</summary>
                  <div class="source-stack">
                    {tweetSrcs.map((s) => {
                      const b = bookmarksById.get(s.id);
                      if (!b) return null;
                      if (b.html) {
                        return (
                          <div class="tw-wrap">
                            <Fragment set:html={b.html} />
                            {b.note && <div class="source-note">📝 {b.note}</div>}
                          </div>
                        );
                      }
                      return (
                        <div class="source-fallback">
                          <div class="source-meta">
                            <span>{b.author_name || b.author_handle || 'unknown'}</span>
                            <a href={b.url} target="_blank" rel="noopener">view on X →</a>
                          </div>
                          <div class="source-text" set:html={linkifyCitations(b.text)} />
                          {b.note && <div class="source-note">📝 {b.note}</div>}
                        </div>
                      );
                    })}
                    {paperSrcs.map((s) => {
                      const p = papersById.get(s.id);
                      if (!p) return null;
                      return (
                        <div class="source-paper">
                          <div class="source-meta">
                            <span class="source-type-pill">📄 PAPER</span>
                            <span>
                              {p.authors.slice(0, 3).join('; ')}
                              {p.authors.length > 3 ? ' et al.' : ''}
                            </span>
                            {p.journal && (
                              <span class="paper-journal">
                                · <em>{p.journal}</em>{p.pub_date ? ` (${p.pub_date.slice(0, 7)})` : ''}
                              </span>
                            )}
                          </div>
                          <div class="paper-title">{p.title}</div>
                          <div class="paper-links">
                            <a href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener">
                              PMID {p.pmid} →
                            </a>
                            {p.doi && (
                              <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">
                                doi
                              </a>
                            )}
                            {p.pmc_id && (
                              <a
                                href={`https://www.ncbi.nlm.nih.gov/pmc/articles/${p.pmc_id}/`}
                                target="_blank"
                                rel="noopener"
                              >
                                full text (PMC)
                              </a>
                            )}
                          </div>
                          {p.abstract && (
                            <details class="paper-abstract">
                              <summary>Abstract</summary>
                              <div class="paper-abstract-body" set:html={linkifyCitations(p.abstract.replace(/\n/g, '<br/>'))} />
                            </details>
                          )}
                          {p.note && <div class="source-note">📝 {p.note}</div>}
                        </div>
                      );
                    })}
                    {slideSrcs.map((s) => {
                      const slide = slidesById.get(s.id);
                      if (!slide) return null;
                      const url = toSlideUrl(slide.file_path);
                      return (
                        <div class="source-slide">
                          <div class="source-meta">
                            <span class="source-type-pill">🩻 SLIDE</span>
                            {slide.source_label && <span>{slide.source_label}</span>}
                          </div>
                          <img
                            src={url}
                            alt={slide.source_label ?? 'Slide photograph'}
                            loading="lazy"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
                          />
                          <div class="slide-fallback" style="display:none">
                            (Slide image not published — curator-private.)
                          </div>
                          {slide.note && <div class="source-note">📝 {slide.note}</div>}
                        </div>
                      );
                    })}
                  </div>
                </details>
              );
            })()}
          </div>
        ))}

        {site.open_questions && site.open_questions.length > 0 && (
          <div class="open-questions">
            <div class="section-label">Open questions</div>
            <ul>
              {site.open_questions.map((q) => (<li set:html={linkifyCitations(q)} />))}
            </ul>
          </div>
        )}
      </article>
    );
  })}

  {digest.meta && (digest.meta.dropped.length > 0 || !digest.meta.ocr_available) && (
    <section class="disclosure" aria-label="Build disclosures">
      <div class="section-label">Build disclosures</div>
      <p>
        {digest.meta.studies_analyzed} of {digest.meta.clusters_total} study cluster{digest.meta.clusters_total === 1 ? '' : 's'} analyzed successfully.
        {!digest.meta.ocr_available && ' On-device OCR was unavailable for this build — figure captions omitted.'}
      </p>
      {digest.meta.dropped.length > 0 && (
        <details class="dropped">
          <summary>{digest.meta.dropped.length} cluster{digest.meta.dropped.length === 1 ? '' : 's'} dropped</summary>
          <ul>
            {digest.meta.dropped.map((d) => (
              <li><strong>{d.name}</strong> <span class="dropped-slug">({d.slug})</span><br /><span class="dropped-reason">{d.reason}</span></li>
            ))}
          </ul>
        </details>
      )}
    </section>
  )}
</Base>

<style>
  /* ── Breadcrumb / header ───────────────────────────────── */
  .crumb {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-family: var(--font-sans);
  }
  .crumb a { color: var(--fg-muted); text-decoration: none; margin-right: 0.5rem; }
  .crumb a + a::before { content: '· '; color: var(--border); margin-right: 0.25rem; }
  .crumb a:hover { color: var(--accent); }

  .day-header h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem;
  }
  .conf-pill {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.15rem 0.6rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .meta {
    margin: 0.35rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ── Top line ──────────────────────────────────────────── */
  .topline { margin-top: 2rem; }
  .topline-body {
    font-family: var(--font-serif);
    font-size: 1.65rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--fg);
  }

  /* ── TL;DR ─────────────────────────────────────────────── */
  .tldr {
    margin-top: 1.5rem;
    padding: 0.25rem 0 0.25rem 1.1rem;
    border-left: 3px solid var(--accent);
  }
  .tldr > div:not(.section-label) { line-height: 1.55; color: var(--fg-muted); }
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }

  /* ── Site sections ─────────────────────────────────────── */
  .site {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .site-heading {
    margin: 0 0 0.6rem;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .site-anchor {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
  }
  .site-anchor:hover .site-label { color: var(--accent); text-decoration: underline; }
  .site-emoji { font-size: 1.55rem; line-height: 1; }
  .site-intro {
    margin: 0.5rem 0 1.25rem;
    color: var(--fg-muted);
    line-height: 1.5;
    font-size: 0.95rem;
  }

  /* ── Per-study card ────────────────────────────────────── */
  .study {
    margin: 1.25rem 0;
    padding: 1rem 1.15rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
    scroll-margin-top: 1rem;
  }
  .study-name {
    margin: 0 0 0.35rem;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
  }
  .study-nct {
    font-size: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .study-tldr {
    margin: 0 0 0.55rem;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--fg);
  }
  .study-details {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--fg);
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .study-details li { margin: 0.25rem 0; }
  .study-subdetails {
    margin: 0.2rem 0 0.4rem;
    padding-left: 1.1rem;
    list-style: none;
  }
  .study-subdetails li {
    margin: 0.15rem 0;
    font-size: 0.92rem;
    color: var(--fg);
    position: relative;
    padding-left: 0.7rem;
  }
  .study-subdetails li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  /* ── Comparison tables ─────────────────────────────────── */
  .study-table-wrap {
    margin: 0.4rem 0 0.6rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-card);
  }
  .study-table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.88rem;
    font-family: var(--font-sans);
    line-height: 1.4;
  }
  .study-table th,
  .study-table td {
    padding: 0.45rem 0.7rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .study-table tbody tr:last-child td { border-bottom: none; }
  .study-table th {
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--fg-muted);
    background: var(--bg-card);
  }
  /* Sticky first column on mobile so row labels stay visible when scrolling */
  @media (max-width: 600px) {
    .study-table th:first-child,
    .study-table td:first-child {
      position: sticky;
      left: 0;
      background: var(--bg-card);
      border-right: 1px solid var(--border);
      z-index: 1;
    }
  }

  /* ── Sources (collapsed) + Twitter widgets ─────────────── */
  .sources { margin-top: 0.85rem; }
  .sources summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
  }
  .sources summary:hover { color: var(--accent); }
  .source-stack {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  /* Twitter's widgets.js produces a centered <iframe>; constrain width and
     remove default centering so it flows in our column. */
  .tw-wrap :global(.twitter-tweet) { margin: 0 !important; }
  .tw-wrap :global(iframe) { max-width: 100% !important; }
  .source-fallback {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .source-text { line-height: 1.5; white-space: pre-wrap; }
  .source-note {
    margin-top: 0.45rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-style: italic;
  }
  /* ── Paper sources ─────────────────────────────────────── */
  .source-paper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    font-size: 0.92rem;
  }
  .source-type-pill {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 3px;
    margin-right: 0.4rem;
    vertical-align: 1px;
  }
  .paper-title {
    margin: 0.35rem 0 0.4rem;
    font-family: var(--font-serif);
    font-weight: 600;
    line-height: 1.35;
  }
  .paper-journal { color: var(--fg-muted); font-family: var(--font-sans); font-size: 0.82rem; }
  .paper-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    margin-bottom: 0.4rem;
  }
  .paper-links a { color: var(--accent); }
  .paper-abstract { margin-top: 0.4rem; }
  .paper-abstract summary {
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    padding: 0.25rem 0;
  }
  .paper-abstract summary:hover { color: var(--accent); }
  .paper-abstract-body {
    margin-top: 0.4rem;
    line-height: 1.5;
    color: var(--fg);
  }
  /* ── Slide sources ─────────────────────────────────────── */
  .source-slide {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-slide img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
    margin-top: 0.5rem;
  }
  .slide-fallback {
    margin-top: 0.5rem;
    padding: 0.5rem 0.7rem;
    background: var(--bg);
    border: 1px dashed var(--border);
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    text-align: center;
  }

  /* ── Promoted figure ───────────────────────────────────── */
  .study-figure {
    margin: 0.6rem 0 0.8rem;
    padding: 0;
  }
  .study-figure img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .study-figure figcaption {
    margin-top: 0.4rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .caption-table-wrap {
    margin-top: 0.4rem;
  }
  .caption-table-wrap .study-table {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
  }

  /* ── Disclosure (dropped clusters / OCR availability) ──── */
  .disclosure {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--border);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }
  .disclosure .section-label { margin-bottom: 0.4rem; }
  .disclosure p { margin: 0; }
  .dropped {
    margin-top: 0.6rem;
  }
  .dropped summary {
    cursor: pointer;
    padding: 0.25rem 0;
