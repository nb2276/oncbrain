---
import Base from '../layouts/Base.astro';
import { listDigests, type DigestArtifact, type DigestDetail, type DigestStudy, type SocImplication } from '../lib/digest-data.ts';
import { linkifyCitations } from '../lib/extract.ts';
import { getDiseaseSite } from '../lib/disease-sites.ts';
import { isSafeImageUrl } from '../lib/vision-ocr.ts';
import { assignSlugsForDate } from '../lib/slug-resolve.ts';

// 60-second triage signal: verdict pill at the top of each study card.
// Six buckets matching VOICE.md "SOC-implication verdict" taxonomy.
const VERDICT_META: Record<SocImplication, { emoji: string; label: string }> = {
  'practice-changing': { emoji: '🚀', label: 'Practice-changing' },
  'challenges-soc': { emoji: '↔️', label: 'Challenges SOC' },
  'confirmatory': { emoji: '🔄', label: 'Confirmatory' },
  'early-signal': { emoji: '🧪', label: 'Early signal' },
  'methodologically-limited': { emoji: '⚠️', label: 'Caveats dominate' },
  'unclear': { emoji: '❔', label: 'Unclear' },
};

// Comparator promotion: lift any 🔗 bullets out of the main details list
// into a dedicated "vs leading data" callout. A rad onc scanning a study
// wants to know how this compares to prior evidence before reading the
// methodology bullets. The bullets themselves stay verbatim; we just give
// them a visual home that signals their role.
function isComparatorBullet(d: DigestDetail): boolean {
  const text = typeof d === 'string' ? d : (d as { text: string }).text;
  return /^\s*🔗/.test(text);
}
function stripComparatorEmoji(text: string): string {
  return text.replace(/^\s*🔗\s*/, '');
}

export async function getStaticPaths() {
  return listDigests().map((artifact) => ({
    params: { date: artifact.date },
    props: { artifact },
  }));
}

interface Props {
  artifact: DigestArtifact;
}

const { artifact } = Astro.props as Props;
const { date, conference, digest, bookmarks, generated_at } = artifact;

const bookmarksById = new Map(bookmarks.map((b) => [b.id, b]));
const papersById = new Map((artifact.papers ?? []).map((p) => [p.id, p]));
const slidesById = new Map((artifact.slides ?? []).map((s) => [s.id, s]));
const generatedDate = new Date(generated_at).toISOString().slice(0, 10);
const title = conference ? `${conference.name} — ${date}` : date;

// v0.5: resolve a study's source list. Prefer source_ids (typed) when present;
// fall back to tweet_ids (legacy v0.4 artifacts).
type SourceRef = { type: 'tweet' | 'paper' | 'slide'; id: number };
function resolveSources(study: typeof digest.sites[number]['studies'][number]): SourceRef[] {
  if (study.source_ids && study.source_ids.length > 0) return study.source_ids;
  return study.tweet_ids.map((id) => ({ type: 'tweet' as const, id }));
}

// "data/slide-photos/<date>/<uuid>.jpg" → "/slides/<date>/<uuid>.jpg"
function toSlideUrl(filePath: string): string {
  if (filePath.startsWith('data/slide-photos/')) {
    return '/slides/' + filePath.slice('data/slide-photos/'.length);
  }
  return filePath;
}

// Per-date slug resolution: walk every study on this date in render order
// and disambiguate collisions from the deriveSlug() fallback. Indexed by
// study reference identity (the same DigestStudy object is rendered below).
const allStudiesOnDate = digest.sites.flatMap((s) => s.studies);
const resolvedSlugs = assignSlugsForDate(allStudiesOnDate);
const slugByStudy = new Map<typeof allStudiesOnDate[number], string>();
allStudiesOnDate.forEach((s, i) => slugByStudy.set(s, resolvedSlugs[i]!));

// Per-study derived view data, precomputed so the template stays a single
// expression per study (Astro's parser dislikes multi-statement arrow
// bodies inside JSX expressions): unique source authors, comparator
// bullets lifted out of details for the "vs leading data" callout, the
// rest of the bullets, and the verdict metadata.
// Authors carry their source type so the renderer can style tweet
// handles (monospace) differently from paper attributions (italic
// surname). Codex review P2: "Siva et al." in code-font reads as a
// code identifier; only @handles belong in monospace.
type StudyAuthor = { name: string; kind: 'tweet' | 'paper' };
type StudyMeta = {
  authors: StudyAuthor[];
  comparatorBullets: DigestDetail[];
  otherBullets: DigestDetail[];
  verdictMeta: { emoji: string; label: string } | null;
};
const studyMeta = new Map<typeof allStudiesOnDate[number], StudyMeta>();
for (const study of allStudiesOnDate) {
  const refs = study.source_ids ?? study.tweet_ids.map((id) => ({ type: 'tweet' as const, id }));
  const authors: StudyAuthor[] = [];
  const seen = new Set<string>();
  for (const ref of refs) {
    let candidate: StudyAuthor | null = null;
    if (ref.type === 'tweet') {
      const b = bookmarksById.get(ref.id);
      const name = b?.author_handle ?? b?.author_name ?? null;
      if (name) candidate = { name, kind: 'tweet' };
    } else if (ref.type === 'paper') {
      const p = papersById.get(ref.id);
      const first = p?.authors?.[0];
      // "Siva" reads as a partial citation; "Siva et al." reads as a
      // proper attribution. Append the suffix when there's more than
      // one author on the paper.
      if (first) {
        const name = (p?.authors?.length ?? 0) > 1 ? `${first} et al.` : first;
        candidate = { name, kind: 'paper' };
      }
    }
    if (candidate && !seen.has(candidate.name)) {
      seen.add(candidate.name);
      authors.push(candidate);
    }
  }
  studyMeta.set(study, {
    authors,
    comparatorBullets: study.details.filter(isComparatorBullet),
    otherBullets: study.details.filter((d) => !isComparatorBullet(d)),
    verdictMeta: study.verdict ? VERDICT_META[study.verdict.soc_implication] : null,
  });
}
---

<Base title={title} description={digest.top_line || digest.tldr}>
  <nav class="crumb">
    <a href="/">← all dates</a>
    {conference && <a href={`/conferences/${conference.slug}/`}>{conference.name}</a>}
    <a href="/sites/">browse by site</a>
  </nav>

  <header class="day-header">
    <h2>
      {date}
      {conference && <span class="conf-pill">{conference.name}</span>}
    </h2>
    <p class="meta">digest generated {generatedDate}</p>
  </header>

  <section class="topline" aria-label="Top line">
    <div class="topline-body" set:html={linkifyCitations(digest.top_line)} />
  </section>

  <section class="tldr">
    <div class="section-label">TL;DR</div>
    <div set:html={linkifyCitations(digest.tldr)} />
  </section>

  {digest.sites.map((site) => {
    const meta = getDiseaseSite(site.disease_site);
    return (
      <article class="site">
        <h3 class="site-heading">
          <a href={`/sites/${meta.slug}/`} class="site-anchor">
            <span class="site-emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
            <span class="site-label">{meta.label}</span>
          </a>
        </h3>
        {site.intro && (
          <p class="site-intro" set:html={linkifyCitations(site.intro)} />
        )}

        {site.studies.map((study) => (
          <div class="study" id={slugByStudy.get(study)}>
            <h4 class="study-name">
              {study.name}
              {study.nct && (
                <a class="citation study-nct" href={`https://clinicaltrials.gov/study/${study.nct}`} target="_blank" rel="noopener">{study.nct}</a>
              )}
            </h4>
            {(studyMeta.get(study)?.authors.length ?? 0) > 0 && (
              <p class="study-authors">
                Sourced from {studyMeta.get(study)!.authors.slice(0, 3).map((a, i) => (
                  <Fragment>{i > 0 && ', '}<span class:list={['author-name', `author-${a.kind}`]}>{a.name}</span></Fragment>
                ))}
                {studyMeta.get(study)!.authors.length > 3 && (
                  <span class="author-more"> · +{studyMeta.get(study)!.authors.length - 3}</span>
                )}
              </p>
            )}
            {study.verdict?.audience && (
              <p class="study-audience"><span class="audience-label">For</span>{study.verdict.audience}</p>
            )}
            {study.verdict?.rationale && studyMeta.get(study)?.verdictMeta && (
              <aside class:list={['verdict-block', `verdict-${study.verdict.soc_implication}`]}>
                <div class="verdict-pill">
                  <span class="verdict-emoji" aria-hidden="true">{studyMeta.get(study)!.verdictMeta!.emoji}</span>
                  <span class="verdict-label">{studyMeta.get(study)!.verdictMeta!.label}</span>
                </div>
                <p class="verdict-rationale">{study.verdict.rationale}</p>
              </aside>
            )}
            <p class="study-tldr" set:html={linkifyCitations(study.tldr)} />
            {/* Comparator before figure: codex review P2 caught the order
                drift. A rad onc scanning wants "how does this compare to
                current practice" before the visual detour into KM curves
                or forest plots. */}
            {(studyMeta.get(study)?.comparatorBullets.length ?? 0) > 0 && (
              <section class="comparator-block">
                <div class="comparator-label">vs leading data</div>
                <ul class="comparator-list">
                  {studyMeta.get(study)!.comparatorBullets.map((d) => (
                    typeof d === 'string'
                      ? <li set:html={linkifyCitations(stripComparatorEmoji(d))} />
                      : <li set:html={linkifyCitations(stripComparatorEmoji(d.text))} />
                  ))}
                </ul>
              </section>
            )}
            {study.key_figure_url && isSafeImageUrl(study.key_figure_url) && (
              <figure class="study-figure">
                <img
                  src={study.key_figure_url}
                  alt={typeof study.key_figure_caption === 'string' ? study.key_figure_caption : study.name}
                  loading="lazy"
                />
                {typeof study.key_figure_caption === 'string' && (
                  <figcaption>{study.key_figure_caption}</figcaption>
                )}
                {study.key_figure_caption && typeof study.key_figure_caption !== 'string' && (
                  <figcaption>
                    <div class="study-table-wrap caption-table-wrap">
                      <table class="study-table">
                        <thead>
                          <tr>
                            {study.key_figure_caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                          </tr>
                        </thead>
                        <tbody>
                          {study.key_figure_caption.rows.map((row) => (
                            <tr>
                              {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </figcaption>
                )}
              </figure>
            )}
            {(studyMeta.get(study)?.otherBullets.length ?? 0) > 0 && (
              <ul class="study-details">
                {studyMeta.get(study)!.otherBullets.map((d) => {
                  if (typeof d === 'string') {
                    return <li set:html={linkifyCitations(d)} />;
                  }
                  if ('table' in d) {
                    return (
                      <li>
                        <span set:html={linkifyCitations(d.text)} />
                        <div class="study-table-wrap">
                          <table class="study-table">
                            <thead>
                              <tr>
                                {d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                              </tr>
                            </thead>
                            <tbody>
                              {d.table.rows.map((row) => (
                                <tr>
                                  {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </li>
                    );
                  }
                  return (
                    <li>
                      <span set:html={linkifyCitations(d.text)} />
                      {d.subdetails.length > 0 && (
                        <ul class="study-subdetails">
                          {d.subdetails.map((s) => (<li set:html={linkifyCitations(s)} />))}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            )}
            {(() => {
              const sources = resolveSources(study);
              const tweetSrcs = sources.filter((s) => s.type === 'tweet');
              const paperSrcs = sources.filter((s) => s.type === 'paper');
              const slideSrcs = sources.filter((s) => s.type === 'slide');
              const total = tweetSrcs.length + paperSrcs.length + slideSrcs.length;
              if (total === 0) return null;
              const badges: string[] = [];
              if (tweetSrcs.length > 0) badges.push(`🐦 ${tweetSrcs.length} tweet${tweetSrcs.length === 1 ? '' : 's'}`);
              if (paperSrcs.length > 0) badges.push(`📄 ${paperSrcs.length} paper${paperSrcs.length === 1 ? '' : 's'}`);
              if (slideSrcs.length > 0) badges.push(`🩻 ${slideSrcs.length} slide${slideSrcs.length === 1 ? '' : 's'}`);
              return (
                <details class="sources">
                  <summary>📚 Sources · {badges.join(' · ')}</summary>
                  <div class="source-stack">
                    {tweetSrcs.map((s) => {
                      const b = bookmarksById.get(s.id);
                      if (!b) return null;
                      if (b.html) {
                        return (
                          <div class="tw-wrap">
                            <Fragment set:html={b.html} />
                            {b.note && <div class="source-note">📝 {b.note}</div>}
                          </div>
                        );
                      }
                      return (
                        <div class="source-fallback">
                          <div class="source-meta">
                            <span>{b.author_name || b.author_handle || 'unknown'}</span>
                            <a href={b.url} target="_blank" rel="noopener">view on X →</a>
                          </div>
                          <div class="source-text" set:html={linkifyCitations(b.text)} />
                          {b.note && <div class="source-note">📝 {b.note}</div>}
                        </div>
                      );
                    })}
                    {paperSrcs.map((s) => {
                      const p = papersById.get(s.id);
                      if (!p) return null;
                      return (
                        <div class="source-paper">
                          <div class="source-meta">
                            <span class="source-type-pill">📄 PAPER</span>
                            <span>
                              {p.authors.slice(0, 3).join('; ')}
                              {p.authors.length > 3 ? ' et al.' : ''}
                            </span>
                            {p.journal && (
                              <span class="paper-journal">
                                · <em>{p.journal}</em>{p.pub_date ? ` (${p.pub_date.slice(0, 7)})` : ''}
                              </span>
                            )}
                          </div>
                          <div class="paper-title">{p.title}</div>
                          <div class="paper-links">
                            <a href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener">
                              PMID {p.pmid} →
                            </a>
                            {p.doi && (
                              <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">
                                doi
                              </a>
                            )}
                            {p.pmc_id && (
                              <a
                                href={`https://www.ncbi.nlm.nih.gov/pmc/articles/${p.pmc_id}/`}
                                target="_blank"
                                rel="noopener"
                              >
                                full text (PMC)
                              </a>
                            )}
                          </div>
                          {p.abstract && (
                            <details class="paper-abstract">
                              <summary>Abstract</summary>
                              <div class="paper-abstract-body" set:html={linkifyCitations(p.abstract.replace(/\n/g, '<br/>'))} />
                            </details>
                          )}
                          {p.note && <div class="source-note">📝 {p.note}</div>}
                        </div>
                      );
                    })}
                    {slideSrcs.map((s) => {
                      const slide = slidesById.get(s.id);
                      if (!slide) return null;
                      const url = toSlideUrl(slide.file_path);
                      return (
                        <div class="source-slide">
                          <div class="source-meta">
                            <span class="source-type-pill">🩻 SLIDE</span>
                            {slide.source_label && <span>{slide.source_label}</span>}
                          </div>
                          <img
                            src={url}
                            alt={slide.source_label ?? 'Slide photograph'}
                            loading="lazy"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
                          />
                          <div class="slide-fallback" style="display:none">
                            (Slide image not published — curator-private.)
                          </div>
                          {slide.note && <div class="source-note">📝 {slide.note}</div>}
                        </div>
                      );
                    })}
                  </div>
                </details>
              );
            })()}
            {study.open_questions && study.open_questions.length > 0 && (
              <div class="open-questions study-open-questions">
                <div class="section-label">Open questions</div>
                <ul>
                  {study.open_questions.map((q) => (<li set:html={linkifyCitations(q)} />))}
                </ul>
              </div>
            )}
          </div>
        ))}

        {!site.studies.some((s) => s.open_questions && s.open_questions.length > 0) &&
          site.open_questions &&
          site.open_questions.length > 0 && (
            <div class="open-questions">
              <div class="section-label">Open questions</div>
              <ul>
                {site.open_questions.map((q) => (<li set:html={linkifyCitations(q)} />))}
              </ul>
            </div>
          )}
      </article>
    );
  })}

  {digest.meta && (digest.meta.dropped.length > 0 || !digest.meta.ocr_available) && (
    <section class="disclosure" aria-label="Build disclosures">
      <div class="section-label">Build disclosures</div>
      <p>
        {digest.meta.studies_analyzed} of {digest.meta.clusters_total} study cluster{digest.meta.clusters_total === 1 ? '' : 's'} analyzed successfully.
        {!digest.meta.ocr_available && ' On-device OCR was unavailable for this build — figure captions omitted.'}
      </p>
      {digest.meta.dropped.length > 0 && (
        <details class="dropped">
          <summary>{digest.meta.dropped.length} cluster{digest.meta.dropped.length === 1 ? '' : 's'} dropped</summary>
          <ul>
            {digest.meta.dropped.map((d) => (
              <li><strong>{d.name}</strong> <span class="dropped-slug">({d.slug})</span><br /><span class="dropped-reason">{d.reason}</span></li>
            ))}
          </ul>
        </details>
      )}
    </section>
  )}
</Base>

<style>
  /* ── Breadcrumb / header ───────────────────────────────── */
  .crumb {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-family: var(--font-sans);
  }
  .crumb a { color: var(--fg-muted); text-decoration: none; margin-right: 0.5rem; }
  .crumb a + a::before { content: '· '; color: var(--border); margin-right: 0.25rem; }
  .crumb a:hover { color: var(--accent); }

  .day-header h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem;
  }
  .conf-pill {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.15rem 0.6rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .meta {
    margin: 0.35rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  /* ── Top line ──────────────────────────────────────────── */
  .topline { margin-top: 2rem; }
  .topline-body {
    font-family: var(--font-serif);
    font-size: 1.65rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--fg);
  }

  /* ── TL;DR ─────────────────────────────────────────────── */
  .tldr {
    margin-top: 1.5rem;
    padding: 0.25rem 0 0.25rem 1.1rem;
    border-left: 3px solid var(--accent);
  }
  .tldr > div:not(.section-label) { line-height: 1.55; color: var(--fg-muted); }
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }

  /* ── Site sections ─────────────────────────────────────── */
  .site {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .site-heading {
    margin: 0 0 0.6rem;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .site-anchor {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
  }
  .site-anchor:hover .site-label { color: var(--accent); text-decoration: underline; }
  .site-emoji { font-size: 1.55rem; line-height: 1; }
  .site-intro {
    margin: 0.5rem 0 1.25rem;
    color: var(--fg-muted);
    line-height: 1.5;
    font-size: 0.95rem;
  }

  /* ── Per-study card ────────────────────────────────────── */
  .study {
    margin: 1.25rem 0;
    padding: 1rem 1.15rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
    scroll-margin-top: 1rem;
  }
  .study-name {
    margin: 0 0 0.35rem;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
  }
  .study-nct {
    font-size: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  /* Author surface: credibility-by-attribution. Beats raw like counts as a
     signal for clinical content. Small + muted; it's metadata. */
  .study-authors {
    margin: 0 0 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .author-name { color: var(--fg); }
  /* Tweet @handles read as code identifiers — monospace. */
  .author-tweet {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
  }
  /* Paper attributions ("Siva et al.") read as bibliographic
     entries — italic surname style. Codex P2: monospace was wrong. */
  .author-paper {
    font-style: italic;
    font-size: 0.82rem;
  }
  .author-more { color: var(--fg-muted); }

  /* Audience gate: "For: ..." one-liner before the analyst verdict. The
     rad onc gates applicability before reading deeper. */
  .study-audience {
    margin: 0 0 0.55rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .audience-label {
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: var(--fg-muted);
    margin-right: 0.5rem;
  }

  /* SOC-implication verdict block — the 5-second triage signal. The
     --verdict-color custom property carries the per-bucket color
     anchor; one base style + six color values via the variant classes. */
  .verdict-block {
    margin: 0.45rem 0 0.85rem;
    padding: 0.65rem 0.85rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--verdict-color, var(--accent));
    border-radius: 4px;
  }
  .verdict-block.verdict-practice-changing { --verdict-color: #1a5e3a; }
  .verdict-block.verdict-challenges-soc { --verdict-color: #9a5a1a; }
  .verdict-block.verdict-confirmatory { --verdict-color: var(--accent); }
