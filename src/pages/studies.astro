---
// v0.14 T3: the full flat study index. The home page shows a what's-new slice
// and links here for the complete, filterable corpus. The TagFilterRail (the
// "narrow the feed" tool) lives here, where the full feed it narrows renders.
//
// RecentFeed renders every study, so it is also the corpus for the "new since
// last visit" marker (no allIds needed: the rendered rows ARE the corpus). The
// sessionStorage baseline keeps markers consistent with the home slice within a
// session (see src/lib/whats-new.ts).
import Base from '../layouts/Base.astro';
import TagFilterRail from '../components/TagFilterRail.astro';
import RecentFeed from '../components/RecentFeed.astro';
import SiteNav from '../components/SiteNav.astro';
import { listRecentStudies } from '../lib/digest-data.ts';
import { buildFilterRailOptions } from '../lib/tag-foundations.ts';

const feed = listRecentStudies(Number.MAX_SAFE_INTEGER);

// Per-namespace filter options, scoped to the studies that render on this page.
// Empty namespaces are dropped so the rail never shows an unsatisfiable filter.
const filterOptions = buildFilterRailOptions(
  feed.map((r) => ({
    study: r.study,
    conferenceSlug: r.conference?.slug ?? null,
    conferenceLabel: r.conference?.name ?? null,
  })),
);
---

<Base title="All studies · onc brain" description="Every study in the oncbrain corpus, newest first, filterable by verdict, modality, intent, and methodology.">
  {feed.length > 0 && (
    <TagFilterRail
      modality={filterOptions.modality}
      intent={filterOptions.intent}
      methodology={filterOptions.methodology}
      verdict={filterOptions.verdict}
      meeting={filterOptions.meeting}
      totalCount={feed.length}
    />
  )}

  <p class="studies-back"><a href="/">← Home</a></p>

  {/* v0.14.3: disease-site nav, the missing cross-corpus wayfinding axis the
      T3 reviews flagged. Shared SiteNav so home + /studies stay in sync. */}
  {feed.length > 0 && <SiteNav />}

  {feed.length > 0 ? (
    <RecentFeed items={feed} totalCount={feed.length} heading="All studies" />
  ) : (
    <p style="margin-top:2rem;color:var(--fg-muted)">No studies yet — check back soon.</p>
  )}
</Base>

<style>
  .studies-back {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .studies-back a { color: var(--fg-muted); text-decoration: none; }
  .studies-back a:hover { color: var(--accent); text-decoration: underline; }
</style>
