---
// v0.31: the reader's saved "for my specialty" preference. v0.32: promoted from a
// muted divider to a distinct, labeled panel (action label + helper subtitle + card
// container) so readers actually discover they can pick their specialty.
// Pure client-side +
// localStorage — independent of the tag filter rail. When one or more specialties
// are picked, studies NOT relevant to any of them are DIMMED (kept in place, just
// de-emphasized) so the studies that matter to the reader stand out; the pick
// persists across visits. Studies without a `data-specialties` attribute (older
// artifacts not yet rebuilt with the field) are treated as relevant-to-all and
// never dimmed. The bar hides itself on pages that have no tagged studies.
---

<div class="specialty-bar" data-specialty-bar hidden>
  <div class="specialty-bar-head">
    <span class="specialty-bar-label">Focus on your specialty</span>
    <span class="specialty-bar-sub">Highlight the studies that matter to you. Saved for next time.</span>
  </div>
  <div class="specialty-bar-opts" role="group" aria-label="Emphasize studies relevant to your specialty">
    <label class="specialty-chip">
      <input type="checkbox" data-specialty="radonc" />
      <span>🎯 Radiation</span>
    </label>
    <label class="specialty-chip">
      <input type="checkbox" data-specialty="medonc" />
      <span>💊 Medical</span>
    </label>
    <label class="specialty-chip">
      <input type="checkbox" data-specialty="surgonc" />
      <span>🔪 Surgical</span>
    </label>
  </div>
  <span class="specialty-bar-count" data-specialty-count hidden aria-live="polite"></span>
  <button type="button" class="specialty-bar-clear" data-specialty-clear hidden>Clear</button>
</div>

<style>
  /* v0.32: promoted from a muted divider to a distinct, inviting panel — the
     reader has to notice it's a control they can use (the curator didn't). A
     card container + an action label + a one-line "what this does / it's saved"
     helper carry the affordance. */
  .specialty-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    margin: 0 0 1.5rem;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-sans);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 10px;
  }
  /* An author `display` beats the UA [hidden]{display:none} rule, so the SSR
     `hidden` attribute (self-hide when no tagged studies) needs this explicit
     guard — else an inert bar renders on every page until the corpus is rebuilt. */
  .specialty-bar[hidden] { display: none; }
  .specialty-bar-head {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    margin-right: 0.3rem;
  }
  .specialty-bar-label {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.2;
  }
  .specialty-bar-sub {
    font-size: 0.74rem;
    color: var(--fg-muted);
    line-height: 1.3;
  }
  .specialty-bar-opts { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .specialty-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 36px;
    padding: 0.28rem 0.7rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.82rem;
    color: var(--fg);
    cursor: pointer;
    user-select: none;
  }
  .specialty-chip:hover { border-color: var(--accent); }
  .specialty-chip input { position: absolute; opacity: 0; width: 0; height: 0; }
  /* Filled state when checked. Needs :has() (all current browsers since 2023); on
     an engine without it the dim still works, the chip just shows no fill (the
     native checkbox is visually hidden, so there's no pure-CSS parent-select fallback). */
  .specialty-chip:has(input:checked) {
    background: var(--accent);
    border-color: transparent;
    color: var(--bg-card);
    font-weight: 600;
  }
  .specialty-chip:has(input:focus-visible) { outline: 2px solid var(--accent); outline-offset: 2px; }
  .specialty-bar-count {
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 600;
    margin-left: auto;
  }
  .specialty-bar-clear {
    background: transparent;
    border: none;
    padding: 0.2rem 0.3rem;
    font: inherit;
    font-size: 0.75rem;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .specialty-bar-clear:hover { color: var(--accent); text-decoration: underline; }

  /* Dim studies not relevant to the reader's picked specialties. Kept in flow so
     the digest stays browseable; just visually recessed so relevant cards lead. */
  :global(.study[data-specialty-dim]) {
    opacity: 0.42;
    transition: opacity 140ms ease;
  }
  :global(.study[data-specialty-dim]:hover),
  :global(.study[data-specialty-dim]:focus-within) {
    opacity: 1;
  }
</style>

<script is:inline>
  (function () {
    var KEY = 'oncbrain:specialties';
    var KNOWN = { radonc: 1, medonc: 1, surgonc: 1 };
    // v0.32: when several specialties are picked, the card's "why it matters" shows
    // the first one (this fixed order) that the card actually has a variant for.
    var SIG_PRIORITY = ['radonc', 'medonc', 'surgonc'];
    function init() {
      var bar = document.querySelector('[data-specialty-bar]');
      if (!bar) return;
      var cards = Array.prototype.slice.call(document.querySelectorAll('.study'));
      // Only surface the bar where at least one study carries specialty data (else
      // it's inert on an un-rebuilt corpus) AND there are 2+ studies to prioritize
      // among (dimming the sole card on the standalone /study/ page is pointless).
      var tagged = document.querySelectorAll('.study[data-specialties]');
      if (tagged.length === 0 || cards.length < 2) return;
      bar.removeAttribute('hidden');

      var boxes = Array.prototype.slice.call(bar.querySelectorAll('[data-specialty]'));
      var countEl = bar.querySelector('[data-specialty-count]');
      var clearBtn = bar.querySelector('[data-specialty-clear]');

      function read() {
        // Validate stored tokens against the known slugs — a stale/renamed/tampered
        // value would otherwise make `active` true with no chip checked, dimming
        // every card with no visible explanation.
        try {
          var v = JSON.parse(localStorage.getItem(KEY) || '[]');
          var out = new Set();
          if (Array.isArray(v)) for (var i = 0; i < v.length; i++) if (KNOWN[v[i]]) out.add(v[i]);
          return out;
        } catch (e) { return new Set(); }
      }
      function save(set) {
        // Array.from (NOT slice.call) — a Set isn't array-like, so slice.call
        // would silently persist [] and the preference would never survive a reload.
        try { localStorage.setItem(KEY, JSON.stringify(Array.from(set))); } catch (e) {}
      }
      // v0.32: show the "why it matters" written for the reader's picked specialty
      // when this card carries such a variant; else the default block. Scoped to
      // blocks whose closest .study is THIS card, so a nested sibling card's
      // variants are never toggled by the parent's pass.
      function swapSignificance(card, set, active) {
        var all = card.querySelectorAll('[data-sig-for]');
        if (!all.length) return;
        var variants = [];
        for (var i = 0; i < all.length; i++) if (all[i].closest('.study') === card) variants.push(all[i]);
        if (!variants.length) return;
        var pick = null;
        if (active) {
          for (var p = 0; p < SIG_PRIORITY.length && !pick; p++) {
            if (!set.has(SIG_PRIORITY[p])) continue;
            for (var v = 0; v < variants.length; v++) {
              if (variants[v].getAttribute('data-sig-for') === SIG_PRIORITY[p]) { pick = SIG_PRIORITY[p]; break; }
            }
          }
        }
        for (var v2 = 0; v2 < variants.length; v2++) {
          if (pick && variants[v2].getAttribute('data-sig-for') === pick) variants[v2].removeAttribute('hidden');
          else variants[v2].setAttribute('hidden', '');
        }
        var defs = card.querySelectorAll('[data-sig-default]');
        for (var d = 0; d < defs.length; d++) {
          if (defs[d].closest('.study') !== card) continue;
          if (pick) defs[d].setAttribute('hidden', ''); else defs[d].removeAttribute('hidden');
        }
      }
      function apply(set) {
        var active = set.size > 0;
        var relevant = 0;
        for (var i = 0; i < cards.length; i++) {
          var card = cards[i];
          var raw = card.getAttribute('data-specialties');
          var spec = raw ? raw.split(/\s+/).filter(Boolean) : [];
          // relevant if no active pick, OR the card has no specialty data (unknown),
          // OR it shares at least one specialty with the reader's pick (OR-logic).
          var isRel = !active || spec.length === 0 || spec.some(function (s) { return set.has(s); });
          if (isRel) {
            card.removeAttribute('data-specialty-dim');
            // Count only VISIBLE relevant cards — a card the tag filter rail hid
            // (`hidden` attr) must not inflate "N relevant" past what's on screen.
            if (active && spec.length > 0 && !card.hasAttribute('hidden')) relevant++;
          } else {
            card.setAttribute('data-specialty-dim', '');
          }
          swapSignificance(card, set, active);
        }
        if (countEl) {
          if (active) { countEl.textContent = relevant + ' relevant'; countEl.removeAttribute('hidden'); }
          else countEl.setAttribute('hidden', '');
        }
        if (clearBtn) {
          if (active) clearBtn.removeAttribute('hidden'); else clearBtn.setAttribute('hidden', '');
        }
      }

      var set = read();
      for (var b = 0; b < boxes.length; b++) {
        boxes[b].checked = set.has(boxes[b].getAttribute('data-specialty'));
      }
      apply(set);

      function onChange() {
        var s = new Set();
        for (var i = 0; i < boxes.length; i++) {
          if (boxes[i].checked) s.add(boxes[i].getAttribute('data-specialty'));
        }
        save(s);
        apply(s);
      }
      for (var j = 0; j < boxes.length; j++) boxes[j].addEventListener('change', onChange);
      if (clearBtn) clearBtn.addEventListener('click', function () {
        for (var k = 0; k < boxes.length; k++) boxes[k].checked = false;
        var s = new Set();
        save(s);
        apply(s);
      });
      // The tag filter rail hides/shows cards independently; re-apply on its change
      // event so the dim state + "N relevant" count track what's actually visible.
      document.addEventListener('oncbrain:filterchange', function () {
        var s = new Set();
        for (var i = 0; i < boxes.length; i++) if (boxes[i].checked) s.add(boxes[i].getAttribute('data-specialty'));
        apply(s);
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
