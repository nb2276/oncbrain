---
// Live search on the home page.
//
// Loads /search-index.json lazily (on input focus or first keystroke) so
// the 95% of visits that don't search pay no extra bytes. Filter is a
// case-insensitive substring match across name + tldr + nct + site label;
// results sort newest-date first.
//
// Anchor target: /<date>/#<slug> — [date].astro emits id={study.slug}.
---

<section class="search-box">
  <label class="visually-hidden" for="study-search">Search studies, trials, or NCT identifiers</label>
  <div class="search-label">
    <span class="search-icon" aria-hidden="true">🔍</span>
    <input
      id="study-search"
      type="search"
      placeholder="Search studies, trials, NCT…"
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      enterkeyhint="search"
      aria-controls="search-results"
    />
    <button type="button" class="search-clear" aria-label="Clear search" hidden>×</button>
  </div>

  <div id="search-results" class="search-results" data-state="empty">
    <p class="search-status" aria-live="polite"></p>
    <ul class="search-list"></ul>
  </div>
</section>

<style>
  .search-box {
    margin: 0 0 1.5rem;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .search-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s ease;
  }
  .search-label:focus-within {
    border-color: var(--accent);
  }
  .search-icon {
    font-size: 0.95rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .search-label input[type='search'] {
    flex: 1;
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 16px; /* >=16px keeps iOS from auto-zooming the viewport */
    color: var(--fg);
    outline: none;
    min-width: 0;
  }
  .search-label input[type='search']::-webkit-search-cancel-button {
    appearance: none;
  }
  .search-clear {
    border: 0;
    background: transparent;
    color: var(--fg-muted);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }
  .search-clear:hover {
    color: var(--fg);
  }

  .search-results {
    margin-top: 0.85rem;
  }
  .search-results[data-state='empty'] {
    display: none;
  }
  .search-status {
    margin: 0 0 0.6rem;
    color: var(--fg-muted);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    font-family: var(--font-sans);
  }
  .search-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .search-list a {
    display: block;
    padding: 0.75rem 0.95rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg);
    text-decoration: none;
  }
  .search-list a:hover,
  .search-list a:focus-visible {
    border-color: var(--accent);
  }
  .search-list .result-meta {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--fg-muted);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    font-family: var(--font-sans);
    margin-bottom: 0.2rem;
  }
  .search-list .result-emoji {
    font-size: 0.95rem;
  }
  .search-list .result-name {
    font-weight: 600;
    color: var(--fg);
    line-height: 1.3;
  }
  .search-list .result-tldr {
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.4;
    margin-top: 0.2rem;
  }
</style>

<script>
  type SearchEntry = {
    date: string;
    site: string;
    site_label: string;
    site_emoji: string;
    name: string;
    slug: string;
    tldr: string;
    nct: string | null;
  };

  const MAX_RESULTS = 20;
  const DEBOUNCE_MS = 80;
  // Only ASCII letters, digits, and dashes are safe to interpolate into the
  // anchor fragment without escaping; everything else gets URI-encoded.
  // dates are YYYY-MM-DD so they pass trivially.
  const SAFE_ANCHOR = /^[a-zA-Z0-9-]+$/;

  let cache: SearchEntry[] | null = null;
  let inflight: Promise<SearchEntry[]> | null = null;

  function isSearchEntry(x: unknown): x is SearchEntry {
    if (!x || typeof x !== 'object') return false;
    const e = x as Record<string, unknown>;
    return (
      typeof e.date === 'string' &&
      typeof e.site === 'string' &&
      typeof e.site_label === 'string' &&
      typeof e.site_emoji === 'string' &&
      typeof e.name === 'string' &&
      typeof e.slug === 'string' &&
      typeof e.tldr === 'string' &&
      (e.nct === null || typeof e.nct === 'string')
    );
  }

  function loadIndex(): Promise<SearchEntry[]> {
    if (cache) return Promise.resolve(cache);
    if (inflight) return inflight;
    inflight = fetch('/search-index.json')
      .then((r) => {
        if (!r.ok) throw new Error(`search-index ${r.status}`);
        return r.json();
      })
      .then((data: unknown) => {
        // Validate shape — a malformed or hostile payload should not brick
        // the component or feed unchecked input into the renderer.
        if (!Array.isArray(data)) {
          throw new Error('search-index: payload is not an array');
        }
        const valid = data.filter(isSearchEntry);
        cache = valid;
        return valid;
      })
      .catch((err) => {
        // Reset inflight so the next call retries, and DO NOT memoize an
        // empty cache — that would make the failure permanent.
        console.warn('search index load failed', err);
        inflight = null;
        return [] as SearchEntry[];
      });
    return inflight;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string),
    );
  }

  // Anchor-fragment escape. `date` is always YYYY-MM-DD and `slug` is
  // safe-slug-shaped from the index emitter, but defense-in-depth — if a
  // malformed entry slipped past the shape check, URI-encode it.
  function anchorEscape(s: string): string {
    return SAFE_ANCHOR.test(s) ? s : encodeURIComponent(s);
  }

  function filter(query: string, entries: SearchEntry[]): SearchEntry[] {
    const q = query.trim().toLowerCase();
    if (q.length === 0) return [];
    return entries.filter((e) => {
      if (e.name.toLowerCase().includes(q)) return true;
      if (e.tldr.toLowerCase().includes(q)) return true;
      if (e.nct && e.nct.toLowerCase().includes(q)) return true;
      if (e.site_label.toLowerCase().includes(q)) return true;
      return false;
    });
  }

  function render(query: string, all: SearchEntry[]): void {
    const results = filter(query, all);
    const status = document.querySelector('.search-status') as HTMLElement | null;
    const list = document.querySelector('.search-list') as HTMLElement | null;
    const container = document.querySelector('.search-results') as HTMLElement | null;
    if (!status || !list || !container) return;

    if (query.trim().length === 0) {
      container.dataset.state = 'empty';
      status.textContent = '';
      list.innerHTML = '';
      return;
    }

    container.dataset.state = 'active';

    if (results.length === 0) {
      status.textContent = `No studies match "${query}". Try a trial name, NCT, or disease site.`;
      list.innerHTML = '';
      return;
    }

    const shown = results.slice(0, MAX_RESULTS);
    const overflow = results.length - shown.length;
    status.textContent =
      overflow > 0
        ? `${results.length} results · showing ${shown.length} (+${overflow} more — narrow your search)`
        : `${results.length} result${results.length === 1 ? '' : 's'}`;

    // EVERY interpolated field gets escaped — including date, slug, emoji.
    // The emoji comes from disease-sites.ts (trusted constant), but uniform
    // escaping protects against future drift if that source is ever widened.
    list.innerHTML = shown
      .map((e) => {
        const href = `/${anchorEscape(e.date)}/#${anchorEscape(e.slug)}`;
        return `
        <li>
          <a href="${escapeHtml(href)}">
            <div class="result-meta">
              <span class="result-emoji" aria-hidden="true">${escapeHtml(e.site_emoji)}</span>
              <span>${escapeHtml(e.site_label)}</span>
              <span aria-hidden="true">·</span>
              <span>${escapeHtml(e.date)}</span>
            </div>
            <div class="result-name">${escapeHtml(e.name)}</div>
            <div class="result-tldr">${escapeHtml(e.tldr)}</div>
          </a>
        </li>
      `;
      })
      .join('');
  }

  function setup(): void {
    const input = document.getElementById('study-search') as HTMLInputElement | null;
    const clear = document.querySelector('.search-clear') as HTMLButtonElement | null;
    if (!input || !clear) return;

    // Prefetch on focus so the first keystroke feels instant.
    input.addEventListener('focus', () => {
      void loadIndex();
    });

    // Debounce + stale-q guard: capture the input value at the moment we're
    // about to render, not at event time, so a fast typer + slow first fetch
    // doesn't repaint stale results into a cleared box.
    let debounceTimer: number | null = null;
    const scheduleRender = () => {
      if (debounceTimer !== null) window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(async () => {
        debounceTimer = null;
        const all = await loadIndex();
        const q = input.value;
        render(q, all);
      }, DEBOUNCE_MS);
    };

    input.addEventListener('input', () => {
      clear.hidden = input.value.length === 0;
      scheduleRender();
    });

    clear.addEventListener('click', () => {
      input.value = '';
      clear.hidden = true;
      if (debounceTimer !== null) {
        window.clearTimeout(debounceTimer);
        debounceTimer = null;
      }
      render('', cache ?? []);
      input.focus();
    });

    // `/` shortcut focuses the input from anywhere (skip when already in a form field).
    document.addEventListener('keydown', (e) => {
      if (e.key !== '/') return;
      const target = e.target as HTMLElement | null;
      const tag = target?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || target?.isContentEditable) return;
      e.preventDefault();
      input.focus();
    });

    // `Esc` clears + blurs.
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        input.value = '';
        clear.hidden = true;
        if (debounceTimer !== null) {
          window.clearTimeout(debounceTimer);
          debounceTimer = null;
        }
        render('', cache ?? []);
        input.blur();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
