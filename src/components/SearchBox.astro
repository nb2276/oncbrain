---
// Live search on the home page.
//
// Loads /search-index.json lazily (on input focus or first keystroke) so
// the 95% of visits that don't search pay no extra bytes. Filter is a
// case-insensitive substring match across name + tldr + nct + site label;
// results sort newest-date first.
//
// Anchor target: /<date>/#<slug> — [date].astro emits id={study.slug}.
---

<section class="search-box">
  <label class="search-label" for="study-search">
    <span class="search-icon" aria-hidden="true">🔍</span>
    <input
      id="study-search"
      type="search"
      placeholder="Search studies, trials, NCT…"
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      enterkeyhint="search"
    />
    <button type="button" class="search-clear" aria-label="Clear search" hidden>×</button>
  </label>

  <div class="search-results" data-state="empty" aria-live="polite">
    <p class="search-status"></p>
    <ul class="search-list"></ul>
  </div>
</section>

<style>
  .search-box {
    margin: 0 0 1.5rem;
  }
  .search-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s ease;
  }
  .search-label:focus-within {
    border-color: var(--accent);
  }
  .search-icon {
    font-size: 0.95rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .search-label input[type='search'] {
    flex: 1;
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 16px; /* >=16px keeps iOS from auto-zooming the viewport */
    color: var(--fg);
    outline: none;
    min-width: 0;
  }
  .search-label input[type='search']::-webkit-search-cancel-button {
    appearance: none;
  }
  .search-clear {
    border: 0;
    background: transparent;
    color: var(--fg-muted);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }
  .search-clear:hover {
    color: var(--fg);
  }

  .search-results {
    margin-top: 0.85rem;
  }
  .search-results[data-state='empty'] {
    display: none;
  }
  .search-status {
    margin: 0 0 0.6rem;
    color: var(--fg-muted);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    font-family: var(--font-sans);
  }
  .search-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .search-list a {
    display: block;
    padding: 0.75rem 0.95rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg);
    text-decoration: none;
  }
  .search-list a:hover,
  .search-list a:focus-visible {
    border-color: var(--accent);
  }
  .search-list .result-meta {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--fg-muted);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    font-family: var(--font-sans);
    margin-bottom: 0.2rem;
  }
  .search-list .result-emoji {
    font-size: 0.95rem;
  }
  .search-list .result-name {
    font-weight: 600;
    color: var(--fg);
    line-height: 1.3;
  }
  .search-list .result-tldr {
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.4;
    margin-top: 0.2rem;
  }
</style>

<script>
  type SearchEntry = {
    date: string;
    site: string;
    site_label: string;
    site_emoji: string;
    name: string;
    slug: string;
    tldr: string;
    nct: string | null;
  };

  const MAX_RESULTS = 20;
  let cache: SearchEntry[] | null = null;
  let inflight: Promise<SearchEntry[]> | null = null;

  function loadIndex(): Promise<SearchEntry[]> {
    if (cache) return Promise.resolve(cache);
    if (inflight) return inflight;
    inflight = fetch('/search-index.json')
      .then((r) => {
        if (!r.ok) throw new Error(`search-index ${r.status}`);
        return r.json();
      })
      .then((data: SearchEntry[]) => {
        cache = data;
        return data;
      })
      .catch((err) => {
        console.warn('search index load failed', err);
        cache = [];
        return cache;
      });
    return inflight;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string),
    );
  }

  function filter(query: string, entries: SearchEntry[]): SearchEntry[] {
    const q = query.trim().toLowerCase();
    if (q.length === 0) return [];
    return entries.filter((e) => {
      if (e.name.toLowerCase().includes(q)) return true;
      if (e.tldr.toLowerCase().includes(q)) return true;
      if (e.nct && e.nct.toLowerCase().includes(q)) return true;
      if (e.site_label.toLowerCase().includes(q)) return true;
      return false;
    });
  }

  function render(query: string, all: SearchEntry[]): void {
    const results = filter(query, all);
    const status = document.querySelector('.search-status') as HTMLElement | null;
    const list = document.querySelector('.search-list') as HTMLElement | null;
    const container = document.querySelector('.search-results') as HTMLElement | null;
    if (!status || !list || !container) return;

    if (query.trim().length === 0) {
      container.dataset.state = 'empty';
      status.textContent = '';
      list.innerHTML = '';
      return;
    }

    container.dataset.state = 'active';

    if (results.length === 0) {
      status.textContent = `No studies match "${query}". Try a trial name, NCT, or disease site.`;
      list.innerHTML = '';
      return;
    }

    const shown = results.slice(0, MAX_RESULTS);
    const overflow = results.length - shown.length;
    status.textContent =
      overflow > 0
        ? `${results.length} results · showing ${shown.length} (+${overflow} more — narrow your search)`
        : `${results.length} result${results.length === 1 ? '' : 's'}`;

    list.innerHTML = shown
      .map(
        (e) => `
        <li>
          <a href="/${e.date}/#${e.slug}">
            <div class="result-meta">
              <span class="result-emoji" aria-hidden="true">${e.site_emoji}</span>
              <span>${escapeHtml(e.site_label)}</span>
              <span aria-hidden="true">·</span>
              <span>${e.date}</span>
            </div>
            <div class="result-name">${escapeHtml(e.name)}</div>
            <div class="result-tldr">${escapeHtml(e.tldr)}</div>
          </a>
        </li>
      `,
      )
      .join('');
  }

  function setup(): void {
    const input = document.getElementById('study-search') as HTMLInputElement | null;
    const clear = document.querySelector('.search-clear') as HTMLButtonElement | null;
    if (!input || !clear) return;

    // Prefetch on focus so the first keystroke feels instant.
    input.addEventListener('focus', () => {
      void loadIndex();
    });

    input.addEventListener('input', async () => {
      const q = input.value;
      clear.hidden = q.length === 0;
      const all = await loadIndex();
      render(q, all);
    });

    clear.addEventListener('click', () => {
      input.value = '';
      clear.hidden = true;
      render('', cache ?? []);
      input.focus();
    });

    // `/` shortcut focuses the input from anywhere (skip when already in a form field).
    document.addEventListener('keydown', (e) => {
      if (e.key !== '/') return;
      const target = e.target as HTMLElement | null;
      const tag = target?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || target?.isContentEditable) return;
      e.preventDefault();
      input.focus();
    });

    // `Esc` clears + blurs.
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        input.value = '';
        clear.hidden = true;
        render('', cache ?? []);
        input.blur();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
