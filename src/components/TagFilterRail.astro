---
// v0.11 PR-2: cross-page tag filter rail (desktop-only ≥1200px).
//
// Server-side renders a checkbox tree grouped by namespace. The inlined
// client-side script reads the URL on hydrate, ticks matching boxes,
// and re-applies the filter to every `[data-tags]` card on the page.
// On change, the URL is updated via `history.replaceState` and the
// filter is re-applied; the first matching card is scrolled into view.
//
// Layout: sits in the RIGHT gutter at ≥1200px (narrow content pages,
// home + sites) and at ≥1640px (wide content pages, date + tag landing
// pages, which set Base `wide`). On the wide layout the TriageRail
// gets moved to the LEFT gutter (see TriageRail.astro) so the filter
// rail owns the right.
//
// Below 1200px the rail is hidden entirely. The PR-3 mobile drawer
// will surface filters on smaller viewports; until then the static
// `/tags/<slug>/` landings + intersection URLs serve narrow-screen
// filter intent.
//
// Cards lacking the `[data-tags]` attribute (e.g. a hypothetical pre-
// v0.11 study artifact) are intentionally left UNFILTERED — the
// filter logic only touches elements that opted in via the attribute.
// This is the empty-tags semantic pinned in
// test/study-data-tags.test.ts.

import { VERDICT_META } from '../lib/verdict.ts';
import type { TagNamespace } from '../lib/tag-foundations.ts';

interface TagOption {
  slug: string;
  label: string;
  count: number; // base count for this tag on the current page
}

interface Props {
  // Per-namespace tag options, in the display order the rail should
  // render. Caller passes only tags that have at least one card on the
  // current page, so the rail never shows a zero-count checkbox the
  // reader can never satisfy.
  modality?: TagOption[];
  intent?: TagOption[];
  methodology?: TagOption[];
  verdict?: TagOption[];
  meeting?: TagOption[];
  // Pre-checked filters (e.g. on /tags/<slug>/ the URL's path tag is
  // checked at server render so the page loads with the correct
  // visible card set even before JS hydrates). Passed slug-only.
  initialFilters?: ReadonlyArray<string>;
  // Pre-checked filters the reader CANNOT uncheck. On /tags/<slug>/
  // the path-derived tag(s) lock — unchecking them would silently
  // empty the page (the SSR rendered only matching cards).
  lockedFilters?: ReadonlyArray<string>;
  // Total visible-card count for the header. Caller computes this so
  // the rail header reads e.g. "FILTERS — 41 studies".
  totalCount: number;
}

const {
  modality = [],
  intent = [],
  methodology = [],
  verdict = [],
  meeting = [],
  initialFilters = [],
  lockedFilters = [],
  totalCount,
} = Astro.props as Props;

// Render order is the v0.10 information hierarchy: Verdict (the triage
// signal subspecialists scan for first), then Modality / Intent /
// Methodology (the structural facets), then Meeting (the temporal
// facet). Order matches the cards' on-page chip order.
type Section = { namespace: TagNamespace; label: string; options: TagOption[] };
const allSections: Section[] = [
  { namespace: 'verdict', label: 'Verdict', options: verdict },
  { namespace: 'modality', label: 'Modality', options: modality },
  { namespace: 'intent', label: 'Intent', options: intent },
  { namespace: 'methodology', label: 'Methodology', options: methodology },
  { namespace: 'meeting', label: 'Meeting', options: meeting },
];
const sections: Section[] = allSections.filter((s) => s.options.length > 0);

const initialSet = new Set(initialFilters.map((s) => s.toLowerCase()));
const lockedSet = new Set(lockedFilters.map((s) => s.toLowerCase()));

// Verdict emojis come from the canonical taxonomy. Other namespaces
// don't carry an emoji vocabulary — they stay plain text.
function emojiFor(namespace: TagNamespace, slug: string): string | null {
  if (namespace !== 'verdict') return null;
  const meta = (VERDICT_META as Record<string, { emoji: string }>)[slug];
  return meta?.emoji ?? null;
}
---

{sections.length > 0 && (
  <Fragment>
    {/* v0.11 PR-3 mobile drawer trigger. Rendered inline in document
        flow so it appears above the cards on each page type, BUT only
        visible at viewports where the desktop rail is hidden (the CSS
        in the style block flips visibility on the same breakpoints).
        Carries an aria-controls + aria-expanded pair so screen readers
        announce the drawer state changes. */}
    <button
      type="button"
      class="filter-rail-trigger"
      data-filter-rail-trigger
      data-active={initialSet.size > 0 ? 'true' : null}
      aria-controls="filter-rail-panel"
      aria-haspopup="dialog"
      aria-expanded="false"
    >
      <span class="filter-rail-trigger-label">Filters</span>
      <span class="filter-rail-trigger-count" data-filter-rail-trigger-count>
        {totalCount}
      </span>
    </button>
    {/* Backdrop for the mobile drawer: tap-outside dismiss. Hidden
        until the drawer is open at mobile breakpoints. */}
    <div
      class="filter-rail-backdrop"
      data-filter-rail-backdrop
      hidden
    ></div>
    {/* PR-6 page-level empty banner: inline in document flow ABOVE
        the cards, visible on mobile when the drawer is closed AND
        the filter yields zero matches. Both reviewers caught the
        original empty-state lived inside the closed drawer where a
        mobile reader couldn't see it. Hidden by default; the JS
        toggles visibility when visible-card count is 0 AND the
        active filter set is non-empty. Pure text + "Open filters"
        link to the drawer trigger — the suggestions stay in the
        drawer panel for desktop + opened-drawer cases. */}
    <div
      class="filter-rail-page-empty"
      data-filter-rail-page-empty
      hidden
      role="status"
      aria-live="polite"
    ></div>
    <aside
      id="filter-rail-panel"
      class="filter-rail"
      role="dialog"
      aria-modal="true"
      aria-labelledby="filter-rail-title"
      data-filter-rail
    >
    <header class="filter-rail-header">
      <div class="filter-rail-title" id="filter-rail-title">Filters</div>
      <div class="filter-rail-count" data-filter-rail-count>
        {totalCount} stud{totalCount === 1 ? 'y' : 'ies'}
      </div>
      {/* Close button shown only when the drawer is open at mobile
          breakpoints. Provides keyboard + tap dismiss alongside Escape
          and tap-outside. */}
      <button
        type="button"
        class="filter-rail-close"
        data-filter-rail-close
        aria-label="Close filters"
      >×</button>
    </header>

    {sections.map((section) => (
      <fieldset class="filter-rail-section" data-namespace={section.namespace}>
        <legend>{section.label}</legend>
        <ul>
          {section.options.map((opt) => {
            const checked = initialSet.has(opt.slug);
            const locked = lockedSet.has(opt.slug);
            const id = `filter-${section.namespace}-${opt.slug}`;
            const emoji = emojiFor(section.namespace, opt.slug);
            return (
              <li>
                <label for={id}>
                  <input
                    type="checkbox"
                    id={id}
                    data-filter-checkbox
                    data-slug={opt.slug}
                    data-namespace={section.namespace}
                    checked={checked}
                    disabled={locked}
                  />
                  {emoji && <span class="filter-rail-emoji" aria-hidden="true">{emoji}</span>}
                  <span class="filter-rail-label">{opt.label}</span>
                  <span class="filter-rail-base-count">{opt.count}</span>
                </label>
              </li>
            );
          })}
        </ul>
      </fieldset>
    ))}

    {/* Active-filter summary + empty-state suggestions live at the
        BOTTOM of the rail (not the top) so ticking a checkbox doesn't
        push the namespace sections downward — the box you just clicked
        stays at the same y-coordinate. */}
    <div class="filter-rail-active" data-filter-rail-active hidden>
      {/* Replaced by client script when filters are active. */}
    </div>
    <div
      class="filter-rail-empty"
      data-filter-rail-empty
      hidden
      role="status"
      aria-live="polite"
    >
      {/* PR-9 promise folded into PR-6: when the active filter yields
          zero studies, surface "Removing X would show N" suggestions
          so the reader has a one-tap path back to a non-empty view.
          Populated by the inline script via textContent + dataset to
          dodge any innerHTML interpolation surface. */}
    </div>

    <button type="button" class="filter-rail-clear" data-filter-rail-clear>
      Clear all
    </button>
    </aside>
  </Fragment>
)}

<style>
  /* ── Mobile drawer trigger (PR-3) ───────────────────────────────
     Inline in document flow on smaller viewports; CSS-hidden on
     viewports where the desktop rail takes over. */
  .filter-rail-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1rem;
    padding: 0.45rem 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    background: var(--bg-card);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    /* Touch target: 36px tall is below iOS HIG 44px; bump on mobile. */
    min-height: 44px;
  }
  .filter-rail-trigger:hover,
  .filter-rail-trigger:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-rail-trigger-label {
    font-weight: 500;
  }
  .filter-rail-trigger-count {
    margin-left: auto;
    padding: 0.05rem 0.45rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
  }
  /* Subtle pulse when filters are active to nudge readers toward the
     active state without being visually loud. data-active is set
     server-side via initialSet (no first-paint flash on URL-filtered
     loads) and updated client-side after each filter change. */
  .filter-rail-trigger[data-active='true'] {
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-rail-trigger[data-active='true'] .filter-rail-trigger-count {
    background: var(--accent);
    color: var(--bg-card);
  }

  /* Hide the trigger while the drawer is open so it can't sit
     visually-obscured behind the backdrop with `aria-expanded=true` —
     a screen-reader user tabbing onto it would land on a hidden
     element. Adversarial review caught this. */
  :global(html[data-drawer-open]) .filter-rail-trigger {
    visibility: hidden;
  }

  /* ── Mobile drawer backdrop ─────────────────────────────────────
     Hidden until the drawer is opened at mobile breakpoints. */
  .filter-rail-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 50;
    /* Tap-outside dismiss happens via JS click handler. */
  }

  /* ── Mobile drawer close button ─────────────────────────────────
     Inside the rail header; visible only at mobile breakpoints. */
  .filter-rail-close {
    margin-left: auto;
    width: 36px;
    height: 36px;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: var(--fg-muted);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    display: none;
  }
  .filter-rail-close:hover,
  .filter-rail-close:focus-visible {
    background: var(--accent-bg);
    color: var(--accent);
  }

  /* Hidden by default; bottom-sheet drawer state at mobile widths. */
  .filter-rail { display: none; }
  .filter-rail-trigger { display: none; }

  /* Mobile / tablet drawer at <1200px (narrow body) and <1640px (wide
     body). Trigger is inline in document flow; rail sits as a bottom
     sheet, transformed off-screen until the drawer is open. */
  @media (max-width: 1199.98px) {
    body:not(.wide) .filter-rail-trigger { display: flex; }
    body:not(.wide) .filter-rail {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      /* 100dvh accounts for iOS Safari's collapsing URL bar — 100vh
         would over-shoot and put the close button off-screen. Falls
         back to vh on older browsers via the safety net below. */
      max-height: 80vh;
      max-height: 80dvh;
      padding: 0.75rem 0.75rem calc(1rem + env(safe-area-inset-bottom, 0));
      background: var(--bg);
      border-top: 1px solid var(--border);
      border-radius: 14px 14px 0 0;
      box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.25);
      overflow-y: auto;
      font-family: var(--font-sans);
      z-index: 60;
      /* Slide up when [data-open]; out-of-view by default. The
         transform animates so readers feel the drawer arrive. */
      transform: translateY(100%);
      transition: transform 200ms ease;
    }
    body:not(.wide) .filter-rail[data-open='true'] {
      transform: translateY(0);
    }
    body:not(.wide) .filter-rail-close { display: flex; align-items: center; justify-content: center; }
  }
  @media (max-width: 1639.98px) {
    body.wide .filter-rail-trigger { display: flex; }
    body.wide .filter-rail {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      max-height: 80vh;
      max-height: 80dvh;
      padding: 0.75rem 0.75rem calc(1rem + env(safe-area-inset-bottom, 0));
      background: var(--bg);
      border-top: 1px solid var(--border);
      border-radius: 14px 14px 0 0;
      box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.25);
      overflow-y: auto;
      font-family: var(--font-sans);
      z-index: 60;
      transform: translateY(100%);
      transition: transform 200ms ease;
    }
    body.wide .filter-rail[data-open='true'] {
      transform: translateY(0);
    }
    body.wide .filter-rail-close { display: flex; align-items: center; justify-content: center; }
  }

  /* Body scroll-lock when the drawer is open: the JS adds
     [data-drawer-open] to <html>; the page underneath stops scrolling
     so the drawer feels like a real modal. */
  :global(html[data-drawer-open]) {
    overflow: hidden;
  }

  /* Narrow body (700px, home + sites): rail visible at ≥1200px. The
     viewport gutter at 1200px is (1200-700)/2 = 250px on each side,
     enough to hold the 220px rail at right:1.25rem without overlap. */
  @media (min-width: 1200px) {
    body:not(.wide) .filter-rail {
      display: block;
      position: fixed;
      top: 6.5rem;
      right: 1.25rem;
      width: 220px;
      max-height: calc(100vh - 9rem);
      overflow-y: auto;
      font-family: var(--font-sans);
      background: var(--bg);
      z-index: 5;
    }
  }

  /* Wide body (1180px, date + tag-landings): rail waits for ≥1640px
     because at 1200-1639px viewports the content column nearly fills
     the screen and the rail would paint OVER the right edge of every
     card. Both reviewers caught this. Below 1640px, wide-body pages
     get no filter rail — readers narrow via /tags/<slug>/ navigation
     until PR-3 ships the mobile drawer. */
  @media (min-width: 1640px) {
    body.wide .filter-rail {
      display: block;
      position: fixed;
      top: 6.5rem;
      right: 1.25rem;
      width: 220px;
      max-height: calc(100vh - 9rem);
      overflow-y: auto;
      font-family: var(--font-sans);
      background: var(--bg);
      z-index: 5;
    }
  }

  .filter-rail-header {
    margin-bottom: 0.5rem;
    padding: 0 0.4rem;
  }
  .filter-rail-title {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .filter-rail-count {
    font-size: 0.75rem;
    color: var(--fg-muted);
    margin-top: 0.1rem;
  }

  /* Active-filter summary chips appear above the namespace sections
     when at least one filter is on. Updated by the inline script. */
  .filter-rail-active {
    margin: 0.4rem 0.4rem 0.8rem;
    padding: 0.5rem 0.6rem;
    background: var(--accent-bg);
    border-radius: 4px;
    font-size: 0.75rem;
    line-height: 1.45;
  }
  .filter-rail-active strong {
    color: var(--accent);
    font-weight: 600;
  }
  .filter-rail-rss {
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .filter-rail-rss:hover,
  .filter-rail-rss:focus-visible {
    text-decoration: underline;
  }

  /* PR-6 smart empty-state: when the active filter narrows to 0
     studies, show "Removing X would show N" suggestions so the
     reader has a one-tap escape. Lives under the active-chips
     summary; visible only when populated. */
  .filter-rail-empty {
    margin: 0.4rem 0.4rem 0.8rem;
    padding: 0.6rem 0.7rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--fg-muted);
  }
  .filter-rail-empty strong {
    color: var(--fg);
    font-weight: 500;
  }
  .filter-rail-empty-suggest {
    display: block;
    margin-top: 0.35rem;
    color: var(--accent);
    background: transparent;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    text-align: left;
  }
  .filter-rail-empty-suggest:hover,
  .filter-rail-empty-suggest:focus-visible {
    text-decoration: underline;
  }

  /* PR-6 page-level empty banner. Inline in document flow so it's
     readable on mobile when the drawer is closed; on desktop the rail
     itself shows the richer empty-state, so the banner is suppressed
     to avoid duplication. */
  .filter-rail-page-empty {
    margin: 1rem 0 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--fg-muted);
  }
  .filter-rail-page-empty strong {
    color: var(--fg);
    font-weight: 500;
  }
  .filter-rail-page-empty button {
    background: transparent;
    border: none;
    padding: 0;
    margin-left: 0.4rem;
    color: var(--accent);
    font: inherit;
    cursor: pointer;
  }
  .filter-rail-page-empty button:hover,
  .filter-rail-page-empty button:focus-visible {
    text-decoration: underline;
  }
  /* Suppress the page-level banner at desktop breakpoints — the
     drawer-internal empty-state is already visible there. */
  @media (min-width: 1200px) {
    body:not(.wide) .filter-rail-page-empty { display: none; }
  }
  @media (min-width: 1640px) {
    body.wide .filter-rail-page-empty { display: none; }
  }

  .filter-rail-section {
    border: none;
    margin: 0;
    padding: 0.5rem 0.4rem 0.5rem;
  }
  .filter-rail-section legend {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.25rem;
  }
  .filter-rail-section ul { list-style: none; margin: 0; padding: 0; }
  .filter-rail-section li { margin: 0; }

  .filter-rail-section label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.22rem 0.3rem;
    border-radius: 4px;
    font-size: 0.8rem;
    line-height: 1.3;
    color: var(--fg);
    cursor: pointer;
  }
  .filter-rail-section label:hover {
    background: var(--accent-bg);
  }
  .filter-rail-section input[type='checkbox'] {
    flex: none;
    margin: 0;
    accent-color: var(--accent);
  }
  .filter-rail-section input[type='checkbox']:disabled + .filter-rail-emoji,
  .filter-rail-section input[type='checkbox']:disabled ~ .filter-rail-label {
    opacity: 0.55;
  }
  .filter-rail-emoji {
    flex: none;
    font-size: 0.85rem;
    line-height: 1;
  }
  .filter-rail-label {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .filter-rail-base-count {
    flex: none;
    font-variant-numeric: tabular-nums;
    color: var(--fg-muted);
    font-size: 0.72rem;
  }

  .filter-rail-clear {
    margin: 0.6rem 0.4rem 0;
    width: calc(100% - 0.8rem);
    padding: 0.4rem 0.5rem;
    font-size: 0.78rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--fg-muted);
    font-family: inherit;
    cursor: pointer;
  }
  .filter-rail-clear:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-rail-clear:disabled {
    opacity: 0.5;
    cursor: default;
  }
</style>

<script is:inline>
  /* v0.11 PR-2 client-side filter logic. Pure DOM; no bundler.
     IMPORTANT: KEEP IN SYNC WITH src/lib/filter-store.ts. The pure
     module is unit-tested in test/filter-store.test.ts; THIS inline
     script reimplements the same semantics so it can ship per-page
     without a JS bundle dependency. When you change one, change the
     other AND update the relevant test. Both reviewers caught the
     drift risk; a future PR (likely PR-6) can extract this script
     into a shared <script src> and import directly from the pure
     module. */
  function init() {
    const rail = document.querySelector('[data-filter-rail]');
    if (!rail) return;

    const FILTER_KEY = 'tag';
    const SLUG_REGEX = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;

    const cards = Array.from(document.querySelectorAll('[data-tags]'));
    if (cards.length === 0) return;

    // Pre-compute each card's slug set once (filter logic queries it
    // every time the filter set changes). Sub-millisecond for 41 cards.
    const cardData = cards.map((card) => {
      const tokens = (card.getAttribute('data-tags') || '')
        .split(/\s+/)
        .filter(Boolean);
      const slugs = new Set();
      for (const t of tokens) {
        const idx = t.indexOf(':');
        if (idx > 0 && idx < t.length - 1) {
          slugs.add(t.slice(idx + 1).toLowerCase());
        }
      }
      return { el: card, slugs };
    });

    const checkboxes = Array.from(rail.querySelectorAll('[data-filter-checkbox]'));
    const activeEl = rail.querySelector('[data-filter-rail-active]');
    const countEl = rail.querySelector('[data-filter-rail-count]');
    const clearBtn = rail.querySelector('[data-filter-rail-clear]');
    const trigger = document.querySelector('[data-filter-rail-trigger]');
    const triggerCount = document.querySelector('[data-filter-rail-trigger-count]');
    const triggerCountBase = triggerCount ? triggerCount.textContent : '';
    const backdrop = document.querySelector('[data-filter-rail-backdrop]');
    const closeBtn = rail.querySelector('[data-filter-rail-close]');
    const emptyEl = rail.querySelector('[data-filter-rail-empty]');
    const pageEmptyEl = document.querySelector('[data-filter-rail-page-empty]');
    const baseTotalText = countEl ? countEl.textContent : '';
    /* PR-6 aria-live spam guard: cache the last rendered empty-state
       signature so repeated checkbox toggles that yield the same
       suggestion list don't re-trigger a screen-reader announcement.
       Reviewers caught the original announced on every change. */
    let lastEmptySignature = '';

    /* PR-6 smart empty-state: build a slug → label map once so the
       suggestion buttons can render the same label the checkbox shows.
       Reads from the SSR-rendered checkbox labels rather than the
       namespace JSON because the checkbox labels reflect the curator's
       voice + the page's filter context (e.g. "Practice-changing"
       casing, "Phase 3 RCT" with space, etc.). */
    const slugLabels = (function () {
      const out = new Map();
      for (const cb of checkboxes) {
        const slug = cb.getAttribute('data-slug');
        if (!slug) continue;
        const labelEl = cb.parentElement
          ? cb.parentElement.querySelector('.filter-rail-label')
          : null;
        out.set(slug, (labelEl && labelEl.textContent) || slug);
      }
      return out;
    })();

    /* PR-5: read the inlined built-intersections allowlist + the
       namespace map (PR-1a) so the canonical-redirect + RSS-subscribe
       logic knows when the active filter set has a canonical landing
       page. The namespace map doubles as the single-tag allowlist —
       every slug in it has a /tags/<slug>/ landing by construction.
       Codex P1: without this gate, a bookmarked
       /?tag=invalid-slug would redirect to /tags/invalid-slug/ → 404. */
    const builtIntersections = (function () {
      const el = document.getElementById('built-intersections');
      if (!el) return new Set();
      try {
        const parsed = JSON.parse(el.textContent || '{}');
        if (parsed && Array.isArray(parsed.paths)) {
          return new Set(parsed.paths);
        }
      } catch (e) {
        /* malformed JSON — treat as empty allowlist */
      }
      return new Set();
    })();
    const validSlugs = (function () {
      const el = document.getElementById('tag-namespaces');
      if (!el) return new Set();
      try {
        const parsed = JSON.parse(el.textContent || '{}');
        if (parsed && parsed.map && typeof parsed.map === 'object') {
          return new Set(Object.keys(parsed.map));
        }
      } catch (e) {
        /* malformed — treat as empty (every single-tag redirect now
           bails out, which is safer than a guaranteed 404). */
      }
      return new Set();
    })();

    const lockedSlugs = new Set();
    for (const cb of checkboxes) {
      if (cb.disabled) {
        const slug = cb.getAttribute('data-slug');
        if (slug) lockedSlugs.add(slug);
      }
    }

    /** Read the active filter set from window.location.search. */
    function readUrl() {
      const params = new URLSearchParams(window.location.search);
      const out = new Set();
      for (const [k, v] of params) {
        if (k.toLowerCase() !== FILTER_KEY) continue;
        const slug = v.trim().toLowerCase();
        if (!slug || !SLUG_REGEX.test(slug)) continue;
        out.add(slug);
      }
      return out;
    }

    /* PR-5 canonical strategy: when the active filter set matches a
       pre-generated /tags/<slug>/ or /tags/<a>+<b>(+<c>)/ landing
       page, redirect to that canonical URL. Auto-redirect runs ONLY
       on the full corpus index (/studies/, the v0.14 T3 home of the
       filter rail) and on existing /tags/ routes — on /sites/ and
       /<date>/ pages the redirect would silently drop the site/date
       scope, so the canonical URL is only ever a suggestion there
       (handled by the RSS button being suppressed). (Before T3 the
       full index was home (/); the rail moved to /studies/ with it.) */
    const FILTER_RECEPTIVE_ROUTES = ['/studies/'];
    function isFilterReceptiveRoute(pathname) {
      if (FILTER_RECEPTIVE_ROUTES.includes(pathname)) return true;
      // /tags/<...>/ landings — both single-tag and intersections.
      // /tags/ itself is the index; allow but no auto-redirect because
      // there's no implicit filter scope.
      return /^\/tags\/[^/]+\/?$/.test(pathname);
    }

    function canonicalForActive(active) {
      if (active.size === 0) return null;
      // Sort + alphabetical-join — must match the SSR
      // buildIntersectionAllowlist output format.
      const sorted = Array.from(active).sort();
      const canonical = sorted.join('+');
      if (sorted.length === 1) {
        // Single-tag: validate against the namespace map. Every slug
        // in the map has a /tags/<slug>/ landing; slugs OUTSIDE the
        // map (typo'd bookmark, future-rename, hand-edited URL) would
        // redirect to a non-existent page → 404. Codex P1 fix.
        return validSlugs.has(canonical) ? canonical : null;
      }
      // 2-way and 3-way: must appear in the built allowlist.
      if (builtIntersections.has(canonical)) return canonical;
      return null;
    }

    /** Cross-route redirect if the active set has a canonical and we
       are on a route where auto-redirect is allowed. Returns true if
       a redirect fired (caller should bail out of further work — the
       page is about to navigate). */
    function maybeCrossRouteRedirect(active) {
      const canonical = canonicalForActive(active);
      if (!canonical) return false;
      const target = '/tags/' + canonical + '/';
      const currentPath = window.location.pathname;
      if (currentPath === target) return false; // already canonical
      if (!isFilterReceptiveRoute(currentPath)) return false;
      // PR-5 review (Claude P1): on slow networks the navigation
      // window can run hundreds of ms. Without this guard the reader
      // sees the unfiltered SSR cards because applyFilter was skipped.
      // Hide every study card before navigating so the page goes
      // blank-blank rather than wrong-content → blank → right-content.
      for (const card of cardData) {
        card.el.setAttribute('hidden', '');
      }
      // Full cross-route navigation — replaceState would leave the
      // page DOM in place and PR-5 promised an actual navigation.
      window.location.assign(target);
      return true;
    }

    /** Build a canonical filter URL and history.replaceState into it. */
    function writeUrl(active) {
      const url = new URL(window.location.href);
      // Strip every `tag` (case-folded) before re-appending in canonical
      // alphabetical order. Mirror of buildFilterUrl in filter-store.ts.
      const keys = Array.from(new Set(Array.from(url.searchParams.keys())));
      for (const k of keys) {
        if (k.toLowerCase() === FILTER_KEY) url.searchParams.delete(k);
      }
      const sorted = Array.from(active).sort();
      // PR-5 review (Claude P2): when the active set is JUST the
      // locked filter on /tags/<locked>/, the URL would mirror the
      // path as a redundant ?tag=<locked>. Drop the URL params in
      // that case so the address bar stays clean.
      const lockedOnlyOnCanonical =
        active.size === lockedSlugs.size &&
        Array.from(lockedSlugs).every(function (s) {
          return active.has(s);
        }) &&
        window.location.pathname === '/tags/' + sorted.join('+') + '/';
      if (!lockedOnlyOnCanonical) {
        for (const slug of sorted) url.searchParams.append(FILTER_KEY, slug);
      }
      const target = url.pathname + url.search + url.hash;
      // replaceState (not pushState) — per autoplan revision, every chip
      // click would otherwise stack as a back-button entry the reader
      // would have to walk through one filter at a time.
      window.history.replaceState(window.history.state, '', target);
    }

    /* PR-6: TriageRail stale-item tracking. The jump-list items on
       /<date>/ and /tags/<...>/ pages link to per-study anchors; when
       the filter hides a card, the matching TriageRail item points to
       a hidden target. Codex P2 caught the dead-link surface. Snapshot
       the (item, target-card, anchor) triples once at init — TriageRail
       is SSR'd in the same pass as the cards, so there's no late-DOM
       race. applyFilter iterates the triples and toggles data-stale +
       tabindex on the anchor (pointer-events handled by CSS). */
    const triageItems = (function () {
      const out = [];
      const anchors = document.querySelectorAll('.triage-rail a[href^="#"]');
      for (const a of anchors) {
        const href = a.getAttribute('href');
        if (!href) continue;
        const id = href.slice(1);
        const target = id ? document.getElementById(id) : null;
        if (!target) continue;
        const li = a.closest('li');
        if (li) out.push({ li, target, anchor: a });
      }
      return out;
    })();

    /** Apply the filter to every [data-tags] card on the page. */
    function applyFilter(active, options) {
      let visible = 0;
      for (const { el, slugs } of cardData) {
        let match = true;
        if (active.size > 0) {
          for (const slug of active) {
            if (!slugs.has(slug)) {
              match = false;
              break;
            }
          }
        }
        if (match) {
          el.removeAttribute('hidden');
          visible++;
        } else {
          el.setAttribute('hidden', '');
        }
      }
      // Dim TriageRail items whose target study is now hidden AND
      // remove them from the keyboard tab order. The CSS rule on
      // [data-stale=true] handles pointer-events; tabindex=-1 keeps
      // them out of Tab focus so a keyboard user doesn't land on a
      // dead link.
      for (const { li, target, anchor } of triageItems) {
        if (target.hasAttribute('hidden')) {
          li.setAttribute('data-stale', 'true');
          anchor.setAttribute('tabindex', '-1');
        } else {
          li.removeAttribute('data-stale');
          anchor.removeAttribute('tabindex');
        }
      }
      // PR-6 smart empty-state: when the active filter yields 0 cards
      // AND there are 2+ unlocked filters, suggest the single removal
      // that would unlock the most studies. textContent + dynamic
      // button creation only (no innerHTML interpolation surface).
      //
      // Aria-live spam guard: compute a signature for the empty-state
      // contents (visible count + top suggestions) and only re-render
      // when it changes. Avoids screen-reader announcing on every
      // checkbox toggle that keeps the state empty.
      const isEmpty = visible === 0 && active.size > 0;
      let suggestions = [];
      if (isEmpty) {
        const unlocked = Array.from(active).filter(function (s) {
          return !lockedSlugs.has(s);
        });
        for (const removeSlug of unlocked) {
          const without = new Set(active);
          without.delete(removeSlug);
          let wouldShow = 0;
          for (const { slugs } of cardData) {
            if (without.size === 0) { wouldShow++; continue; }
            let ok = true;
            for (const s of without) {
              if (!slugs.has(s)) { ok = false; break; }
            }
            if (ok) wouldShow++;
          }
          if (wouldShow > 0) {
            suggestions.push({ slug: removeSlug, count: wouldShow });
          }
        }
        // Sort by count desc, then alphabetical for stability.
        suggestions.sort(function (a, b) {
          return b.count - a.count || (a.slug < b.slug ? -1 : a.slug > b.slug ? 1 : 0);
        });
        // Cap at top-2 — cognitive load + screen-reader brevity.
        suggestions = suggestions.slice(0, 2);
      }
      const signature = isEmpty
        ? '0|' + suggestions.map(function (s) { return s.slug + ':' + s.count; }).join(',')
        : 'n';
      const lockedForcedEmpty =
        isEmpty && suggestions.length === 0 && lockedSlugs.size > 0;
      if (emptyEl && signature !== lastEmptySignature) {
        lastEmptySignature = signature;
        emptyEl.textContent = '';
        if (isEmpty) {
          const heading = document.createElement('strong');
          heading.textContent = 'No studies match this filter.';
          emptyEl.appendChild(heading);
          if (suggestions.length === 0) {
            if (lockedForcedEmpty) {
              // Reader is stuck on a locked /tags/<...>/ page where
              // every unlocked removal still yields 0. Offer an
              // actual escape link instead of the lying "clear all".
              const tip = document.createTextNode(' ');
              emptyEl.appendChild(tip);
              const link = document.createElement('a');
              link.href = '/tags/';
              link.textContent = 'Browse all tags →';
              emptyEl.appendChild(link);
            } else {
              const tip = document.createTextNode(' Use Clear all to reset.');
              emptyEl.appendChild(tip);
            }
          } else {
            for (const s of suggestions) {
              const btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'filter-rail-empty-suggest';
              btn.textContent =
                'Drop ' + (slugLabels.get(s.slug) || s.slug) + ' → ' + s.count + ' would show.';
              btn.dataset.removeSlug = s.slug;
              emptyEl.appendChild(btn);
            }
          }
          emptyEl.removeAttribute('hidden');
        } else {
          emptyEl.setAttribute('hidden', '');
        }
      }
      // Page-level inline empty banner (mobile-only via CSS). Mirrors
      // the trigger-open + drawer-open path so a mobile reader with
      // the drawer closed sees the recovery affordance directly above
      // the (empty) card list.
      if (pageEmptyEl) {
        if (isEmpty) {
          pageEmptyEl.textContent = '';
          const heading = document.createElement('strong');
          heading.textContent = 'No studies match this filter.';
          pageEmptyEl.appendChild(heading);
          const open = document.createElement('button');
          open.type = 'button';
          open.textContent = 'Open filters';
          open.addEventListener('click', function () {
            if (trigger) trigger.click();
          });
          pageEmptyEl.appendChild(open);
          pageEmptyEl.removeAttribute('hidden');
        } else {
          pageEmptyEl.setAttribute('hidden', '');
        }
      }
      // Update the active-filter summary + count.
      if (activeEl) {
        if (active.size === 0) {
          activeEl.setAttribute('hidden', '');
          activeEl.textContent = '';
        } else {
          activeEl.removeAttribute('hidden');
          const chipLabels = [];
          for (const slug of active) {
            const cb = rail.querySelector(
              '[data-filter-checkbox][data-slug="' + slug + '"]',
            );
            const labelEl = cb && cb.parentElement
              ? cb.parentElement.querySelector('.filter-rail-label')
              : null;
            chipLabels.push((labelEl && labelEl.textContent) || slug);
          }
          /* PR-5 RSS subscribe link: when the active set matches a
             built canonical landing AND the current route IS that
             canonical landing, surface an RSS feed link pointing at
             the existing /tags/<canonical>/feed.xml endpoint (built
             in v0.10 PR3). The previous "startsWith('/tags/')" gate
             was too loose — Claude review caught that a future
             /tags/foo/related/ subpath would match without a feed
             existing. Exact-path-match closes the gap. */
          const canonical = canonicalForActive(active);
          const showRss =
            canonical !== null &&
            window.location.pathname === '/tags/' + canonical + '/';
          activeEl.innerHTML =
            'Filtering: <strong>' +
            chipLabels.map(escapeHtml).join(' + ') +
            '</strong> · ' +
            visible +
            ' shown' +
            (showRss
              ? ' · <a class="filter-rail-rss" href="/tags/' +
                escapeHtml(canonical) +
                '/feed.xml" rel="alternate" type="application/rss+xml">📡 RSS</a>'
              : '');
        }
      }
      if (countEl) {
        if (active.size === 0) {
          countEl.textContent = baseTotalText;
        } else {
          countEl.textContent =
            visible + ' of ' + cardData.length + ' stud' + (cardData.length === 1 ? 'y' : 'ies');
        }
      }
      if (clearBtn) {
        clearBtn.toggleAttribute('disabled', active.size === 0);
      }
      // PR-3: mobile trigger reflects the active filter state. Count
      // becomes the visible-card count when filters are on; falls back
      // to the base total when filters are cleared. data-active toggles
      // the accent styling so the trigger reads as "filtered" at a
      // glance even before the reader opens the drawer.
      if (trigger) {
        if (active.size === 0) {
          trigger.removeAttribute('data-active');
          if (triggerCount) triggerCount.textContent = triggerCountBase;
        } else {
          trigger.setAttribute('data-active', 'true');
          if (triggerCount) triggerCount.textContent = String(visible);
        }
      }
      // Scroll-to-first-visible on USER-triggered changes (not URL hydrate).
      if (options && options.scrollToFirst) {
        for (const { el } of cardData) {
          if (!el.hasAttribute('hidden')) {
            const r = el.getBoundingClientRect();
            // Only scroll if the first visible card is off-screen above
            // the fold; otherwise the page jump is more disruptive than
            // the silent narrow.
            if (r.top < 0) {
              el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
            break;
          }
        }
      }
    }

    /** Tick / untick checkboxes to match the given active set. */
    function syncCheckboxes(active) {
      for (const cb of checkboxes) {
        const slug = cb.getAttribute('data-slug');
        if (!slug) continue;
        const desired = active.has(slug);
        if (cb.checked !== desired) {
          cb.checked = desired;
        }
      }
    }

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    /** Hydrate from URL → tick boxes → apply filter. Called on first
       load and on bfcache restore (pageshow event.persisted=true). */
    function hydrate() {
      const active = readUrl();
      // Respect locked checkboxes — they're always in the active set
      // regardless of URL (the /tags/<slug>/ page already rendered only
      // matching cards; unchecking is impossible client-side).
      for (const slug of lockedSlugs) active.add(slug);
      // PR-5 canonical: a URL like /?tag=radiation+phase-3-rct on a
      // filter-receptive route should immediately navigate to the
      // canonical landing. Bail out of further hydration — the page
      // is about to unload.
      if (maybeCrossRouteRedirect(active)) return;
      syncCheckboxes(active);
      applyFilter(active, { scrollToFirst: false });
    }

    /** Handler for checkbox change events. Reads ticked state from the
       DOM (not from a Set we maintain), builds the active set, writes
       URL + applies filter. PR-5 canonical: if the user is on a
       filter-receptive route AND the new active set matches a built
       canonical landing, cross-route navigate there instead. */
    function onChange() {
      const active = new Set();
      for (const cb of checkboxes) {
        if (cb.checked) {
          const slug = cb.getAttribute('data-slug');
          if (slug) active.add(slug);
        }
      }
      // Canonical redirect FIRST — saves the same-route URL write
      // and the apply-filter pass when we're about to navigate away.
      if (maybeCrossRouteRedirect(active)) return;
      writeUrl(active);
      applyFilter(active, { scrollToFirst: true });
    }

    function onClear() {
      // Preserve locked filters even on clear-all. lockedSlugs is
      // already snapshot at init from the SSR-disabled checkboxes;
      // re-iterating here would be a second source of truth (Claude
      // review).
      const active = new Set(lockedSlugs);
      syncCheckboxes(active);
      writeUrl(active);
      applyFilter(active, { scrollToFirst: false });
    }

    /* ── PR-3 drawer state ────────────────────────────────────────
       Mobile-only behavior: trigger button opens the drawer, backdrop
       and Escape and close button dismiss it. Body scroll-locks while
       open via the html[data-drawer-open] attribute. Focus moves to
       the first interactive control on open and returns to the
       trigger on close. */
    let lastFocused = null;

    /* Focus trap: cycle Tab/Shift+Tab between the first and last
       focusable element inside the drawer when it's open. Adversarial
       + Codex review both caught the WAI-ARIA dialog gap. Disabled
       checkboxes are excluded. */
    function focusableInRail() {
      const candidates = rail.querySelectorAll(
        'button:not(:disabled), [href], input:not(:disabled), select:not(:disabled), textarea:not(:disabled), [tabindex]:not([tabindex="-1"])',
      );
      return Array.from(candidates).filter(function (el) {
        return el instanceof HTMLElement && !el.hidden;
      });
    }

    function openDrawer() {
      if (!trigger) return;
      const active = document.activeElement;
      // `lastFocused === document.body` is meaningless — body.focus()
      // on close would leave the page with no visible focus ring.
      // Fall back to the trigger in that case. Claude P1 finding.
      lastFocused =
        active && active !== document.body ? active : trigger;
      rail.setAttribute('data-open', 'true');
      if (backdrop) backdrop.removeAttribute('hidden');
      trigger.setAttribute('aria-expanded', 'true');
      document.documentElement.setAttribute('data-drawer-open', '');
      // Focus the first focusable element inside the rail.
      const focusables = focusableInRail();
      if (focusables.length > 0) focusables[0].focus();
    }
    function closeDrawer() {
      if (!trigger) return;
      rail.removeAttribute('data-open');
      if (backdrop) backdrop.setAttribute('hidden', '');
      trigger.setAttribute('aria-expanded', 'false');
      document.documentElement.removeAttribute('data-drawer-open');
      if (lastFocused && lastFocused instanceof HTMLElement) {
        lastFocused.focus();
      } else if (trigger instanceof HTMLElement) {
        trigger.focus();
      }
    }
    function isDrawerOpen() {
      return rail.getAttribute('data-open') === 'true';
    }

    // Wire events.
    for (const cb of checkboxes) {
      cb.addEventListener('change', onChange);
    }
    if (clearBtn) clearBtn.addEventListener('click', onClear);
    if (emptyEl) {
      emptyEl.addEventListener('click', function (e) {
        const target = e.target;
        if (
          target instanceof HTMLElement &&
          target.classList.contains('filter-rail-empty-suggest') &&
          target.dataset.removeSlug
        ) {
          const slug = target.dataset.removeSlug;
          // Untick the checkbox and fire onChange to re-run the
          // canonical-redirect + applyFilter pipeline.
          for (const cb of checkboxes) {
            if (cb.getAttribute('data-slug') === slug && !cb.disabled) {
              cb.checked = false;
              break;
            }
          }
          onChange();
        }
      });
    }
    if (trigger) {
      trigger.addEventListener('click', function () {
        if (isDrawerOpen()) closeDrawer();
        else openDrawer();
      });
    }
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (backdrop) backdrop.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function (e) {
      if (!isDrawerOpen()) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeDrawer();
        return;
      }
      // Focus trap: cycle Tab/Shift+Tab within the dialog.
      if (e.key === 'Tab') {
        const focusables = focusableInRail();
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const activeEl = document.activeElement;
        if (e.shiftKey) {
          if (activeEl === first || !rail.contains(activeEl)) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (activeEl === last || !rail.contains(activeEl)) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    /* Viewport-crossing cleanup (both reviewers P0): if the reader
       opens the drawer on mobile, then rotates / resizes past the
       desktop breakpoint, the [data-open] + html[data-drawer-open]
       + visible backdrop all remain — locking page scroll and painting
       the backdrop over the desktop layout with no way to close
       (close button is display:none on desktop). Listen for breakpoint
       crossings and force-close. */
    const narrowDesktopMq = window.matchMedia('(min-width: 1200px)');
    const wideDesktopMq = window.matchMedia('(min-width: 1640px)');
    function onBreakpointChange() {
      if (!isDrawerOpen()) return;
      const isWide = document.body.classList.contains('wide');
      if (isWide ? wideDesktopMq.matches : narrowDesktopMq.matches) {
        closeDrawer();
      }
    }
    if (narrowDesktopMq.addEventListener) {
      narrowDesktopMq.addEventListener('change', onBreakpointChange);
      wideDesktopMq.addEventListener('change', onBreakpointChange);
    } else if (narrowDesktopMq.addListener) {
      narrowDesktopMq.addListener(onBreakpointChange);
      wideDesktopMq.addListener(onBreakpointChange);
    }

    // Initial hydrate. The inline script runs WITHIN the Astro <body>,
    // potentially BEFORE the page's study cards are parsed below the
    // rail — so we defer wiring + hydrate to DOMContentLoaded (or
    // execute synchronously if the document is already complete).
    hydrate();
    // bfcache restore (iOS Safari + Firefox): re-hydrate so the URL
    // and the in-memory FilterStore stay in sync. event.persisted=true
    // means we came back via bfcache, not a fresh load.
    window.addEventListener('pageshow', function (e) {
      if (e.persisted) hydrate();
    });
    // History back/forward changes the URL but not the DOM — re-hydrate.
    window.addEventListener('popstate', hydrate);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
