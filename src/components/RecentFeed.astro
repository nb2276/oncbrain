---
// Shared flat study feed, rendered on the home page (a latest-N slice) and the
// /studies browse route (the full corpus). Extracted from index.astro in v0.14
// T3 so both surfaces share one row template, one stylesheet, and one client
// script.
//
// T3 corpus handling: `items` are the rows to RENDER; `allIds` is the FULL
// corpus of study ids. The home passes a 12-row slice plus the full allIds so
// the "new since last visit" count + seen-set cover the whole feed even though
// only a slice renders. /studies renders everything, so it omits allIds (the
// rendered rows are the corpus). The id list is embedded as JSON and read by
// whats-new.ts via initWhatsNew.
import { linkifyCitations } from '../lib/extract.ts';
import { getDiseaseSite } from '../lib/disease-sites.ts';
import { buildShareUrl } from '../lib/share-url.ts';
import { studyDataTags } from '../lib/study-data-tags.ts';
import { verdictMetaFor } from '../lib/verdict.ts';
import { jsonForScriptTag } from '../lib/json-script.ts';
import { stripStudyNamePrefix, type RecentStudy } from '../lib/digest-data.ts';

interface Props {
  // Rows to render (the home passes a slice; /studies passes everything).
  items: RecentStudy[];
  // The full corpus size, for the "Studies · N" heading.
  totalCount: number;
  // The full corpus ids, for the what's-new count + seen-set. Omit when
  // items already are the full corpus (/studies).
  allIds?: string[];
  // Optional "Browse all N studies →" link rendered under the slice (home).
  browseAll?: { href: string; label: string } | null;
  heading?: string;
  // v0.14.4: full-corpus id -> disease-site map, emitted as a JSON island so the
  // per-nav-chip new-counts cover studies the home doesn't render (it slices).
  // Omit on /studies (rows ARE the corpus; the client derives it from data-site).
  siteById?: Record<string, string>;
}

const { items, totalCount, allIds, browseAll = null, heading = 'Studies', siteById } = Astro.props as Props;
const showCorpusIds = Array.isArray(allIds) && allIds.length > 0;
const showSiteMap = siteById && Object.keys(siteById).length > 0;
---

<section class="recent-section">
  <h2 class="section-label">{heading} · {totalCount}<span class="recent-new-total" aria-live="polite"></span></h2>
  {showCorpusIds && (
    <script type="application/json" id="all-study-ids" set:html={jsonForScriptTag(allIds)} />
  )}
  {showSiteMap && (
    <script type="application/json" id="study-sites" set:html={jsonForScriptTag(siteById)} />
  )}
  <ul class="recent-list">
    {items.map((r) => {
      const meta = getDiseaseSite(r.disease_site);
      const tldr = stripStudyNamePrefix(r.study.tldr, r.study.name);
      const teaser = tldr.length > 200 ? tldr.slice(0, 199).trimEnd() + '…' : tldr;
      const shareUrl = buildShareUrl({ site: r.disease_site, date: r.date, slug: r.slug });
      const dataTags = studyDataTags(r.study, r.disease_site, r.conference?.slug ?? null);
      // T1-A: feed verdict glyph is practice-changing ONLY (a rarity flag).
      const practiceMeta =
        r.study.verdict?.soc_implication === 'practice-changing'
          ? verdictMetaFor('practice-changing')
          : null;
      // T2: stable per-study id for the "new since last visit" marker.
      const studyId = `${r.date}#${r.slug}`;
      return (
        <li class="recent-li" data-study-id={studyId} data-site={r.disease_site} data-tags={dataTags || undefined}>
          <a class="recent-card" href={`/${r.date}/#${r.slug}`}>
            <div class="recent-meta">
              <span class="recent-new-pill">New</span>
              {practiceMeta && (
                <span class="verdict-flag">
                  <span aria-hidden="true">{practiceMeta.emoji}</span>
                  <span class="sr-only">{practiceMeta.label}</span>
                </span>
              )}
              <span class="recent-emoji" aria-hidden="true" title={`${meta.label}: ${meta.rationale}`}>{meta.emoji}</span>
              <span class="recent-site">{meta.label}</span>
              <span class="recent-dot" aria-hidden="true">·</span>
              <span class="recent-date">{r.date}</span>
              {r.conference && (
                <span class="recent-conf">{r.conference.name}</span>
              )}
            </div>
            <div class="recent-name">{r.study.name}</div>
            <div class="recent-tldr" set:html={linkifyCitations(teaser)} />
          </a>
          {shareUrl && (
            <Fragment>
              <button
                type="button"
                class="recent-share"
                data-share-url={shareUrl}
                data-share-title={r.study.name}
                aria-label={`Share ${r.study.name}`}
                title="Share"
              ><svg class="share-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg></button>
              <span class="sr-share-status" aria-live="polite"></span>
              <input
                type="text"
                class="share-recovery"
                readonly
                tabindex={-1}
                aria-label="Copy this URL manually"
              />
            </Fragment>
          )}
        </li>
      );
    })}
  </ul>
  {browseAll && (
    <a class="recent-browse-all" href={browseAll.href}>{browseAll.label} →</a>
  )}
</section>

<style>
  /* Recent N studies list. */
  .recent-section { margin-top: 2.5rem; }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  /* Each feed item is a <li class="recent-li"> so the absolutely-positioned
     share button (sibling of the <a>) can use the li as its containing block.
     Button-in-anchor would be invalid HTML, hence the sibling layout. */
  .recent-li { position: relative; }
  .recent-card {
    display: block;
    min-height: 44px;
    /* Extra bottom padding so the TL;DR text doesn't run under the absolutely
       positioned share button at bottom-right. */
    padding: 0.9rem 1.05rem 2.2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
  }
  /* Card border stays accent while cursor is anywhere over the li OR keyboard
     focus lands on either the link or the share button — avoids the visual
     "card disconnect" when the cursor moves from card body to the absolutely-
     positioned share button (which is outside the <a>'s hover region). */
  .recent-li:hover .recent-card,
  .recent-card:focus-within { border-color: var(--accent); }
  .recent-li:focus-within .recent-card { border-color: var(--accent); }
  /* v0.14.4: when a filter is active, the matched (still-visible) cards get a
     brighter accent edge so the filtered results read as "these matched" rather
     than just "fewer rows". The flag is set on <html> by the filter rail's
     applyFilter; non-matching rows are [hidden] so only matches light up. */
  html[data-filtering] .recent-li:not([hidden]) .recent-card {
    border-color: var(--accent);
    box-shadow: inset 3px 0 0 var(--accent);
  }
  .recent-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    color: var(--fg-muted);
    margin-bottom: 0.25rem;
  }
  .recent-emoji { font-size: 0.95rem; }
  .recent-site { font-weight: 600; color: var(--fg); }
  .recent-dot { opacity: 0.55; }
  .recent-conf {
    margin-left: auto;
    padding: 0.05rem 0.45rem;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .recent-name {
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    color: var(--fg);
    margin-bottom: 0.2rem;
  }
  .recent-tldr {
    color: var(--fg-muted);
    font-size: 0.93rem;
    line-height: 1.45;
  }

  /* "Browse all N studies →" link under the home slice. Plain serif accent link,
     not a button, per DESIGN.md "cards earn their existence". */
  .recent-browse-all {
    display: inline-block;
    margin-top: 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .recent-browse-all:hover { text-decoration: underline; }

  /* T1-A: practice-changing feed flag (🚀). Sits at the head of the meta row,
     a touch larger than the site emoji so the rare flag reads as the row's
     priority signal. Only renders for practice-changing studies. */
  .verdict-flag { font-size: 1.0rem; line-height: 1; }

  /* T2: "new since last visit". The pill ships in markup hidden by default and
     is revealed by the .is-new class the client script adds to the <li> — never
     via inline display (the empty-inline-reveal footgun bit this codebase
     twice). Text pill at .section-label typography, NEUTRAL color, so it can't
     collide with the emoji vocabulary or imply a verdict. */
  .recent-new-pill {
    display: none;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.04rem 0.32rem;
    line-height: 1.5;
    align-self: center;
  }
  .recent-li.is-new .recent-new-pill { display: inline-block; }

  /* "N new overall" total beside the Studies heading. Hidden until the script
     fills it and adds .is-shown (same class-toggle reveal, no inline display). */
  .recent-new-total {
    display: none;
    margin-left: 0.45rem;
    font-weight: 400;
    color: var(--fg-muted);
    text-transform: none;
    letter-spacing: 0;
  }
  .recent-new-total.is-shown { display: inline; }

  /* Visually-hidden label so the bare 🚀 flag is announced ("Practice-changing")
     to screen readers instead of an emoji name. Same clip pattern as
     .sr-share-status. */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Share affordance: absolute bottom-right overlay, sibling of the link
     (button-in-anchor is invalid HTML). Hidden until share-script.ts confirms
     navigator.share or navigator.clipboard is available. .is-flipped is added
     during the Copied / Couldn't copy window for the accent-color flash. */
  .recent-share {
    display: none;
    align-items: center;
    justify-content: center;
    position: absolute;
    bottom: 0.5rem;
    right: 0.6rem;
    z-index: 2;
    background: none;
    border: none;
    padding: 0.5rem;
    color: var(--fg-muted);
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
  }
  .recent-share:hover { color: var(--accent); }
  .recent-share.is-flipped { color: var(--accent); }
  .recent-share .share-icon { display: block; }

  /* Screen-reader-only live region for state announcements. Visible label
     change is the sighted user's signal; this announces the same text to
     screen readers because mutating button textContent doesn't fire reliably
     across NVDA / JAWS / VoiceOver. */
  .sr-share-status {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Inline URL recovery: appears above the share button (rare path — when
     clipboard.writeText rejects). Pre-selected for Cmd+A/Cmd+C. Auto-hides
     after 10s. */
  .share-recovery {
    display: none;
    position: absolute;
    bottom: calc(0.5rem + 44px + 0.3rem);
    right: 0.6rem;
    z-index: 3;
    padding: 0.3rem 0.45rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    color: var(--fg);
    background: var(--bg-card);
    border: 1px solid var(--accent);
    border-radius: 3px;
    max-width: calc(100% - 1.2rem);
    width: 18rem;
  }
</style>

<script>
  // Wire the share buttons + the "new since last visit" marker wherever this
  // feed renders. Astro hoists + dedupes identical inline scripts across pages.
  import { initShareButtons } from '../lib/share-script.ts';
  import { initWhatsNew } from '../lib/whats-new.ts';
  function init() {
    initShareButtons();
    initWhatsNew();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
