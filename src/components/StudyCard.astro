  :global(:root:not([data-theme='light'])) .study.verdict-practice-changing { --verdict-color: #5fcc8a; }
  :global(:root:not([data-theme='light'])) .study.verdict-challenges-soc { --verdict-color: #d99a4a; }
  :global(:root:not([data-theme='light'])) .study.verdict-early-signal { --verdict-color: #6fbfd6; }
  :global(:root:not([data-theme='light'])) .study.verdict-methodologically-limited { --verdict-color: #d9785a; }

  /* Share affordance anchored to the top-right of .study-head. On wide
     figures-present cards (grid: head | figs at >=1200px) the head is the
     LEFT column, so the button stays in the narrative column instead of
     overlaying the figures column. .study-head gets padding-right so the
