  /* Depth fold: methodology + attribution behind a tap. Summary mirrors the
     sources affordance (muted, sans). Triangle marker is the native one. */
  .study-depth { margin-top: 0.5rem; }
  .study-depth > summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
