  .study-details li { margin: 0.25rem 0; }
  .study-subdetails {
    margin: 0.2rem 0 0.4rem;
    padding-left: 1.1rem;
    list-style: none;
  }
  .study-subdetails li {
    margin: 0.15rem 0;
    font-size: 0.92rem;
    color: var(--fg);
