    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .caption-table-wrap {
    margin-top: 0.4rem;
  }
  .caption-table-wrap .study-table {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
  }
  /* Caption tables live in the narrow figure column; let cells wrap so wide
     results/AE tables fit the column instead of being clipped on the right. */
  .caption-table-wrap .study-table th,
  .caption-table-wrap .study-table td {
    white-space: normal;
    padding: 0.4rem 0.55rem;
  }

  /* Per-study open questions: a divider inside the depth fold. */
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }
  .open-questions {
    margin-top: 1.5rem;
    padding: 0.85rem 1.1rem;
    background: var(--citation-bg);
    border-radius: 4px;
  }
  .open-questions ul { margin: 0; padding-left: 1.2rem; line-height: 1.55; }
  .open-questions li { margin: 0.25rem 0; }
  .study-open-questions {
    margin-top: 1rem;
    padding: 0.6rem 0 0;
    background: transparent;
    border-top: 1px solid var(--border);
    border-radius: 0;
  }
  .study-open-questions .section-label { color: var(--fg-muted); }

  @media (max-width: 600px) {
    .study { padding: 0.85rem 1rem; }
  }

  /* Verdict colors in dark mode: lighter values, legible on the dark card. */
  @media (prefers-color-scheme: dark) {
    .verdict-block.verdict-practice-changing { --verdict-color: #5fcc8a; }
    .verdict-block.verdict-challenges-soc { --verdict-color: #d99a4a; }
    .verdict-block.verdict-early-signal { --verdict-color: #6fbfd6; }
    .verdict-block.verdict-methodologically-limited { --verdict-color: #d9785a; }
  }

  /* Share affordance anchored to the top-right of .study-head. On wide
     figures-present cards (grid: head | figs at >=1200px) the head is the
     LEFT column, so the button stays in the narrative column instead of
     overlaying the figures column. .study-head gets padding-right so the
     trial name + audience + TL;DR + verdict + comparator never run under
     the absolutely-positioned button. Starts display:none; share-script.ts
     reveals it after confirming Web Share or Clipboard API. .is-flipped is
     added during the Copied/Couldn't copy window for an accent flash. */
  .study-share {
    display: none;
    position: absolute;
    top: 0;
    right: 0;
    background: none;
    border: none;
    padding: 0.5rem 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--fg-muted);
    cursor: pointer;
    line-height: 1.2;
    /* 44px minimum touch target via padding (no chip background). */
    min-height: 44px;
  }
  .study-share:hover { color: var(--accent); }
  .study-share.is-flipped { color: var(--accent); }

  /* Screen-reader-only live region for state announcements. Visible label
     change is the sighted user's signal; this announces the same text to
     screen readers because mutating button textContent doesn't fire reliably
     across NVDA / JAWS / VoiceOver. */
  .sr-share-status {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Inline URL recovery: revealed when clipboard.writeText() rejects (rare —
     incognito, denied permission, etc.). User can Cmd+A / Cmd+C the
     pre-selected text. Auto-hides after 10s. Positioned absolutely below
     the share button so it sits in the utility row's reserved space without
     pushing other content. */
  .share-recovery {
    display: none;
    position: absolute;
    top: calc(44px + 0.3rem);
    right: 0;
    z-index: 2;
    padding: 0.3rem 0.4rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    color: var(--fg);
    background: var(--bg-card);
    border: 1px solid var(--accent);
    border-radius: 3px;
    width: 18rem;
    max-width: 100%;
  }
</style>
<script>
  // Wire the share buttons on this page. Astro hoists + dedupes identical
  // inline scripts, so this runs once per page regardless of how many
  // StudyCards (or home-feed share buttons) render.
  import { initShareButtons } from '../lib/share-script.ts';
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareButtons);
  } else {
    initShareButtons();
  }
</script>
