---
// Single source of truth for the dense per-study card. Rendered by both the
// per-date digest (`[date].astro`) and the by-site aggregation
// (`sites/[site].astro`). Presentation-only: callers resolve a study's sources
// to concrete bookmark/paper/slide arrays and pass them in.
//
// Triage-first layout (v0.9): the card rests at its triage layer — name,
// verdict pill, TL;DR, and the "vs leading data" callout — so a busy reader
// scans verdicts + headline numbers down the page. The methodology depth
// (audience, figure, detail bullets/tables, open questions, attribution) folds
// behind a native <details> expander. Sources stay in their own collapsible.
import { linkifyCitations } from '../lib/extract.ts';
import { isSafeImageUrl } from '../lib/vision-ocr.ts';
import { VERDICT_META, REVIEW_GLYPH } from '../lib/verdict.ts';
import { tradePressLabel } from '../lib/paper-url.ts';
import {
  studyFigures,
  stripStudyNamePrefix,
  type DigestStudy,
  type DigestDetail,
  type DigestArtifact,
  type DigestArtifactPaper,
  type DigestArtifactSlide,
} from '../lib/digest-data.ts';
import {
  groupTrialsByQuestion,
  watchingTrialsBadge,
  statusPillText,
  statusAriaLabel,
  formatPhaseChip,
  formatTrialSubline,
  hasTrialSubline,
} from '../lib/related-trials-render.ts';
import type { SiblingPreview, TrialAppearance } from '../lib/tag-index.ts';

type Bookmark = DigestArtifact['bookmarks'][number];
type StudyAuthor = { name: string; kind: 'tweet' | 'paper' };

interface Props {
  study: DigestStudy;
  // Resolved sources (the caller dereferences source_ids/tweet_ids).
  bookmarks?: Bookmark[];
  papers?: DigestArtifactPaper[];
  slides?: DigestArtifactSlide[];
  // Optional anchor id on the card root (per-date page uses it for deep links).
  anchorId?: string;
  // Optional "Sourced from …" attribution line (per-date page only).
  authors?: StudyAuthor[];
  // Optional canonical share URL (standalone per-study page: /study/{date}-{slug}/).
  // A real page (not a #fragment) so a shared link unfurls with the study's own
  // og:title + og:image. Absent → share button is not rendered. Absolutized at
  // click time in share-script.ts.
  shareUrl?: string;
  // v0.10: pre-resolved cross-cutting tag chips. Caller passes via
  // studyTagChips() so the label resolution happens where conference
  // context lives (meeting labels need digest.conference.name, which the
  // card doesn't have). Adversarial review caught that calling
  // resolveTagDisplay() with no occurrences silently dropped every meeting
  // chip. Rendered as a plain text meta-line below the comparator on the
  // card head; each chip links to /tags/<slug>/. Absent / empty → no row.
  tagChips?: Array<{ slug: string; label: string }>;
  // v0.10: "Studies like this" sibling footer entries (up to 3, date-desc).
  // Caller looks up via buildSiblingPreviews() and passes the per-study list.
  // Rendered inside the depth fold, after authors attribution. Defensive
  // .slice(0, 3) on render in case a caller passes more. Absent / empty →
  // no section.
  siblings?: SiblingPreview[];
  // v0.28: same-trial cross-day history. Caller looks up via buildTrialHistory()
  // keyed on studyKeyString({date, resolvedSlug}) and passes the per-card list.
  // Rendered as a thin "Also covered · <date> · <date>" wayfinding line in the
  // card head (identity, not the "Studies like this" similarity footer). Absent
  // / empty → no line.
  trialHistory?: TrialAppearance[];
  // v0.11 PR-1a: space-separated `namespace:slug` token string for the
  // future filter rail (PR-2). Caller derives via studyDataTags() so the
  // disease-site + conference context lives where it's known. Absent →
  // no attribute emitted (filter rail treats the card as uncategorized).
  dataTags?: string;
}

const {
  study,
  bookmarks = [],
  papers = [],
  slides = [],
  anchorId,
  authors = [],
  shareUrl,
  tagChips = [],
  siblings = [],
  trialHistory = [],
  dataTags,
} = Astro.props as Props;

// Short, timezone-safe label from a YYYY-MM-DD string. Parsing as a Date would
// shift a day under UTC; a manual split avoids that. "2026-05-17" → "May 17".
const MONTHS_SHORT = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
function shortDate(iso: string, withYear = false): string {
  const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(iso);
  if (!m) return iso;
  const label = `${MONTHS_SHORT[Number(m[2]) - 1] ?? '?'} ${Number(m[3])}`;
  return withYear ? `${label} '${m[1]!.slice(2)}` : label;
}
const visibleHistory = trialHistory.slice(0, 4);
const hasHistory = visibleHistory.length > 0;

// Defensive cap on siblings: computeSiblings already caps at 3, but a future
// caller passing a longer list shouldn't render an unbounded footer.
const visibleSiblings = siblings.slice(0, 3);
const hasTagChips = tagChips.length > 0;
const hasSiblings = visibleSiblings.length > 0;

// 🔗 bullets are lifted out of the main list into the "vs leading data" callout.
function isComparatorBullet(d: DigestDetail): boolean {
  const text = typeof d === 'string' ? d : (d as { text: string }).text;
  return /^\s*🔗/.test(text);
}
function stripComparatorEmoji(text: string): string {
  return text.replace(/^\s*🔗\s*/, '');
}
// Render an href only for an http(s) URL — defense-in-depth against a
// javascript:/data: scheme reaching an anchor. Shared by the v0.15.3 article
// link and the v0.16 provenance link so the two guards can't drift.
function isHttpUrl(u: string | null | undefined): u is string {
  return typeof u === 'string' && /^https?:\/\//i.test(u);
}
// "data/slide-photos/<date>/<uuid>.jpg" → "/slides/<date>/<uuid>.jpg"
function toSlideUrl(filePath: string): string {
  return filePath.startsWith('data/slide-photos/')
    ? '/slides/' + filePath.slice('data/slide-photos/'.length)
    : filePath;
}
// v0.30: emphasize the numbers that carry the result. Runs AFTER linkifyCitations,
// so it operates only on text between tags (never inside an <a href>) and does NOT
// re-escape (the text is already escaped). The first effect-size token (HR/OR/RR or
// a "% vs %") is the one driving the headline → .stat-key; other stats → .stat.
// The p-value pattern also matches the escaped `p&lt;`/`p&gt;` forms.
function emphasizeStats(html: string): string {
  if (!html) return html;
  let keyed = false;
  const TOK = /\b(?:a?HR|OR|RR|IRR)\s*[=:]?\s*\d+\.\d+(?:\s*\((?:95%\s*CI[:\s]*)?[\d.]+\s*[–-]\s*[\d.]+\))?|\b\d{1,3}(?:\.\d)?%(?:\s*vs\.?\s*\d{1,3}(?:\.\d)?%)?|\bp\s*(?:[=<>]|&lt;|&gt;)\s*0?\.\d+|\b\d+(?:\.\d)?\s*(?:mo|months|yr|years|wks|weeks)\b/gi;
  return html.replace(/<[^>]+>|[^<]+/g, (seg) => {
    if (seg.charAt(0) === '<') return seg;
    return seg.replace(TOK, (tok) => {
      const isEffect = /^(?:a?HR|OR|RR|IRR)/i.test(tok) || tok.indexOf('%') !== -1;
      const cls = isEffect && !keyed ? ((keyed = true), 'stat stat-key') : 'stat';
      return `<span class="${cls}">${tok}</span>`;
    });
  });
}
// v0.30: convert a small, safe subset of inline markdown (**bold**) AFTER
// linkifyCitations (so text is already escaped and <a> citations are whole HTML
// islands we skip) and BEFORE emphasizeStats. Restores the mockup's bolded key
// terms in the structured fold without breaking citations or double-escaping.
function applySafeBold(html: string): string {
  return html
    .split(/(<a\b[^>]*>[\s\S]*?<\/a>|<[^>]+>)/gi)
    .map((seg) => (!seg || seg.charAt(0) === '<' ? seg : seg.replace(/\*\*([^*\n][\s\S]*?[^*\n]|\S)\*\*/g, '<b>$1</b>')))
    .join('');
}
// The full inline pipeline for structured-fold prose: link citations → bold key
// terms → emphasize stat numbers.
function renderBrief(text: string): string {
  return emphasizeStats(applySafeBold(linkifyCitations(text)));
}
// v0.30: split an "Applies to" body ("Represents X. Does not represent Y.") into
// the ✓ represents / ✕ excludes pair (mockup). Null when it doesn't match → prose.
function splitApplies(body: string): { yes: string; no: string } | null {
  const m = body.match(/^(.*?)(\bdoes\s+not\b[\s\S]*)$/i);
  if (!m) return null;
  const yes = m[1].replace(/^\s*represents\s*/i, '').replace(/[.;,\s]+$/, '').trim();
  const no = m[2].trim();
  return yes && no ? { yes, no } : null;
}
// v0.30: short label for the endpoint-class chip in the endpoint-forward head.
function endpointClassLabel(k: string): string {
  if (k === 'overall-survival') return 'hard';
  if (k === 'local-control') return 'local control';
  if (k === 'safety') return 'safety';
  return 'surrogate';
}

const comparatorBullets = study.details.filter(isComparatorBullet);
const otherBullets = study.details.filter((d) => !isComparatorBullet(d));
const verdictMeta = study.verdict ? VERDICT_META[study.verdict.soc_implication] : null;

// v0.22: perspective-framed "Why it matters" prose — an always-visible callout
// under the verdict. The heading is "Why it matters", suffixed with the active
// lens label ("· Radiation oncology") when the build stamped one. Both fields
// are absent on the pre-v0.22 corpus and when Phase 2 abstained, so the block
// simply doesn't render.
const significanceText =
  typeof study.significance === 'string' && study.significance.trim()
    ? study.significance.trim()
    : null;
const significanceLabel =
  typeof study.significance_perspective === 'string' && study.significance_perspective.trim()
    ? study.significance_perspective.trim()
    : null;

// v0.26 (E3): the Monday-clinic decision line. Design decision Y: significance
// holds the resting long-form slot and the clinic line folds into the depth; but
// when there is NO significance, PROMOTE the clinic line into the resting slot so
// the card keeps one long-form surface. The clinic line folds (below) only when
// significance already occupies the resting slot, so it never renders twice.
const mondayClinicText =
  typeof study.monday_clinic === 'string' && study.monday_clinic.trim()
    ? study.monday_clinic.trim()
    : null;
const restingProse: { text: string; label: string; sublabel: string | null } | null = significanceText
  ? { text: significanceText, label: 'Why it matters', sublabel: significanceLabel }
  : mondayClinicText
    ? { text: mondayClinicText, label: 'Monday clinic', sublabel: null }
    : null;
// v0.32: per-specialty "why it matters" variants. The default significance-block
// (restingProse) stays the primary/fallback; when the reader picks their specialty
// in the header bar, the client hides the default and reveals the matching variant.
// Only render variants when a real significance holds the resting slot (not the
// promoted Monday-clinic line) and the map carries specialty-keyed entries.
const SPECIALTY_LABELS: Record<string, string> = {
  radonc: 'Radiation oncology',
  medonc: 'Medical oncology',
  surgonc: 'Surgical oncology',
};
const significanceVariants: Array<{ specialty: string; label: string; text: string }> =
  significanceText && study.significance_by_specialty
    ? Object.entries(study.significance_by_specialty)
        .filter(([spec, text]) => SPECIALTY_LABELS[spec] && typeof text === 'string' && !!text.trim())
        .map(([spec, text]) => ({ specialty: spec, label: SPECIALTY_LABELS[spec]!, text: (text as string).trim() }))
    : [];
// v0.31: the verdict Rationale, the Monday-clinic decision, and a Limitations
// section can echo each other. When the Monday-clinic line substantially restates
// the verdict rationale it adds nothing beside it in the fold, so drop it (the
// rationale stays as the verdict's basis). Conservative word-overlap gate so a
// genuinely distinct decision line is never hidden.
function sigWordSet(s: string): Set<string> {
  return new Set(
    s.toLowerCase().replace(/[^a-z0-9\s]/g, ' ').split(/\s+/).filter((w) => w.length > 3),
  );
}
function contentOverlap(a: string, b: string): number {
  const sa = sigWordSet(a);
  const sb = sigWordSet(b);
  if (sa.size === 0 || sb.size === 0) return 0;
  let inter = 0;
  for (const w of sa) if (sb.has(w)) inter++;
  return inter / Math.min(sa.size, sb.size);
}
const rationaleText = typeof study.verdict?.rationale === 'string' ? study.verdict.rationale : '';
const foldedClinic =
  significanceText && mondayClinicText && contentOverlap(mondayClinicText, rationaleText) < 0.6
    ? mondayClinicText
    : null;

// v0.27: the curator's own note on this study — the human editor's voice, set
// durably via the override CLI (never LLM-generated). Rendered as its own
// margin-note callout, visually distinct from the blue AI "why it matters"
// block. Absent/null when the curator hasn't annotated the study.
const curatorNoteText =
  typeof study.curator_note === 'string' && study.curator_note.trim()
    ? study.curator_note.trim()
    : null;

// v0.26 (E1): the text-ready share body — the decision content a colleague sees
// when the card is forwarded, not a bare title+URL. Name-led headline (the TL;DR,
// verbatim) + verdict + the Monday-clinic line when present. The deep link rides
// the Web Share `url` field (data-share-url), so it isn't duplicated here.
const shareHeadline = (study.tldr ?? '').trim();
const shareText = [
  shareHeadline && shareHeadline.toLowerCase().startsWith(study.name.toLowerCase())
    ? shareHeadline
    : [study.name, shareHeadline].filter(Boolean).join(': '),
  verdictMeta ? `${verdictMeta.emoji} ${verdictMeta.label}` : null,
  mondayClinicText,
].filter((l): l is string => Boolean(l && l.trim())).join('\n');

// IMRD-style section bucketing for the depth fold. The leading emoji on each
// bullet already encodes the section (VOICE.md): 🔍/💊 are Methods, 📊/📐 are
// Results, ⚠️ is Critique. Bullets without a recognized emoji prefix fall to
// Notes so nothing is silently dropped.
type DepthSection = 'methods' | 'results' | 'critique' | 'notes';
function bucketBullet(d: DigestDetail): DepthSection {
  const text = typeof d === 'string' ? d : (d as { text: string }).text;
  // ⚠️ ships with or without the U+FE0F variation selector depending on
  // source/keyboard; match both forms.
  const m = text.match(/^\s*(🔍|💊|📊|📐|⚠️|⚠)/u);
  if (!m) return 'notes';
  const e = m[1];
  if (e === '🔍' || e === '💊') return 'methods';
  if (e === '📊' || e === '📐') return 'results';
  return 'critique';
}
const methodsBullets = otherBullets.filter((d) => bucketBullet(d) === 'methods');
const resultsBullets = otherBullets.filter((d) => bucketBullet(d) === 'results');
const critiqueBullets = otherBullets.filter((d) => bucketBullet(d) === 'critique');
const notesBullets = otherBullets.filter((d) => bucketBullet(d) === 'notes');
const hasConsort = Boolean(study.consort && study.consort.arms.length >= 2);
const depthSections: Array<{ label: string; bullets: DigestDetail[]; consort: boolean }> = [];
if (methodsBullets.length > 0 || hasConsort) depthSections.push({ label: 'Methods', bullets: methodsBullets, consort: hasConsort });
if (resultsBullets.length > 0) depthSections.push({ label: 'Results', bullets: resultsBullets, consort: false });
if (critiqueBullets.length > 0) depthSections.push({ label: 'Critique', bullets: critiqueBullets, consort: false });
if (notesBullets.length > 0) depthSections.push({ label: 'Notes', bullets: notesBullets, consort: false });

// v0.30: structured fold sections (Design / Population / Regimen / …). When the
// Phase-2 agent emits these, the fold renders them as the mockup's labeled prose
// "spec sheet" INSTEAD of the emoji-IMRD buckets; absent → the buckets.
const analysisSections = Array.isArray(study.analysis_sections)
  ? study.analysis_sections.filter(
      (s): s is { label: string; body: string } =>
        Boolean(s && typeof s.label === 'string' && s.label.trim() && typeof s.body === 'string' && s.body.trim()),
    )
  : [];
const hasAnalysisSections = analysisSections.length > 0;
// Detail tables (arm-vs-arm data) survive even when analysis_sections replaces the
// prose fold — the prose can't carry a grounded 2D table, so render them alongside.
const tableDetails = study.details.filter(
  (d): d is { text: string; table: { columns: string[]; rows: string[][] } } =>
    typeof d === 'object' && d !== null && 'table' in d,
);

// v0.10: figure gallery (KM curve, forest plot, results/AE table…). Normalizes
// the v0.4 single-figure shape; re-applies the host allowlist at render time as
// defense-in-depth (build already validated). First figure is the visual anchor;
// the rest fold behind a tap on mobile (auto-expanded on desktop via Base.astro).
const figures = studyFigures(study).filter((f) => isSafeImageUrl(f.url));
const hasFigures = figures.length > 0;
const restFigures = figures.slice(1);

const hasOpenQuestions = Boolean(
  study.open_questions && study.open_questions.length > 0,
);
// Audience ("For …") is lifted to the triage layer (just under the name), so it
// is no longer part of the folded depth.
const hasAudience = Boolean(study.verdict?.audience);
// Folded "depth" layer: everything past the triage essentials. Figures live in
// their own column; audience is now in the head; CONSORT folds into Methods.
const hasDepth =
  hasAnalysisSections ||
  otherBullets.length > 0 ||
  hasOpenQuestions ||
  authors.length > 0 ||
  hasConsort;
const depthSummary = otherBullets.length > 0
  ? `${otherBullets.length} ${otherBullets.length === 1 ? 'detail' : 'details'}`
  : 'Details';

// v0.13: trials-to-watch grouping. Pre-compute the per-question lookup map
// so the open-questions <ul> can find watchers for each <li> in O(1). The
// badge text is null when this study has zero related_trials so the
// <summary> just renders the existing depthSummary.
const trialsByQuestion = groupTrialsByQuestion(study.related_trials);
const trialsBadgeText = watchingTrialsBadge(study.related_trials);

const sourceTotal = bookmarks.length + papers.length + slides.length;
const sourceBadges: string[] = [];
if (bookmarks.length > 0) sourceBadges.push(`🐦 ${bookmarks.length} tweet${bookmarks.length === 1 ? '' : 's'}`);
if (papers.length > 0) sourceBadges.push(`📄 ${papers.length} paper${papers.length === 1 ? '' : 's'}`);
if (slides.length > 0) sourceBadges.push(`🩻 ${slides.length} slide${slides.length === 1 ? '' : 's'}`);

// v0.16 trade-press provenance (Codex #5): a "Reported via {outlet}" line
// renders ONLY when this study's sources are trade-press-ONLY — a single outlet,
// no tweets/slides/primary papers. On a mixed cluster (trade + primary paper +
// slides) naming one outlet would misattribute, so it's suppressed there.
// tradePressLabel() returns the authoritative outlet name from the URL host
// (null for non-trade), which doubles as the is-trade-press test.
const tradePressPapers = papers
  .map((p) => ({ p, label: p.source_url ? tradePressLabel(p.source_url) : null }))
  .filter((x): x is { p: DigestArtifactPaper; label: string } => x.label !== null);
const tradeOutlets = new Set(tradePressPapers.map((x) => x.label));
const isTradePressOnly =
  bookmarks.length === 0 &&
  slides.length === 0 &&
  papers.length > 0 &&
  tradePressPapers.length === papers.length &&
  tradeOutlets.size === 1;
const provenanceOutlet = isTradePressOnly ? tradePressPapers[0]!.label : null;
const provenanceUrlRaw = provenanceOutlet ? tradePressPapers[0]!.p.source_url : null;
// Same http(s)-only href guard the Sources block applies to source_url (isHttpUrl).
const provenanceUrl = isHttpUrl(provenanceUrlRaw) ? provenanceUrlRaw : null;

// v0.16 review extras: a content_type:review carries no verdict (stripped at
// build) and surfaces a plain-text "Trials discussed" acronym list instead.
const isReview = study.content_type === 'review';
// Array.isArray guard (not just ??): a hand-edited / corrupted artifact with a
// non-array discussed_trials would otherwise crash .map at build.
const discussedTrials =
  isReview && Array.isArray(study.discussed_trials) ? study.discussed_trials : [];
const hasDiscussedTrials = discussedTrials.length > 0;
// v0.17 (T6): a discussed-trial acronym → resolved same-date study slug, for
// deep-linking the "Trials discussed" list to the auto-resolved card. Keyed by
// the normalized (upper, whitespace-collapsed) acronym, matching db.normalizeAcronym.
const discussedTrialLinks = isReview && study.discussed_trial_links ? study.discussed_trial_links : {};
const normTrial = (t: string) => t.trim().replace(/\s+/g, ' ').toUpperCase();

// v0.17 (T6): true when any source paper was auto-resolved from a review's
// discussed trials (curator-approved). Drives the provenance pill that tells a
// reader this study card appeared because a review named the trial.
const isReviewResolved = papers.some((p) => p.resolved_from_review === true);
---

<div class:list={['study', hasFigures && 'has-figures', study.verdict?.soc_implication && `verdict-${study.verdict.soc_implication}`]} id={anchorId} data-tags={dataTags || undefined} data-specialties={study.relevant_specialties && study.relevant_specialties.length > 0 ? study.relevant_specialties.join(' ') : undefined}>
  <div class="study-head">
  {/* ── Triage layer: always visible. v0.30: name + a compact verdict CHIP on
      one row (the mockup glance top); the verdict rationale moves into the fold
      so the head reads clean instead of a stacked pill + paragraph. ── */}
  <div class="glance">
  <div class="glance-top">
    {verdictMeta && study.verdict && (
      <span class:list={['verdict-chip', `verdict-${study.verdict.soc_implication}`]}>
        <span class="verdict-emoji" aria-hidden="true">{verdictMeta.emoji}</span>{verdictMeta.label}
      </span>
    )}
    <h4 class="study-name">
      {study.name}
      {study.nct && (
        <a class="citation study-nct" href={`https://clinicaltrials.gov/study/${study.nct}`} target="_blank" rel="noopener">{study.nct}</a>
      )}
    </h4>
  </div>
  {study.is_preprint && (
    <p class="preprint-badge" role="note" title="Preprint server (medRxiv / bioRxiv / Research Square). Findings are not yet peer-reviewed; the verdict is capped at early-signal.">
      <span class="preprint-badge-tag">PREPRINT</span><span class="preprint-badge-text">not peer-reviewed</span>
    </p>
  )}
  {hasAudience && (
    <p class="study-audience study-audience-head"><span class="audience-label">For</span>{study.verdict!.audience}</p>
  )}
  {study.primary_endpoint && study.primary_endpoint.name && study.primary_endpoint.stat_value && (
    <div class="study-endpoint">
      <div class="endpoint-head">
        <span class="endpoint-name">{study.primary_endpoint.name}</span>
        {/* The class chip flags a CAVEAT — a surrogate/proxy, local control, or a
            safety endpoint. Overall survival is the definitive endpoint and the
            name already says it, so no chip (a bare "hard" beside "Overall
            survival" read as cryptic). */}
        {study.primary_endpoint.klass !== 'overall-survival' && (
          <span class:list={['endpoint-class', `ec-${study.primary_endpoint.klass}`]}>{endpointClassLabel(study.primary_endpoint.klass)}</span>
        )}
      </div>
      <p class="endpoint-stat" set:html={emphasizeStats(linkifyCitations(study.primary_endpoint.stat_value))} />
      {study.primary_endpoint.stat_detail && (
        <p class="endpoint-sub" set:html={linkifyCitations(study.primary_endpoint.stat_detail)} />
      )}
    </div>
  )}
  <p class:list={['study-tldr', study.primary_endpoint?.stat_value && 'study-tldr--plain']}><span class="tldr-label">TL;DR</span><span set:html={emphasizeStats(linkifyCitations(stripStudyNamePrefix(study.tldr, study.name)))} /></p>
  </div>{/* /.glance */}
  {provenanceOutlet && (
    <p class="study-provenance">
      <span class="provenance-icon" aria-hidden="true">{REVIEW_GLYPH}</span>
      <span class="provenance-text">Reported via{' '}
        {provenanceUrl
          ? <a class="provenance-link" href={provenanceUrl} target="_blank" rel="noopener">{provenanceOutlet} →</a>
          : <span class="provenance-outlet">{provenanceOutlet}</span>}
      </span>
    </p>
  )}
  {isReviewResolved && (
    <p class="study-resolved-from">
      <span class="resolved-icon" aria-hidden="true">↘</span>
      <span>Surfaced from a review's discussed trials</span>
    </p>
  )}
  {hasDiscussedTrials && (
    <section class="discussed-trials" aria-label="Trials discussed in this review">
      <div class="discussed-trials-label">Trials discussed</div>
      <p class="discussed-trials-list">
        {discussedTrials.map((t, i) => (
          <Fragment>
            {i > 0 && <span class="dt-sep" aria-hidden="true">·</span>}
            {discussedTrialLinks[normTrial(t)]
              ? <a class="dt-name dt-link" href={`#${discussedTrialLinks[normTrial(t)]}`}>{t}</a>
              : <span class="dt-name">{t}</span>}
          </Fragment>
        ))}
      </p>
    </section>
  )}
  {restingProse && (
    <section
      class="significance-block"
      aria-label="Why this study matters"
      data-sig-default={significanceVariants.length > 0 ? '' : undefined}
    >
      <div class="significance-label">
        {restingProse.label}{restingProse.sublabel && (
          <Fragment><span class="significance-sep" aria-hidden="true"> · </span>{restingProse.sublabel}</Fragment>
        )}
      </div>
      <p class="significance-text" set:html={linkifyCitations(restingProse.text)} />
    </section>
  )}
  {/* v0.32: hidden per-specialty variants; the SpecialtyBar reveals the one the
      reader picks and hides the default. Server-rendered so each keeps citation
      links + styling for free. */}
  {significanceVariants.map((v) => (
    <section
      class="significance-block significance-variant"
      aria-label={`Why this study matters for ${v.label.toLowerCase()}`}
      data-sig-for={v.specialty}
      hidden
    >
      <div class="significance-label">
        Why it matters<span class="significance-sep" aria-hidden="true"> · </span>{v.label}
      </div>
      <p class="significance-text" set:html={linkifyCitations(v.text)} />
    </section>
  ))}
  {curatorNoteText && (
    <section class="curator-note-block" aria-label="Curator's note">
      <div class="curator-note-label">📝 Curator's note</div>
      <p class="curator-note-text" set:html={linkifyCitations(curatorNoteText)} />
    </section>
  )}
  {comparatorBullets.length > 0 && !hasAnalysisSections && (
    <section class="comparator-block">
      <div class="comparator-label">vs leading data</div>
      <ul class="comparator-list">
        {comparatorBullets.map((d) => (
          typeof d === 'string'
            ? <li set:html={linkifyCitations(stripComparatorEmoji(d))} />
            : <li set:html={linkifyCitations(stripComparatorEmoji(d.text))} />
        ))}
      </ul>
    </section>
  )}
  {/* ── v0.10 tag chip row: plain text meta-line, dot separated. Each chip
      links to /tags/<slug>/. No border, no fill, no uppercase. Wraps to
      multiple lines on narrow viewports rather than overflowing. Subtraction
      first per DESIGN.md "cards earn their existence." ── */}
  {/* ── v0.28 cross-day trial history: thin "Also covered" wayfinding line.
      IDENTITY (same trial on other dates), not the "Studies like this"
      similarity footer. Each date links to that day's card. Absent → no line. ── */}
  {hasHistory && (
    <p class="study-history" aria-label="This trial covered on other dates">
      <span class="study-history__label">Also covered</span>
      {visibleHistory.map((h) => (
        <Fragment>
          <span class="tag-sep" aria-hidden="true">·</span>
          <a
            class="study-history__link"
            href={`/${h.date}/#${h.resolvedSlug}`}
            aria-label={`${h.name} — also covered ${shortDate(h.date, true)}`}
          >{shortDate(h.date, h.crossYear)}</a>
        </Fragment>
      ))}
    </p>
  )}
  {/* ── Share affordance: top-right of the head. Anchored to .study-head (not
      to .study) so on wide-desktop figures-present cards it stays in the left
      narrative column instead of overlaying the figures column. Hidden via
      CSS display:none until share-script.ts confirms an API works. ── */}
  {shareUrl && (
    <Fragment>
      <button
        type="button"
        class="study-share"
        data-share-url={shareUrl}
        data-share-title={study.name}
        data-share-text={shareText}
        aria-label={`Share ${study.name}`}
        title="Share"
      ><svg class="share-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg></button>
      <span class="sr-share-status" aria-live="polite"></span>
      <input
        type="text"
        class="share-recovery"
        readonly
        tabindex={-1}
        aria-label="Copy this URL manually"
      />
    </Fragment>
  )}
  </div>{/* /.study-head */}

  {/* ── Figures: right column on desktop; first shown + rest folded on mobile ── */}
  {hasFigures && (
    <div class="study-figures">
      <figure class="study-figure">
        <img class="study-zoom" src={figures[0]!.url} alt={typeof figures[0]!.caption === 'string' ? figures[0]!.caption : study.name} loading="lazy" onerror="this.style.display='none'" />
        {typeof figures[0]!.caption === 'string' && figures[0]!.caption && (
          <figcaption>{figures[0]!.caption}</figcaption>
        )}
        {figures[0]!.caption && typeof figures[0]!.caption !== 'string' && (
          <figcaption>
            <div class="study-table-wrap caption-table-wrap">
              <table class="study-table">
                <thead>
                  <tr>{figures[0]!.caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}</tr>
                </thead>
                <tbody>
                  {figures[0]!.caption.rows.map((row) => (
                    <tr>{row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </figcaption>
        )}
      </figure>
      {restFigures.length > 0 && (
        <details class="more-figures">
          <summary>+{restFigures.length} more figure{restFigures.length === 1 ? '' : 's'}</summary>
          <div class="more-figures-stack">
            {restFigures.map((fig) => (
              <figure class="study-figure">
                <img class="study-zoom" src={fig.url} alt={typeof fig.caption === 'string' ? fig.caption : study.name} loading="lazy" onerror="this.style.display='none'" />
                {typeof fig.caption === 'string' && fig.caption && (
                  <figcaption>{fig.caption}</figcaption>
                )}
                {fig.caption && typeof fig.caption !== 'string' && (
                  <figcaption>
                    <div class="study-table-wrap caption-table-wrap">
                      <table class="study-table">
                        <thead>
                          <tr>{fig.caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}</tr>
                        </thead>
                        <tbody>
                          {fig.caption.rows.map((row) => (
                            <tr>{row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}</tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        </details>
      )}
    </div>
  )}

  <div class="study-rest">
  {/* ── Depth layer: folded behind a tap. Bullets flow IMRD-style (Methods →
      Results → Critique → Notes), with CONSORT nested inside Methods. ── */}
  {hasDepth && (
    <details class="study-depth">
      <summary>
        <span class="depth-summary-count">{depthSummary}</span>
        {trialsBadgeText && (
          <Fragment>
            <span class="trials-badge-sep" aria-hidden="true"> · </span>
            <span class="trials-watching-badge">{trialsBadgeText}</span>
          </Fragment>
        )}
      </summary>
      {hasAnalysisSections && analysisSections.map((sec) => {
        const isResults = /result/i.test(sec.label);
        const applies = /^applies/i.test(sec.label) ? splitApplies(sec.body) : null;
        return (
          <section class="depth-section">
            <div class="section-label">{sec.label}</div>
            <div class="depth-section-body">
              {applies ? (
                <Fragment>
                  <div class="rep yes"><span class="mark" aria-hidden="true">✓</span><span set:html={renderBrief(applies.yes)} /></div>
                  <div class="rep no"><span class="mark" aria-hidden="true">✕</span><span set:html={renderBrief(applies.no)} /></div>
                </Fragment>
              ) : (
                <p class="depth-prose" set:html={renderBrief(sec.body)} />
              )}
              {isResults && tableDetails.map((d) => (
                <div class="study-table-wrap">
                  <table class="study-table">
                    <thead><tr>{d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}</tr></thead>
                    <tbody>{d.table.rows.map((row) => (<tr>{row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}</tr>))}</tbody>
                  </table>
                </div>
              ))}
            </div>
          </section>
        );
      })}
      {hasAnalysisSections && tableDetails.length > 0 && !analysisSections.some((s) => /result/i.test(s.label)) && (
        <section class="depth-section">
          <div class="section-label">Results</div>
          <div class="depth-section-body">
            {tableDetails.map((d) => (
              <div class="study-table-wrap">
                <table class="study-table">
                  <thead><tr>{d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}</tr></thead>
                  <tbody>{d.table.rows.map((row) => (<tr>{row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}</tr>))}</tbody>
                </table>
              </div>
            ))}
          </div>
        </section>
      )}
      {!hasAnalysisSections && depthSections.map((sec) => (
        <section class="depth-section">
          <div class="section-label">{sec.label}</div>
          <div class="depth-section-body">
          {sec.bullets.length > 0 && (
            <ul class="study-details">
              {sec.bullets.map((d) => {
                if (typeof d === 'string') {
                  return <li set:html={linkifyCitations(d)} />;
                }
                // v0.26 (Thread 1): a figure-sourced bullet earns a citation
                // mark. Named for what value-membership PROVES ("read from a
                // figure"), never "verified". Non-emoji per DESIGN.md's reserved
                // vocabulary, like the text-neutral NEW pill.
                const isFig = 'source_tier' in d && d.source_tier === 'figure';
                if ('table' in d) {
                  return (
                    <li>
                      <span set:html={linkifyCitations(d.text)} />{isFig && <sup class="src-fig" title="Read from a figure, not the abstract">†</sup>}
                      <div class="study-table-wrap">
                        <table class="study-table">
                          <thead>
                            <tr>
                              {d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                            </tr>
                          </thead>
                          <tbody>
                            {d.table.rows.map((row) => (
                              <tr>
                                {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </li>
                  );
                }
                if ('subdetails' in d) {
                  return (
                    <li>
                      <span set:html={linkifyCitations(d.text)} />{isFig && <sup class="src-fig" title="Read from a figure, not the abstract">†</sup>}
                      {d.subdetails.length > 0 && (
                        <ul class="study-subdetails">
                          {d.subdetails.map((s) => (<li set:html={linkifyCitations(s)} />))}
                        </ul>
                      )}
                    </li>
                  );
                }
                // v0.26: plain { text, source_tier? } — the explicit subdetails
                // guard above already makes this crash-safe (supersedes main's
                // defensive-hotfix variant), while keeping the figure-sourced †.
                return (
                  <li>
                    <span set:html={linkifyCitations(d.text)} />{isFig && <sup class="src-fig" title="Read from a figure, not the abstract">†</sup>}
                  </li>
                );
              })}
            </ul>
          )}
          {sec.consort && study.consort && (
            <details class="consort">
              <summary>CONSORT flow</summary>
              <div class="consort-flow">
                {study.consort.enrolled != null && (
                  <>
                    <div class="consort-node">Assessed / enrolled <b>{study.consort.enrolled}</b></div>
                    <div class="consort-arrow">
                      {study.consort.excluded != null ? `↓  ${study.consort.excluded} excluded` : '↓'}
                    </div>
                  </>
                )}
                <div class="consort-node consort-rand">Randomized <b>{study.consort.randomized}</b></div>
                <div class="consort-arrow">↓</div>
                <div class="consort-arms">
                  {study.consort.arms.map((a) => (
                    <div class="consort-arm">
                      <div class="consort-arm-label">{a.label}</div>
                      <div class="consort-arm-line">allocated <b>{a.allocated}</b></div>
                      {a.analyzed != null && (
                        <div class="consort-arm-line consort-analyzed">analyzed <b>{a.analyzed}</b></div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </details>
          )}
          </div>
        </section>
      ))}
      {study.verdict?.rationale && (
        <section class="depth-section">
          <div class="section-label">Rationale</div>
          <div class="depth-section-body"><p class="depth-prose">{study.verdict.rationale}</p></div>
        </section>
      )}
      {/* v0.30: the Monday-clinic bottom line renders AFTER the evidence
          (Methods → Results → Critique), so the conclusion follows the data
          instead of preceding it. It led the fold pre-v0.30, which read as a
          conclusion before its own results. Content unchanged; order only. */}
      {foldedClinic && (
        <section class="depth-section clinic-section" aria-label="Monday clinic decision">
          <div class="section-label">Monday clinic</div>
          <p class="clinic-text" set:html={linkifyCitations(foldedClinic)} />
        </section>
      )}
      {hasOpenQuestions && (
        <div class="open-questions study-open-questions">
          <div class="section-label">Open questions</div>
          <ul>
            {study.open_questions!.map((q) => {
              const watching = trialsByQuestion.get(q) ?? [];
              const hasWatching = watching.length > 0;
              return (
                <li class:list={[hasWatching && 'has-watching']}>
                  <span class="open-question-text" set:html={linkifyCitations(q)} />
                  {hasWatching && (
                    <div
                      class="trials-watching"
                      role="group"
                      aria-label="Trials watching this question"
                    >
                      {watching.map((t) => {
                        const phaseText = formatPhaseChip(t.phase);
                        const subline = formatTrialSubline(t);
                        return (
                          <div class="trials-watching-row">
                            <div class="trials-watching-line1">
                              <span
                                class="trial-status"
                                aria-label={`Status: ${statusAriaLabel(t.overall_status)}`}
                              >{statusPillText(t.overall_status)}</span>
                              <a
                                class="citation trial-nct"
                                href={`https://clinicaltrials.gov/study/${t.nct}`}
                                target="_blank"
                                rel="noopener"
                              >{t.brief_title}</a>
                              {phaseText && (
                                <span class="trial-phase-chip">{phaseText}</span>
                              )}
                            </div>
                            {hasTrialSubline(t) && (
                              <div class="trials-watching-line2">{subline}</div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      )}
      {authors.length > 0 && (
        <p class="study-authors">
          Sourced from {authors.slice(0, 3).map((a, i) => (
            <Fragment>{i > 0 && ', '}<span class:list={['author-name', `author-${a.kind}`]}>{a.name}</span></Fragment>
          ))}
          {authors.length > 3 && (
            <span class="author-more"> · +{authors.length - 3}</span>
          )}
        </p>
      )}
      {/* ── v0.10 "Studies like this" sibling footer. Inside the depth fold so
          mobile readers see it only when they tap to expand (auto-expanded on
          desktop per Base.astro). No cards, no borders, no grid — reads as a
          continuation of the source-attribution lines per design pass 4. ── */}
      {hasSiblings && (
        <aside class="study-siblings" aria-labelledby={`siblings-${anchorId ?? study.slug ?? 'x'}`}>
          <h4 class="section-label sibling-label" id={`siblings-${anchorId ?? study.slug ?? 'x'}`}>· Studies like this ·</h4>
          <ul class="sibling-list">
            {visibleSiblings.map((s) => (
              <li class="sibling-row">
                <a class="sibling-link" href={`/${s.date}/#${s.resolvedSlug}`}>
                  {s.verdictEmoji && (
                    <span class="sibling-emoji" aria-hidden="true">{s.verdictEmoji}</span>
                  )}
                  <span class="sibling-name">{s.name}</span>
                  <span class="sibling-tldr">{s.tldr}</span>
                  <span class="sibling-date">{s.date}</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </details>
  )}

  {/* ── Provenance: separate collapsible ── */}
  {sourceTotal > 0 && (
    <details class="sources">
      <summary>📚 Sources · {sourceBadges.join(' · ')}</summary>
      <div class="source-stack">
        {bookmarks.map((b) => {
          if (b.html) {
            return (
              <div class="tw-wrap">
                <Fragment set:html={b.html} />
                {b.note && <div class="source-note">📝 {b.note}</div>}
              </div>
            );
          }
          return (
            <div class="source-fallback">
              <div class="source-meta">
                <span>{b.author_name || b.author_handle || 'unknown'}</span>
                <a href={b.url} target="_blank" rel="noopener">view on X →</a>
              </div>
              <div class="source-text" set:html={linkifyCitations(b.text)} />
              {b.note && <div class="source-note">📝 {b.note}</div>}
            </div>
          );
        })}
        {papers.map((p) => (
          <div class="source-paper">
            <div class="source-meta">
              <span class="source-type-pill">📄 PAPER</span>
              <span>
                {p.authors.slice(0, 3).join('; ')}
                {p.authors.length > 3 ? ' et al.' : ''}
              </span>
              {p.journal && (
                <span class="paper-journal">
                  · <em>{p.journal}</em>{p.pub_date ? ` (${p.pub_date.slice(0, 7)})` : ''}
                </span>
              )}
            </div>
            <div class="paper-title">{p.title}</div>
            <div class="paper-links">
              {p.pmid && (
                <a href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener">
                  PMID {p.pmid} →
                </a>
              )}
              {p.doi && (
                <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">
                  doi
                </a>
              )}
              {p.pmc_id && (
                <a href={`https://www.ncbi.nlm.nih.gov/pmc/articles/${p.pmc_id}/`} target="_blank" rel="noopener">
                  full text (PMC)
                </a>
              )}
              {/* v0.15.3: link to the source article. Essential for trade-press
                  (UroToday/ASCO Post/OncLive) which have no PMID/DOI/PMC — this is
                  their only link. Render only http(s) URLs (defense-in-depth vs a
                  javascript: href). Suppress when it's just the doi.org/dx.doi.org
                  resolver we already render as "doi" (anchored so a tracking param
                  that merely contains "doi.org/" doesn't false-suppress). */}
              {isHttpUrl(p.source_url) &&
                !(p.doi && /^https?:\/\/(www\.|dx\.)?doi\.org\//i.test(p.source_url)) && (
                  <a href={p.source_url} target="_blank" rel="noopener">
                    article →
                  </a>
                )}
            </div>
            {p.abstract && (
              <details class="paper-abstract">
                <summary>Abstract</summary>
                <div class="paper-abstract-body" set:html={linkifyCitations(p.abstract.replace(/\n/g, '<br/>'))} />
              </details>
            )}
            {p.note && <div class="source-note">📝 {p.note}</div>}
          </div>
        ))}
        {slides.map((slide) => (
          <div class="source-slide">
            <div class="source-meta">
              <span class="source-type-pill">🩻 SLIDE</span>
              {slide.source_label && <span>{slide.source_label}</span>}
            </div>
            <img
              src={toSlideUrl(slide.file_path)}
              alt={slide.source_label ?? 'Slide photograph'}
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
            />
            <div class="slide-fallback" style="display:none">
              (Slide image not published — curator-private.)
            </div>
            {slide.note && <div class="source-note">📝 {slide.note}</div>}
          </div>
        ))}
      </div>
    </details>
  )}
  {hasTagChips && (
    <div class="meta">
      <p class="study-tags" aria-label="Cross-cutting tags">
        {tagChips.map((c, i) => (
          <Fragment>
            {i > 0 && <span class="tag-sep" aria-hidden="true">·</span>}
            <a class="tag-chip" href={`/tags/${c.slug}/`}>{c.label}</a>
          </Fragment>
        ))}
      </p>
    </div>
  )}
  </div>{/* /.study-rest */}
</div>

<style>
  .study {
    margin: 2.25rem 0;
    padding: 1rem 1.15rem;
    /* v0.30: subtle verdict wash tints each card by its SOC implication (no
       verdict → plain card bg). Pairs with the verdict left border below. */
    background: color-mix(in srgb, var(--verdict-color, transparent) 4%, var(--bg-card));
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
    /* Lift each card off the page so adjacent left accent bars read as
       separate objects, not one continuous line, when stacked. */
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
    scroll-margin-top: 1rem;
  }

  /* Figure gallery. Below 1200px: single column, DOM order is head → figures →
     rest, so the first figure is a visual anchor right under the triage layer.
     At ≥1200px when figures are present: a 2-column grid — narrative left, figure
     column right spanning the card height (see the @media block below). */
  .study-figures { margin: 0.9rem 0 0.2rem; }
  .study-figures .study-figure { margin: 0; }
  /* Figures open full-screen on click (lightbox wired in Base.astro). */
  .study-zoom { cursor: zoom-in; }

  /* v0.26 (Thread 1): figure-sourced citation mark. Muted, non-emoji, scholarly
     — the tooltip carries the meaning ("read from a figure, not the abstract"). */
  .src-fig {
    color: var(--fg-muted);
    font-size: 0.72em;
    margin-left: 0.1em;
    cursor: help;
  }

  .more-figures { margin-top: 0.85rem; }
  .more-figures > summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
  }
  .more-figures > summary:hover { color: var(--accent); }
  .more-figures[open] > summary { margin-bottom: 0.6rem; color: var(--accent); }
  .more-figures-stack { display: flex; flex-direction: column; gap: 0.85rem; }

  /* Head is the positioning anchor for the absolutely-positioned share
     button at top-right. Only the title row needs to reserve space for
     the button (it's the row at top:0 where the button lives) — padding
     here was applied head-wide in v0.9.10, which compressed every block
     child (TL;DR, verdict, comparator, depth) by 72px and left mobile
     cards with only 235px of usable width. Padding now lives on
     .study-name only; everything below renders full-width. */
  .study-head {
    position: relative;
  }
  .study-name {
    padding-right: 4.5rem;
  }

  /* Two-column (narrative + figure) only when the page is wide enough for both
     to breathe (paired with body.wide → 1180px at ≥1200). Below 1200 the card
     falls back to a single column — head, then figures full-width, then rest —
     i.e. it "falls in line" like mobile, so the narrative never gets cramped. */
  @media (min-width: 1200px) {
    .study.has-figures {
      display: grid;
      grid-template-columns: minmax(0, 1fr) clamp(320px, 40%, 470px);
      grid-template-areas:
        "head figs"
        "rest figs";
      column-gap: 1.75rem;
      align-items: start;
    }
    .study.has-figures > .study-head { grid-area: head; min-width: 0; }
    .study.has-figures > .study-rest { grid-area: rest; min-width: 0; }
    .study.has-figures > .study-figures { grid-area: figs; margin: 0; }
  }

  /* Title earns prominence from size + weight (big bold serif), not a tinted
     band or color swap — keeps the card's type calm instead of choppy. */
  .study-name {
    margin: 0 0 0.4rem;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--fg);
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
  }
  .study-nct {
    font-size: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  /* Author surface: credibility-by-attribution. Small + muted; it's metadata. */
  .study-authors {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .author-name { color: var(--fg); }
  /* Tweet @handles read as code identifiers — monospace. */
  .author-tweet {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
  }
  /* Paper attributions ("Siva et al.") read as bibliographic entries — italic. */
  .author-paper {
    font-style: italic;
    font-size: 0.82rem;
  }
  .author-more { color: var(--fg-muted); }

  /* Audience gate: "FOR …" qualifier under the title. Serif description matches
     the card's content voice (TL;DR, verdict, comparator); only the small FOR
     tag stays sans, consistent with the other section labels. */
  .study-audience {
    margin: 0 0 0.55rem;
    font-size: 0.95rem;
    color: var(--fg-muted);
    line-height: 1.45;
  }
  /* Shared meta-label rhythm (FOR / vs leading data) — one consistent treatment
     so the card's small labels don't each look slightly different. */
  .audience-label {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: var(--fg-muted);
    margin-right: 0.5rem;
  }

  /* v0.14.5 (E5): preprint caution flag. Caveats-amber so it reads as "treat
     with care" without being alarmist; sits under the name, above the verdict. */
  .preprint-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0.3rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    line-height: 1.2;
  }
  .preprint-badge-tag {
    padding: 0.12rem 0.45rem;
    background: #8a3a1a;
    color: #fff;
    border-radius: 4px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .preprint-badge-text {
    color: #8a3a1a;
    font-weight: 600;
  }

  /* SOC-implication verdict block — the 5-second triage signal. */
  .verdict-block {
    margin: 0.35rem 0 0.7rem;
    padding: 0.65rem 0.85rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
  }
  /* Verdict color is defined ONCE on the card root (so the pill inherits it via
     cascade) and reused for the selective left-border below. */
  .study.verdict-practice-changing { --verdict-color: #1a5e3a; }
  .study.verdict-challenges-soc { --verdict-color: #9a5a1a; }
  .study.verdict-confirmatory { --verdict-color: var(--accent); }
  .study.verdict-early-signal { --verdict-color: #1a6a7a; }
  .study.verdict-methodologically-limited { --verdict-color: #8a3a1a; }
  .study.verdict-unclear { --verdict-color: var(--fg-muted); }

  /* T1-B: color the card's left border for the ATTENTION verdicts only, so a
     long page of cards reads as a heat-map where the few that demand action
     pop. Confirmatory / early-signal / unclear keep the neutral border; their
     pill still carries the full verdict. Design review 2026-06-10 validated
     this selective set over coloring all six (which flattened the signal). */
  .study.verdict-practice-changing,
  .study.verdict-challenges-soc,
  .study.verdict-methodologically-limited {
    border-left-color: var(--verdict-color);
  }
  .verdict-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--verdict-color);
    margin-bottom: 0.3rem;
  }
  .verdict-emoji { font-size: 0.95rem; line-height: 1; }
  .verdict-rationale {
    margin: 0;
    font-size: 0.93rem;
    line-height: 1.5;
    color: var(--fg);
  }

  /* Comparator-first callout: 🔗 bullets lifted out of the main details list. */
  .comparator-block {
    margin: 0.65rem 0 0.65rem;
    padding: 0.55rem 0.85rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
  }
  .comparator-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }
  .comparator-list {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--fg);
    line-height: 1.5;
    font-size: 0.93rem;
  }
  .comparator-list li { margin: 0.2rem 0; }

  /* v0.22 "Why it matters": the one long-form prose callout. Same quiet
     bordered shell as the verdict + comparator callouts so the head reads as a
     consistent stack; the prose is serif body (matching the verdict rationale),
     the small-caps label carries the active specialty lens. It earns its width
     because it's the one surface holding the subtle figure/table detail the
     terse bullets drop. */
  .significance-block {
    margin: 0.65rem 0 0.7rem;
    padding: 0.6rem 0.85rem 0.65rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
  }
  /* v0.32: the per-specialty variant blocks ship SSR-hidden; the SpecialtyBar
     reveals the picked one. Explicit guard so a scoped display rule can't leak an
     inert variant onto the card. */
  .significance-block[hidden] { display: none; }
  .significance-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }
  .significance-sep { color: var(--fg-muted); user-select: none; }
  .significance-text {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.55;
    color: var(--fg);
  }
  /* v0.27: curator's own note — a warm, quiet margin-note, distinct from the
     blue AI "why it matters" callout above. Italic body signals human voice. */
  .curator-note-block {
    margin: 0.65rem 0 0.7rem;
    padding: 0.55rem 0.85rem 0.6rem;
    background: var(--citation-bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--fg-muted);
    border-radius: 4px;
  }
  .curator-note-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.3rem;
  }
  .curator-note-text {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.55;
    color: var(--fg);
    font-style: italic;
  }

  /* v0.26 (E3): the folded Monday-clinic decision line — serif prose like the
     significance callout, sitting under its section label in the depth fold. */
  .clinic-text {
    margin: 0.3rem 0 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--fg);
  }

  /* v0.16 trade-press provenance: a quiet attribution line under the TL;DR.
     Metadata weight (sans, muted) — it's a "who reported this," not a result. */
  .study-provenance {
    margin: 0 0 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--fg-muted);
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .provenance-icon { flex: none; font-size: 0.85rem; line-height: 1; }
  .provenance-link { color: var(--accent); text-decoration: none; }
  .provenance-link:hover { text-decoration: underline; }
  .provenance-outlet { color: var(--fg); }

  /* v0.17 (T6): "surfaced from a review" attribution on an auto-resolved study
     card. Quiet metadata weight, same rhythm as the trade-press provenance. */
  .study-resolved-from {
    margin: 0 0 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--fg-muted);
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .resolved-icon { flex: none; color: var(--accent); }
  /* Linked discussed-trial acronym (jumps to the resolved card on this page). */
  .dt-link { color: var(--accent); text-decoration: none; }
  .dt-link:hover { text-decoration: underline; }

  /* v0.16 review "Trials discussed": the acronym landscape a press round-up
     names. Plain text, NOT links (no NCT inference) — same callout shell as the
     comparator block, dot-separated names that wrap on narrow viewports. */
  .discussed-trials {
    margin: 0.65rem 0;
    padding: 0.55rem 0.85rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
  }
  .discussed-trials-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }
  .discussed-trials-list {
    margin: 0;
    color: var(--fg);
    line-height: 1.6;
    font-size: 0.92rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.1rem 0.5rem;
    align-items: baseline;
  }
  .dt-name { font-weight: 600; }
  .dt-sep { color: var(--fg-muted); user-select: none; }

  /* CONSORT participant-flow diagram (in a dropdown). Vertical flow with box
     nodes + arrow connectors; arms wrap to a row, stacking on narrow screens. */
  .consort { margin-top: 0.5rem; }
  .consort > summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
  }
  .consort > summary:hover { color: var(--accent); }
  .consort[open] > summary { margin-bottom: 0.5rem; color: var(--accent); }
  .consort-flow {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    text-align: center;
  }
  .consort-node {
    padding: 0.4rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg);
  }
  .consort-node b { font-weight: 700; }
  .consort-rand { border-color: var(--accent); }
  .consort-arrow {
    color: var(--fg-muted);
    font-size: 0.78rem;
    line-height: 1.5;
    padding: 0.15rem 0;
  }
  .consort-arms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    width: 100%;
  }
  .consort-arm {
    flex: 1 1 130px;
    max-width: 220px;
    padding: 0.5rem 0.7rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 6px;
    text-align: left;
  }
  .consort-arm-label { font-weight: 700; color: var(--fg); margin-bottom: 0.2rem; }
  .consort-arm-line { color: var(--fg-muted); line-height: 1.4; }
  .consort-arm-line b { color: var(--fg); font-weight: 700; }
  .consort-analyzed { font-size: 0.78rem; }

  /* TL;DR is the headline result — make it the lead callout so it isn't lost
     between the title and the verdict/comparator boxes. The one tinted block in
     the head; verdict + comparator are quieter bordered callouts below it. */
  /* v0.30: the TL;DR is the card's hero. It carries a verdict-tinted wash + a
     verdict-color left rule so the headline number (verdict-colored .stat-key)
     reads as the endpoint-forward result box, echoing the redesign mockups. */
  .study-tldr {
    margin: 0 0 0.7rem;
    padding: 0.7rem 0.95rem;
    font-size: 1.16rem;
    line-height: 1.5;
    color: var(--fg);
    background: color-mix(in srgb, var(--verdict-color, var(--accent)) 9%, var(--bg-card));
    border: 1px solid var(--border);
    border-left: 3px solid var(--verdict-color, var(--accent));
    border-radius: 4px;
  }
  /* v0.30: emphasize result-carrying numbers in the headline. The driving effect
     size gets bold + a verdict-hued underline (valence hint via the underline, so
     the text stays neutral and a negative HR never reads as a colored "win");
     secondary stats get bold + tabular figures. */
  .study-tldr .stat { font-weight: 600; font-variant-numeric: tabular-nums; }
  .study-tldr .stat-key {
    font-weight: 700;
    color: var(--verdict-color, var(--fg));
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
    text-decoration-color: var(--verdict-color, var(--fg-muted));
  }
  /* v0.30: endpoint-forward head — leads the card when a structured primary
     endpoint is present. Verdict-washed hero box: endpoint name + class chip,
     then the verbatim stat with its number emphasized. TL;DR then drops to plain. */
  .study-endpoint {
    margin: 0 0 0.5rem;
    padding: 0.65rem 0.95rem 0.7rem;
    background: color-mix(in srgb, var(--verdict-color, var(--accent)) 10%, var(--bg-card));
    border: 1px solid var(--border);
    border-left: 3px solid var(--verdict-color, var(--accent));
    border-radius: 4px;
  }
  .endpoint-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.2rem;
  }
  .endpoint-name { font-weight: 700; font-size: 0.98rem; }
  .endpoint-class {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 1px 6px;
    border-radius: 3px;
    /* Legible neutral fallback for any unrecognized class (the four known
       classes each override below). Was --fg-muted with no fill, which read as
       near-invisible for local-control/surrogate/safety in a screenshot. */
    color: var(--fg);
    background: color-mix(in srgb, var(--fg) 8%, var(--bg-card));
    border: 1px solid var(--border);
  }
  .endpoint-stat {
    margin: 0;
    font-size: 1.9rem;
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.015em;
    font-variant-numeric: tabular-nums;
  }
  .endpoint-stat .stat { font-weight: 700; }
  .endpoint-stat .stat-key { color: var(--verdict-color, var(--fg)); text-decoration: none; }
  /* v0.30: muted CI / p / absolute sub-line under the big endpoint value (mockup .ep-sub). */
  .endpoint-sub {
    margin: 3px 0 0;
    font-size: 0.75rem;
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
    line-height: 1.3;
  }
  /* TL;DR sheds its hero box when the endpoint block already leads the card. */
  .study-tldr--plain {
    background: transparent;
    border: none;
    padding: 0 0 0 0.1rem;
    font-size: 1rem;
  }
  /* v0.30: glance-top — trial name (left) + a compact verdict chip (right),
     replacing the old stacked verdict pill + rationale paragraph. */
  /* v0.31: verdict chip is a KICKER on its own line above the title. Beside-the-
     title (the old space-between row) overlapped a long title that wrapped — the
     chip sat over the first line. Stacking is robust for any title length. */
  .glance-top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding-right: 2.9rem; /* reserve the absolutely-positioned share button's corner */
  }
  .glance-top .study-name { padding-right: 0; }
  /* v0.30: FILLED verdict chip (mockup parity). --verdict-color inverts per
     theme (dark hue in light mode, bright hue in dark), so the text color flips
     too: white on the dark-mode fills would fail, so dark mode uses near-bg text. */
  .verdict-chip {
    flex: 0 0 auto;
    align-self: start;
    margin-top: 0.12rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--verdict-chip-fg, #fff);
    background: var(--verdict-color, var(--fg-muted));
    border: none;
    border-radius: 4px;
    padding: 4px 9px;
    white-space: nowrap;
  }
  :global(:root:not([data-theme='light'])) .verdict-chip { --verdict-chip-fg: var(--bg); }
  .verdict-chip .verdict-emoji { font-size: 0.9rem; line-height: 1; }
  .depth-prose { margin: 0; font-size: 0.92rem; line-height: 1.5; }
  /* v0.30: unified GLANCE wash box (mockup parity) — holds name+chip, the
     endpoint, and the take/TL;DR, capped by a verdict hairline. The endpoint and
     TL;DR shed their own boxes inside it; "why it matters" reads plain below. */
  .glance {
    padding: 0.75rem 0.9rem 0.8rem;
    margin-bottom: 0.85rem;
    background: color-mix(in srgb, var(--verdict-color, var(--accent)) 8%, var(--bg-card));
    border: 1px solid var(--border);
    border-bottom: 2px solid var(--verdict-color, var(--border));
    border-radius: 5px;
  }
  .glance .study-audience { margin: 0.15rem 0 0.4rem; }
  .glance .study-endpoint {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0.15rem 0 0.45rem;
  }
  .glance .study-tldr {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    font-size: 1rem;
  }
  /* de-box "why it matters" — plain read band, no border / blue left-bar. */
  .significance-block {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0.1rem 0 0.75rem;
  }
  /* Endpoint class chip — one legible, distinct fill per class so the endpoint
     TYPE reads as co-equal with the headline number (a survival benefit vs a
     surrogate vs local control is as important as the effect size). Importance
     hierarchy: hard survival (solid dark) > local control (solid accent) >
     surrogate (soft accent tint) > safety (neutral). All derived from theme
     tokens so they invert cleanly between dark + light mode. */
  .endpoint-class.ec-overall-survival {
    color: var(--bg-card);
    background: var(--fg);
    border-color: transparent;
  }
  .endpoint-class.ec-local-control {
    color: var(--bg-card);
    background: var(--accent);
    border-color: transparent;
  }
  .endpoint-class.ec-surrogate {
    color: var(--accent);
    background: var(--accent-bg);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .endpoint-class.ec-safety {
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--fg) 6%, var(--bg-card));
    border-color: var(--border);
  }
  /* NCT as a plain accent line under the name (mockup), not a bordered pill. */
  .glance .study-nct {
    display: block;
    margin: 2px 0 0;
    padding: 0;
    background: none;
    border: none;
    font-size: 0.66rem;
    color: var(--accent);
  }
  /* fold labels tighter, matching the mockup's .fa-lab type scale. */
  .depth-section > .section-label,
  .study-open-questions > .section-label {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }
  /* v0.30: meta footer — tags row at the card bottom (mockup .meta), not mid-card. */
  .meta {
    border-top: 1px solid var(--border);
    margin-top: 0.9rem;
    padding-top: 0.7rem;
  }
  .meta .study-tags { margin: 0; }
  /* v0.30: ✓ represents / ✕ excludes markers in the "Applies to" fold section. */
  .depth-section-body .rep { display: flex; gap: 0.4rem; margin: 0.12rem 0; line-height: 1.45; }
  .depth-section-body .rep .mark { font-weight: 700; flex-shrink: 0; }
  .depth-section-body .rep.yes .mark { color: #1a7a48; }
  .depth-section-body .rep.no .mark { color: #8a4a12; }
  :global(:root:not([data-theme='light'])) .depth-section-body .rep.yes .mark { color: #4fb07a; }
  :global(:root:not([data-theme='light'])) .depth-section-body .rep.no .mark { color: #d9785a; }
  /* Inline TL;DR label — matches the FOR / vs leading data rhythm so the
     headline paragraph is identifiable at a glance. */
  .tldr-label {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: var(--fg-muted);
    margin-right: 0.55rem;
    vertical-align: 0.12em;
  }

  /* Depth fold: methodology + attribution behind a tap. Summary mirrors the
     sources affordance (muted, sans). Triangle marker is the native one. */
  .study-depth { margin-top: 0.5rem; }
  .study-depth > summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
  }
  .study-depth > summary:hover { color: var(--accent); }
  .study-depth[open] > summary {
    margin-bottom: 0.5rem;
    color: var(--accent);
  }

  /* IMRD section dividers inside the depth fold (Methods → Results → Critique
     → Notes). The label reuses .section-label (small caps, muted); a thin top
     rule separates sections so the dropdown reads as a structured paper rather
     than a flat list. CONSORT, when present, is nested inside Methods. */
  /* v0.30: left-labeled "spec sheet" grid — the section label sits in a narrow
     left column, content on the right (the v3-stampede-full mockup treatment).
     Collapses to label-above-content on very narrow phones. */
  .depth-section {
    display: grid;
    grid-template-columns: clamp(84px, 26%, 116px) 1fr;
