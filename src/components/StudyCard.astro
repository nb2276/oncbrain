  .sources summary:hover { color: var(--accent); }
  .source-stack {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .tw-wrap :global(.twitter-tweet) { margin: 0 !important; }
  .tw-wrap :global(iframe) { max-width: 100% !important; }
  .source-fallback {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .source-text { line-height: 1.5; white-space: pre-wrap; }
  .source-note {
    margin-top: 0.45rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-style: italic;
  }
  /* Paper sources */
  .source-paper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    font-size: 0.92rem;
  }
  .source-type-pill {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    background: var(--accent-bg);
    color: var(--accent);
    border-radius: 3px;
    margin-right: 0.4rem;
    vertical-align: 1px;
  }
  .paper-title {
    margin: 0.35rem 0 0.4rem;
    font-family: var(--font-serif);
    font-weight: 600;
    line-height: 1.35;
  }
  .paper-journal { color: var(--fg-muted); font-family: var(--font-sans); font-size: 0.82rem; }
  .paper-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    margin-bottom: 0.4rem;
  }
  .paper-links a { color: var(--accent); }
  .paper-abstract { margin-top: 0.4rem; }
  .paper-abstract summary {
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    padding: 0.25rem 0;
  }
  .paper-abstract summary:hover { color: var(--accent); }
  .paper-abstract-body {
    margin-top: 0.4rem;
    line-height: 1.5;
    color: var(--fg);
  }
  /* Slide sources */
  .source-slide {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    font-size: 0.92rem;
  }
  .source-slide img {
