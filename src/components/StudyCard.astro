---
// Single source of truth for the dense per-study card. Rendered by both the
// per-date digest (`[date].astro`) and the by-site aggregation
// (`sites/[site].astro`). Presentation-only: callers resolve a study's sources
// to concrete bookmark/paper/slide arrays and pass them in.
//
// Triage-first layout (v0.9): the card rests at its triage layer — name,
// verdict pill, TL;DR, and the "vs leading data" callout — so a busy reader
// scans verdicts + headline numbers down the page. The methodology depth
// (audience, figure, detail bullets/tables, open questions, attribution) folds
// behind a native <details> expander. Sources stay in their own collapsible.
import { linkifyCitations } from '../lib/extract.ts';
import { isSafeImageUrl } from '../lib/vision-ocr.ts';
import { VERDICT_META } from '../lib/verdict.ts';
import {
  studyFigures,
  stripStudyNamePrefix,
  type DigestStudy,
  type DigestDetail,
  type DigestArtifact,
  type DigestArtifactPaper,
  type DigestArtifactSlide,
} from '../lib/digest-data.ts';

type Bookmark = DigestArtifact['bookmarks'][number];
type StudyAuthor = { name: string; kind: 'tweet' | 'paper' };

interface Props {
  study: DigestStudy;
  // Resolved sources (the caller dereferences source_ids/tweet_ids).
  bookmarks?: Bookmark[];
  papers?: DigestArtifactPaper[];
  slides?: DigestArtifactSlide[];
  // Optional anchor id on the card root (per-date page uses it for deep links).
  anchorId?: string;
  // Optional "Sourced from …" attribution line (per-date page only).
  authors?: StudyAuthor[];
  // Optional canonical share URL (per-site page anchor: /sites/{site}/#{date}-{slug}).
  // Absent → share button is not rendered. Absolutized at click time in share-script.ts.
  shareUrl?: string;
}

const {
  study,
  bookmarks = [],
  papers = [],
  slides = [],
  anchorId,
  authors = [],
  shareUrl,
} = Astro.props as Props;

// 🔗 bullets are lifted out of the main list into the "vs leading data" callout.
function isComparatorBullet(d: DigestDetail): boolean {
  const text = typeof d === 'string' ? d : (d as { text: string }).text;
  return /^\s*🔗/.test(text);
}
function stripComparatorEmoji(text: string): string {
  return text.replace(/^\s*🔗\s*/, '');
}
// "data/slide-photos/<date>/<uuid>.jpg" → "/slides/<date>/<uuid>.jpg"
function toSlideUrl(filePath: string): string {
  return filePath.startsWith('data/slide-photos/')
    ? '/slides/' + filePath.slice('data/slide-photos/'.length)
    : filePath;
}

const comparatorBullets = study.details.filter(isComparatorBullet);
const otherBullets = study.details.filter((d) => !isComparatorBullet(d));
const verdictMeta = study.verdict ? VERDICT_META[study.verdict.soc_implication] : null;

// IMRD-style section bucketing for the depth fold. The leading emoji on each
// bullet already encodes the section (VOICE.md): 🔍/💊 are Methods, 📊/📐 are
// Results, ⚠️ is Critique. Bullets without a recognized emoji prefix fall to
// Notes so nothing is silently dropped.
type DepthSection = 'methods' | 'results' | 'critique' | 'notes';
function bucketBullet(d: DigestDetail): DepthSection {
  const text = typeof d === 'string' ? d : (d as { text: string }).text;
  // ⚠️ ships with or without the U+FE0F variation selector depending on
  // source/keyboard; match both forms.
  const m = text.match(/^\s*(🔍|💊|📊|📐|⚠️|⚠)/u);
  if (!m) return 'notes';
  const e = m[1];
  if (e === '🔍' || e === '💊') return 'methods';
  if (e === '📊' || e === '📐') return 'results';
  return 'critique';
}
const methodsBullets = otherBullets.filter((d) => bucketBullet(d) === 'methods');
const resultsBullets = otherBullets.filter((d) => bucketBullet(d) === 'results');
const critiqueBullets = otherBullets.filter((d) => bucketBullet(d) === 'critique');
const notesBullets = otherBullets.filter((d) => bucketBullet(d) === 'notes');
const hasConsort = Boolean(study.consort && study.consort.arms.length >= 2);
const depthSections: Array<{ label: string; bullets: DigestDetail[]; consort: boolean }> = [];
if (methodsBullets.length > 0 || hasConsort) depthSections.push({ label: 'Methods', bullets: methodsBullets, consort: hasConsort });
if (resultsBullets.length > 0) depthSections.push({ label: 'Results', bullets: resultsBullets, consort: false });
if (critiqueBullets.length > 0) depthSections.push({ label: 'Critique', bullets: critiqueBullets, consort: false });
if (notesBullets.length > 0) depthSections.push({ label: 'Notes', bullets: notesBullets, consort: false });

// v0.10: figure gallery (KM curve, forest plot, results/AE table…). Normalizes
// the v0.4 single-figure shape; re-applies the host allowlist at render time as
// defense-in-depth (build already validated). First figure is the visual anchor;
// the rest fold behind a tap on mobile (auto-expanded on desktop via Base.astro).
const figures = studyFigures(study).filter((f) => isSafeImageUrl(f.url));
const hasFigures = figures.length > 0;
const restFigures = figures.slice(1);

const hasOpenQuestions = Boolean(
  study.open_questions && study.open_questions.length > 0,
);
// Audience ("For …") is lifted to the triage layer (just under the name), so it
// is no longer part of the folded depth.
const hasAudience = Boolean(study.verdict?.audience);
// Folded "depth" layer: everything past the triage essentials. Figures live in
// their own column; audience is now in the head; CONSORT folds into Methods.
const hasDepth =
  otherBullets.length > 0 ||
  hasOpenQuestions ||
  authors.length > 0 ||
  hasConsort;
const depthSummary = otherBullets.length > 0
  ? `${otherBullets.length} ${otherBullets.length === 1 ? 'detail' : 'details'}`
  : 'Details';

const sourceTotal = bookmarks.length + papers.length + slides.length;
const sourceBadges: string[] = [];
if (bookmarks.length > 0) sourceBadges.push(`🐦 ${bookmarks.length} tweet${bookmarks.length === 1 ? '' : 's'}`);
if (papers.length > 0) sourceBadges.push(`📄 ${papers.length} paper${papers.length === 1 ? '' : 's'}`);
if (slides.length > 0) sourceBadges.push(`🩻 ${slides.length} slide${slides.length === 1 ? '' : 's'}`);
---

<div class:list={['study', hasFigures && 'has-figures']} id={anchorId}>
  <div class="study-head">
  {/* ── Triage layer: always visible ── */}
  <h4 class="study-name">
    {study.name}
    {study.nct && (
      <a class="citation study-nct" href={`https://clinicaltrials.gov/study/${study.nct}`} target="_blank" rel="noopener">{study.nct}</a>
    )}
  </h4>
  {hasAudience && (
    <p class="study-audience study-audience-head"><span class="audience-label">For</span>{study.verdict!.audience}</p>
  )}
  <p class="study-tldr" set:html={linkifyCitations(stripStudyNamePrefix(study.tldr, study.name))} />
  {study.verdict?.rationale && verdictMeta && (
    <aside class:list={['verdict-block', `verdict-${study.verdict.soc_implication}`]}>
      <div class="verdict-pill">
        <span class="verdict-emoji" aria-hidden="true">{verdictMeta.emoji}</span>
        <span class="verdict-label">{verdictMeta.label}</span>
      </div>
      <p class="verdict-rationale">{study.verdict.rationale}</p>
    </aside>
  )}
  {comparatorBullets.length > 0 && (
    <section class="comparator-block">
      <div class="comparator-label">vs leading data</div>
      <ul class="comparator-list">
        {comparatorBullets.map((d) => (
          typeof d === 'string'
            ? <li set:html={linkifyCitations(stripComparatorEmoji(d))} />
            : <li set:html={linkifyCitations(stripComparatorEmoji(d.text))} />
        ))}
      </ul>
    </section>
  )}
  {/* ── Share affordance: top-right of the head. Anchored to .study-head (not
      to .study) so on wide-desktop figures-present cards it stays in the left
      narrative column instead of overlaying the figures column. Hidden via
      CSS display:none until share-script.ts confirms an API works. ── */}
  {shareUrl && (
    <Fragment>
      <button
        type="button"
        class="study-share"
        data-share-url={shareUrl}
        data-share-title={study.name}
        aria-label={`Share link to ${study.name}`}
      >Share</button>
      <span class="sr-share-status" aria-live="polite"></span>
      <input
        type="text"
        class="share-recovery"
        readonly
        tabindex={-1}
        aria-label="Copy this URL manually"
      />
    </Fragment>
  )}
  </div>{/* /.study-head */}

  {/* ── Figures: right column on desktop; first shown + rest folded on mobile ── */}
  {hasFigures && (
    <div class="study-figures">
      <figure class="study-figure">
        <img class="study-zoom" src={figures[0]!.url} alt={typeof figures[0]!.caption === 'string' ? figures[0]!.caption : study.name} loading="lazy" onerror="this.style.display='none'" />
        {typeof figures[0]!.caption === 'string' && figures[0]!.caption && (
          <figcaption>{figures[0]!.caption}</figcaption>
        )}
        {figures[0]!.caption && typeof figures[0]!.caption !== 'string' && (
          <figcaption>
            <div class="study-table-wrap caption-table-wrap">
              <table class="study-table">
                <thead>
                  <tr>{figures[0]!.caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}</tr>
                </thead>
                <tbody>
                  {figures[0]!.caption.rows.map((row) => (
                    <tr>{row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </figcaption>
        )}
      </figure>
      {restFigures.length > 0 && (
        <details class="more-figures">
          <summary>+{restFigures.length} more figure{restFigures.length === 1 ? '' : 's'}</summary>
          <div class="more-figures-stack">
            {restFigures.map((fig) => (
              <figure class="study-figure">
                <img class="study-zoom" src={fig.url} alt={typeof fig.caption === 'string' ? fig.caption : study.name} loading="lazy" onerror="this.style.display='none'" />
                {typeof fig.caption === 'string' && fig.caption && (
                  <figcaption>{fig.caption}</figcaption>
                )}
                {fig.caption && typeof fig.caption !== 'string' && (
                  <figcaption>
                    <div class="study-table-wrap caption-table-wrap">
                      <table class="study-table">
                        <thead>
                          <tr>{fig.caption.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}</tr>
                        </thead>
                        <tbody>
                          {fig.caption.rows.map((row) => (
                            <tr>{row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}</tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        </details>
      )}
    </div>
  )}

  <div class="study-rest">
  {/* ── Depth layer: folded behind a tap. Bullets flow IMRD-style (Methods →
      Results → Critique → Notes), with CONSORT nested inside Methods. ── */}
  {hasDepth && (
    <details class="study-depth">
      <summary>{depthSummary}</summary>
      {depthSections.map((sec) => (
        <section class="depth-section">
          <div class="section-label">{sec.label}</div>
          {sec.bullets.length > 0 && (
            <ul class="study-details">
              {sec.bullets.map((d) => {
                if (typeof d === 'string') {
                  return <li set:html={linkifyCitations(d)} />;
                }
                if ('table' in d) {
                  return (
                    <li>
                      <span set:html={linkifyCitations(d.text)} />
                      <div class="study-table-wrap">
                        <table class="study-table">
                          <thead>
                            <tr>
                              {d.table.columns.map((c) => (<th set:html={linkifyCitations(c)} />))}
                            </tr>
                          </thead>
                          <tbody>
                            {d.table.rows.map((row) => (
                              <tr>
                                {row.map((cell) => (<td set:html={linkifyCitations(cell)} />))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </li>
                  );
                }
                return (
                  <li>
                    <span set:html={linkifyCitations(d.text)} />
                    {d.subdetails.length > 0 && (
                      <ul class="study-subdetails">
                        {d.subdetails.map((s) => (<li set:html={linkifyCitations(s)} />))}
                      </ul>
                    )}
                  </li>
                );
              })}
            </ul>
          )}
          {sec.consort && study.consort && (
            <details class="consort">
              <summary>CONSORT flow</summary>
              <div class="consort-flow">
                {study.consort.enrolled != null && (
                  <>
                    <div class="consort-node">Assessed / enrolled <b>{study.consort.enrolled}</b></div>
                    <div class="consort-arrow">
                      {study.consort.excluded != null ? `↓  ${study.consort.excluded} excluded` : '↓'}
                    </div>
                  </>
                )}
                <div class="consort-node consort-rand">Randomized <b>{study.consort.randomized}</b></div>
                <div class="consort-arrow">↓</div>
                <div class="consort-arms">
                  {study.consort.arms.map((a) => (
                    <div class="consort-arm">
                      <div class="consort-arm-label">{a.label}</div>
                      <div class="consort-arm-line">allocated <b>{a.allocated}</b></div>
                      {a.analyzed != null && (
                        <div class="consort-arm-line consort-analyzed">analyzed <b>{a.analyzed}</b></div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </details>
          )}
        </section>
      ))}
      {hasOpenQuestions && (
        <div class="open-questions study-open-questions">
          <div class="section-label">Open questions</div>
          <ul>
            {study.open_questions!.map((q) => (<li set:html={linkifyCitations(q)} />))}
          </ul>
        </div>
      )}
      {authors.length > 0 && (
        <p class="study-authors">
          Sourced from {authors.slice(0, 3).map((a, i) => (
            <Fragment>{i > 0 && ', '}<span class:list={['author-name', `author-${a.kind}`]}>{a.name}</span></Fragment>
          ))}
          {authors.length > 3 && (
            <span class="author-more"> · +{authors.length - 3}</span>
          )}
        </p>
      )}
    </details>
  )}

  {/* ── Provenance: separate collapsible ── */}
  {sourceTotal > 0 && (
    <details class="sources">
      <summary>📚 Sources · {sourceBadges.join(' · ')}</summary>
      <div class="source-stack">
        {bookmarks.map((b) => {
          if (b.html) {
            return (
              <div class="tw-wrap">
                <Fragment set:html={b.html} />
                {b.note && <div class="source-note">📝 {b.note}</div>}
              </div>
            );
          }
          return (
            <div class="source-fallback">
              <div class="source-meta">
                <span>{b.author_name || b.author_handle || 'unknown'}</span>
                <a href={b.url} target="_blank" rel="noopener">view on X →</a>
              </div>
              <div class="source-text" set:html={linkifyCitations(b.text)} />
              {b.note && <div class="source-note">📝 {b.note}</div>}
            </div>
          );
        })}
        {papers.map((p) => (
          <div class="source-paper">
            <div class="source-meta">
              <span class="source-type-pill">📄 PAPER</span>
              <span>
                {p.authors.slice(0, 3).join('; ')}
                {p.authors.length > 3 ? ' et al.' : ''}
              </span>
              {p.journal && (
                <span class="paper-journal">
                  · <em>{p.journal}</em>{p.pub_date ? ` (${p.pub_date.slice(0, 7)})` : ''}
                </span>
              )}
            </div>
            <div class="paper-title">{p.title}</div>
            <div class="paper-links">
              <a href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener">
                PMID {p.pmid} →
              </a>
              {p.doi && (
                <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">
                  doi
                </a>
              )}
              {p.pmc_id && (
                <a href={`https://www.ncbi.nlm.nih.gov/pmc/articles/${p.pmc_id}/`} target="_blank" rel="noopener">
                  full text (PMC)
                </a>
              )}
            </div>
            {p.abstract && (
              <details class="paper-abstract">
                <summary>Abstract</summary>
                <div class="paper-abstract-body" set:html={linkifyCitations(p.abstract.replace(/\n/g, '<br/>'))} />
              </details>
            )}
            {p.note && <div class="source-note">📝 {p.note}</div>}
          </div>
        ))}
        {slides.map((slide) => (
          <div class="source-slide">
            <div class="source-meta">
              <span class="source-type-pill">🩻 SLIDE</span>
              {slide.source_label && <span>{slide.source_label}</span>}
            </div>
            <img
              src={toSlideUrl(slide.file_path)}
              alt={slide.source_label ?? 'Slide photograph'}
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
            />
            <div class="slide-fallback" style="display:none">
              (Slide image not published — curator-private.)
            </div>
            {slide.note && <div class="source-note">📝 {slide.note}</div>}
          </div>
        ))}
      </div>
    </details>
  )}
  </div>{/* /.study-rest */}
</div>

<style>
  .study {
    margin: 2.25rem 0;
    padding: 1rem 1.15rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
    /* Lift each card off the page so adjacent left accent bars read as
       separate objects, not one continuous line, when stacked. */
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
    scroll-margin-top: 1rem;
  }

  /* Figure gallery. Below 1200px: single column, DOM order is head → figures →
     rest, so the first figure is a visual anchor right under the triage layer.
     At ≥1200px when figures are present: a 2-column grid — narrative left, figure
     column right spanning the card height (see the @media block below). */
  .study-figures { margin: 0.9rem 0 0.2rem; }
  .study-figures .study-figure { margin: 0; }
  /* Figures open full-screen on click (lightbox wired in Base.astro). */
  .study-zoom { cursor: zoom-in; }

  .more-figures { margin-top: 0.85rem; }
  .more-figures > summary {
    cursor: pointer;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.3rem 0;
  }
  .more-figures > summary:hover { color: var(--accent); }
  .more-figures[open] > summary { margin-bottom: 0.6rem; color: var(--accent); }
  .more-figures-stack { display: flex; flex-direction: column; gap: 0.85rem; }

  /* Head is the positioning anchor for the absolutely-positioned share
     button at top-right. padding-right reserves a slot so the trial name,
     audience, TL;DR, verdict, and comparator never run under the button. */
  .study-head {
    position: relative;
    padding-right: 4.5rem;
  }

  /* Two-column (narrative + figure) only when the page is wide enough for both
     to breathe (paired with body.wide → 1180px at ≥1200). Below 1200 the card
     falls back to a single column — head, then figures full-width, then rest —
     i.e. it "falls in line" like mobile, so the narrative never gets cramped. */
  @media (min-width: 1200px) {
    .study.has-figures {
      display: grid;
      grid-template-columns: minmax(0, 1fr) clamp(320px, 40%, 470px);
      grid-template-areas:
        "head figs"
        "rest figs";
      column-gap: 1.75rem;
      align-items: start;
    }
    .study.has-figures > .study-head { grid-area: head; min-width: 0; }
    .study.has-figures > .study-rest { grid-area: rest; min-width: 0; }
    .study.has-figures > .study-figures { grid-area: figs; margin: 0; }
  }

  /* Title earns prominence from size + weight (big bold serif), not a tinted
     band or color swap — keeps the card's type calm instead of choppy. */
  .study-name {
    margin: 0 0 0.4rem;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--fg);
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
  }
  .study-nct {
    font-size: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  /* Author surface: credibility-by-attribution. Small + muted; it's metadata. */
  .study-authors {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--fg-muted);
    line-height: 1.4;
  }
  .author-name { color: var(--fg); }
  /* Tweet @handles read as code identifiers — monospace. */
  .author-tweet {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
  }
  /* Paper attributions ("Siva et al.") read as bibliographic entries — italic. */
  .author-paper {
    font-style: italic;
    font-size: 0.82rem;
  }
  .author-more { color: var(--fg-muted); }

  /* Audience gate: "FOR …" qualifier under the title. Serif description matches
     the card's content voice (TL;DR, verdict, comparator); only the small FOR
     tag stays sans, consistent with the other section labels. */
  .study-audience {
    margin: 0 0 0.55rem;
    font-size: 0.95rem;
    color: var(--fg-muted);
    line-height: 1.45;
  }
  /* Shared meta-label rhythm (FOR / vs leading data) — one consistent treatment
     so the card's small labels don't each look slightly different. */
  .audience-label {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: var(--fg-muted);
    margin-right: 0.5rem;
  }

  /* SOC-implication verdict block — the 5-second triage signal. */
  .verdict-block {
    margin: 0.35rem 0 0.7rem;
    padding: 0.65rem 0.85rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
  }
  .verdict-block.verdict-practice-changing { --verdict-color: #1a5e3a; }
  .verdict-block.verdict-challenges-soc { --verdict-color: #9a5a1a; }
  .verdict-block.verdict-confirmatory { --verdict-color: var(--accent); }
  .verdict-block.verdict-early-signal { --verdict-color: #1a6a7a; }
  .verdict-block.verdict-methodologically-limited { --verdict-color: #8a3a1a; }
  .verdict-block.verdict-unclear { --verdict-color: var(--fg-muted); }
  .verdict-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--verdict-color);
    margin-bottom: 0.3rem;
  }
  .verdict-emoji { font-size: 0.95rem; line-height: 1; }
  .verdict-rationale {
    margin: 0;
    font-size: 0.93rem;
    line-height: 1.5;
    color: var(--fg);
  }

  /* Comparator-first callout: 🔗 bullets lifted out of the main details list. */
  .comparator-block {
    margin: 0.65rem 0 0.65rem;
    padding: 0.55rem 0.85rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 4px;
  }
  .comparator-label {
    font-family: var(--font-sans);
