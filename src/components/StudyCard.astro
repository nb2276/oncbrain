  .study-share {
    display: none;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 0;
    right: 0;
    background: none;
    border: none;
    padding: 0.5rem;
    color: var(--fg-muted);
    cursor: pointer;
    /* 44px minimum touch target (no chip background). */
    min-width: 44px;
    min-height: 44px;
