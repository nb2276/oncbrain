  .consort-arm-label { font-weight: 700; color: var(--fg); margin-bottom: 0.2rem; }
  .consort-arm-line { color: var(--fg-muted); line-height: 1.4; }
  .consort-arm-line b { color: var(--fg); font-weight: 700; }
  .consort-analyzed { font-size: 0.78rem; }

  /* TL;DR is the headline result — make it the lead callout so it isn't lost
     between the title and the verdict/comparator boxes. The one tinted block in
     the head; verdict + comparator are quieter bordered callouts below it. */
  .study-tldr {
    margin: 0 0 0.7rem;
