---
// Desktop-only sticky triage rail: a jump-list of every study on the page,
// each marked with its verdict emoji. Lives in the left gutter beside the
// 700px reading column on wide screens; hidden below 1200px (the column
// re-centers and the rail would overlap). Pure anchor links — no JS.
interface RailItem {
  href: string; // "#<anchor>" or a page URL
  name: string;
  verdictEmoji: string; // verdict emoji (studies) or site emoji (home nav)
}
interface Props {
  items: RailItem[];
  label?: string; // header label; defaults to "Studies · N"
  ariaLabel?: string;
}
const { items, label, ariaLabel } = Astro.props as Props;
const railLabel = label ?? `Studies · ${items.length}`;
const railAria = ariaLabel ?? 'Studies on this page';
---

{items.length > 1 && (
  <nav class="triage-rail" aria-label={railAria}>
    <div class="triage-rail-label">{railLabel}</div>
    <ol>
      {items.map((it) => (
        <li>
          <a href={it.href}>
            <span class="tr-emoji" aria-hidden="true">{it.verdictEmoji}</span>
            <span class="tr-name">{it.name}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  /* Hidden by default (mobile + tablet); the card stack already triages there. */
  .triage-rail { display: none; }

  /* Wide screens only: park the rail in the left gutter, just left of the
     centered 700px column, and keep it in view as the page scrolls. The
     breakpoint is where the gutter is wide enough to hold the rail without
     overlapping the reading column. */
  @media (min-width: 1200px) {
    .triage-rail {
      display: block;
      position: fixed;
      top: 6.5rem;
      left: calc((100vw - 700px) / 2 - 244px);
      width: 220px;
      max-height: calc(100vh - 9rem);
      overflow-y: auto;
      font-family: var(--font-sans);
    }
  }

  .triage-rail-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.5rem;
    padding-left: 0.4rem;
  }
  .triage-rail ol { list-style: none; margin: 0; padding: 0; }
  .triage-rail li { margin: 0; }
  .triage-rail a {
    display: flex;
    gap: 0.45rem;
    align-items: baseline;
    padding: 0.28rem 0.4rem;
    border-radius: 4px;
    font-size: 0.8rem;
    line-height: 1.3;
    color: var(--fg-muted);
    text-decoration: none;
  }
  .triage-rail a:hover {
    background: var(--accent-bg);
    color: var(--accent);
    text-decoration: none;
  }
  .tr-emoji { flex: none; font-size: 0.85rem; line-height: 1; }
  .tr-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
