---
import SearchBox from '../components/SearchBox.astro';
import A2hsHint from '../components/A2hsHint.astro';
// Self-hosted Newsreader (variable, optical-size axis + italic). Same-origin so
// the service worker precaches it for offline fidelity; no Google Fonts CDN
// round-trip or third-party dependency. unicode-range gates the non-latin
// subsets at runtime; the build precaches only the latin subset.
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import { tagFoundations } from '../lib/tag-foundations.ts';
import { jsonForScriptTag } from '../lib/json-script.ts';
interface Props {
  title: string;
  description?: string;
  // v0.10: study-bearing pages (date, by-site) widen the reading column on
  // desktop so each card can carry a figure column on the right. Content pages
  // (home, about) leave this off and stay at the 700px reading width.
  wide?: boolean;
  // v0.14 T4: path to the page's social-preview (og:image) PNG. Defaults to the
  // branded /og/default.png; date + site pages pass their specific card.
  ogImage?: string;
}
const { title, description, wide = false, ogImage = '/og/default.png' } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'onc brain';
const curatorName = import.meta.env.PUBLIC_CURATOR_NAME || '';
const curatorHandle = import.meta.env.PUBLIC_CURATOR_HANDLE || '';
// v0.26 (E5): a mailto to measure "can you do this for my field?" demand — the
// honest, backendless (static-site) input to the curated-replication question.
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || 'oncbrain@oncologytoolkit.com';

// v0.11 PR-1a: canonical URL emission. Strip every filter param so search
// engines don't index the per-page filter URLs as duplicates of the
// canonical content URL. Astro.site is set in astro.config.ts; on dev /
// preview where site may be absent, fall back to the pathname (relative
// canonical, still resolves correctly).
const FILTER_PARAMS = new Set(['tag', 'tags']);
function canonicalHref(url: URL, siteOrigin: string | undefined): string {
  const canon = new URL(url.pathname, siteOrigin || url.origin);
  // Preserve non-filter query params (e.g. utm_*) so canonical doesn't
  // collide with legitimate query-bearing URLs in the future. Today no
  // canonical URL uses query params, so this is defensive only.
  for (const [k, v] of url.searchParams) {
    if (!FILTER_PARAMS.has(k.toLowerCase())) canon.searchParams.append(k, v);
  }
  return canon.toString();
}
const canonicalUrl = canonicalHref(Astro.url, Astro.site?.toString());

// v0.14 T4: absolute og:image URL (social cards require an absolute URL).
const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url.origin).href;
const ogDescription = description || 'Curated, AI-summarized oncology meeting research, by disease site.';

// v0.11 PR-1a: namespace map + built-intersections allowlist for the
// future filter rail (PR-2) and canonical-redirect logic (PR-5). Inlined
// on every page; ~1KB total. Module-level cache in tag-foundations.ts
// keeps this O(1) per page after the first call this build.
const { namespaceMap, intersectionAllowlist } = tagFoundations();
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      /* v0.30 theme: set data-theme before paint to avoid a flash. Default DARK. */
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') t = 'dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {/* v0.11 PR-1a: canonical strips ?tag= filter params so search engines
        index one URL per content page, not one per filter combination. */}
    <link rel="canonical" href={canonicalUrl} />
    {/* v0.14 T4: Open Graph + Twitter card so a shared link renders a branded
        preview image instead of a bare URL. og:image is a build-time PNG. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    {curatorHandle && <meta name="twitter:creator" content={curatorHandle} />}
    <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS feed`} href="/feed.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#14130f" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="onc brain" />
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
    {import.meta.env.PROD && (
      <Fragment>
        {/* Cloudflare Web Analytics — production only, so localhost previews and
            `astro preview` don't pollute the dashboard with dev hits.
            v0.11 PR-1a: `spa: false` disables Cloudflare's automatic SPA
            pageview tracking. CF's SPA mode auto-fires pageview events
            on history.pushState + popstate (per Cloudflare's SPA docs);
            PR-2 will mutate history via replaceState for `?tag=` URL
            sync; PR-5 will navigate cross-route via location.assign.
            Without spa:false, every chip click on a future SPA build
            would dwarf real reads. Custom-event filter telemetry is
            deferred to v0.12 (TODOS.md) per the autoplan revision. */}
        <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "7de09515538540f1b55e9d16c13a1cd4", "spa": false}'></script>
        {/* Google Analytics (gtag.js), property G-PP2FRCMYS1 shared with the
            related site oncologytoolkit.com. Production-only (same gate as the
            CF beacon) so dev / `astro preview` hits don't pollute the shared
            property. is:inline keeps the gtag bootstrap as a real global
            (Astro would otherwise bundle it into a module and break window.gtag). */}
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-PP2FRCMYS1"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-PP2FRCMYS1');
        </script>
      </Fragment>
    )}
    {/* v0.11 PR-1a: small inlined JSON blobs the PR-2 filter rail and
        PR-5 canonical-redirect logic read at hydrate time. Versioned so
        a stale PWA-cached page can detect the schema has moved and skip
        the lookup gracefully. */}
    <script type="application/json" id="tag-namespaces" set:html={jsonForScriptTag(namespaceMap)} />
    <script type="application/json" id="built-intersections" set:html={jsonForScriptTag(intersectionAllowlist)} />
    <style is:global>
      :root {
        /* v0.30: default theme is DARK. The pre-paint script in <head> sets
           data-theme from localStorage (default 'dark'), so these :root values
           are also the no-JS fallback. Light is an explicit opt-in via toggle. */
        color-scheme: dark;
        --fg: #ece8de;
        --fg-muted: #9d978a;
        --bg: #14130f;
        --bg-card: #1d1c17;
        --border: #2f2d27;
        --accent: #6fb0ff;
        --accent-bg: #14253c;
        --citation-bg: #23211c;
        --font-serif: 'Newsreader Variable', 'Newsreader', 'Source Serif Pro', Charter, Georgia, 'Times New Roman', serif;
        --font-sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
      }
      :root[data-theme='light'] {
        color-scheme: light;
        --fg: #1a1a1a;
        --fg-muted: #555;
        --bg: #f7f5f0;
        --bg-card: #fffdf8;
        --border: #e3ddd0;
        --accent: #0a4b8a;
        --accent-bg: #e8f1fa;
        --citation-bg: #f1ede1;
      }
      /* v0.30 theme toggle in the header (sun shown in dark → click for light) */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        flex-shrink: 0;
        background: none;
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--fg-muted);
        cursor: pointer;
        padding: 0;
        margin-left: 0.5rem;
      }
      .theme-toggle:hover { color: var(--accent); border-color: var(--accent); }
      .theme-toggle .ico-moon { display: none; }
      .theme-toggle .ico-sun { display: block; }
      :root[data-theme='light'] .theme-toggle .ico-sun { display: none; }
      :root[data-theme='light'] .theme-toggle .ico-moon { display: block; }
      * { box-sizing: border-box; }
      body {
        font-family: var(--font-serif);
        font-feature-settings: 'kern', 'liga', 'onum';
        max-width: 700px;
        margin: 0 auto;
        padding: 1.75rem 1.25rem 4rem;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.55;
        font-size: 18px;
      }
      header {
        margin-bottom: 1.5rem;
        padding-bottom: 0.9rem;
        border-bottom: 1px solid var(--border);
      }
      header h1 {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        flex: 0 0 auto;
      }
      header h1 a { color: inherit; text-decoration: none; }
      /* Title left, search right; wraps to a full-width search below the title
         when the row is too narrow (mobile). */
      .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem 1rem;
        flex-wrap: wrap;
      }
      .header-title { flex: 0 1 auto; min-width: 0; }
      .header-search {
        flex: 1 1 220px;
        max-width: 340px;
        position: relative;
      }
      @media (max-width: 600px) {
        .header-search { flex-basis: 100%; max-width: none; }
      }
      /* About + curator on one compact line, directly under the title. */
      header .header-sub {
        margin-top: 0.15rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        letter-spacing: 0.02em;
        line-height: 1.4;
        color: var(--fg-muted);
      }
      header .header-sub a { color: var(--accent); }
      h1, h2, h3 { line-height: 1.25; font-family: var(--font-serif); }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .citation {
        display: inline-block;
        padding: 0.05rem 0.4rem;
        background: var(--citation-bg);
        border-radius: 4px;
        font-size: 0.85em;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        text-decoration: none;
        color: var(--accent);
        border: 1px solid var(--border);
      }
      .citation:hover { background: var(--accent-bg); text-decoration: none; }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.825rem;
        color: var(--fg-muted);
      }
      footer p { margin: 0.5rem 0; }
      footer a { color: var(--fg-muted); }
      .disclaimer {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: var(--bg-card);
        border-left: 3px solid var(--accent);
        border-radius: 4px;
        font-size: 0.85rem;
        color: var(--fg-muted);
      }
      @media (max-width: 600px) {
        body { padding: 1.25rem 1rem 3rem; font-size: 16px; }
      }
      /* v0.15.2: PWA "new version" prompt. Shown only on a service-worker UPDATE
         (see body script). v0.19.6: promoted from a bottom-center toast to a
         prominent full-width banner pinned across the top of the screen. */
      .pwa-toast {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1100;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.85rem;
        width: 100%;
        padding: 0.7rem 1rem;
        background: var(--accent);
        color: #fff;
        border-bottom: 1px solid rgba(0, 0, 0, 0.15);
        box-shadow: 0 2px 14px rgba(0, 0, 0, 0.2);
        font-family: var(--font-sans);
        font-size: 0.92rem;
        font-weight: 500;
        animation: pwa-toast-in 0.25s ease-out;
      }
      @keyframes pwa-toast-in {
        from { transform: translateY(-100%); }
        to { transform: translateY(0); }
      }
      @media (prefers-reduced-motion: reduce) {
        .pwa-toast { animation: none; }
      }
      .pwa-toast[hidden] { display: none; }
      .pwa-toast-btn {
        font: inherit;
        font-weight: 700;
        color: var(--accent);
        background: #fff;
        border: none;
        border-radius: 6px;
        padding: 0.35rem 0.85rem;
        cursor: pointer;
      }
      .pwa-toast-btn:disabled { opacity: 0.6; cursor: default; }
      .pwa-toast-dismiss {
        font: inherit;
        font-size: 1.35rem;
        line-height: 1;
        color: #fff;
        opacity: 0.85;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0 0.25rem;
      }
      .pwa-toast-dismiss:hover { opacity: 1; }
      @supports (padding: max(0px)) {
        .pwa-toast { padding-top: max(0.7rem, env(safe-area-inset-top)); }
      }
      /* Study pages widen to fit a narrative + figure two-column card, but only
         once there's room for both to breathe (≥1200px → 1180px body, paired
         with the StudyCard grid breakpoint). Below 1200 the body stays at the
         700px reading column and figure cards fall to a single column, so the
         narrative never runs too wide or gets cramped beside a figure. */
      @media (min-width: 1200px) {
        body.wide { max-width: 1180px; }
      }
      /* Figure lightbox: click any .study-zoom image to view it full-screen. */
      .lightbox-overlay {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background: rgba(0, 0, 0, 0.85);
        cursor: zoom-out;
      }
      .lightbox-overlay.open { display: flex; }
      .lightbox-overlay img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
      }
      .lightbox-close {
        position: fixed;
        top: 0.75rem;
        right: 1.1rem;
        background: none;
        border: none;
        color: #fff;
        font-size: 2.2rem;
        line-height: 1;
        cursor: pointer;
        padding: 0.2rem 0.55rem;
      }
    </style>
  </head>
  <body class:list={[wide && 'wide']}>
    <header>
      <div class="header-top">
        <div class="header-title">
          <h1><a href="/">{siteName}</a></h1>
          <div class="header-sub">
            <a href="/about">About</a>
            {curatorName && (
              <>
                {' · curated by '}{curatorName}
                {curatorHandle && (
                  <>
                    {' · '}
                    <a href={`https://x.com/${curatorHandle.replace(/^@/, '')}`} target="_blank" rel="noopener">{curatorHandle}</a>
                  </>
                )}
              </>
            )}
          </div>
        </div>
        <div class="header-search"><SearchBox /></div>
        <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle light or dark theme" title="Toggle light / dark">
          <svg class="ico-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <svg class="ico-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
      </div>
    </header>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var meta = document.querySelector('meta[name="theme-color"]');
        function apply(t) {
          document.documentElement.setAttribute('data-theme', t);
          try { localStorage.setItem('theme', t); } catch (e) {}
          if (meta) meta.setAttribute('content', t === 'light' ? '#f7f5f0' : '#14130f');
        }
        btn.addEventListener('click', function () {
          var cur = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
          apply(cur === 'light' ? 'dark' : 'light');
        });
      })();
    </script>
    <main>
      <A2hsHint />
      <slot />
    </main>
    <footer>
      <div class="disclaimer">
        <strong>Disclaimer:</strong> This digest contains AI-generated summaries
        of publicly posted social media content from oncology meetings. It is
        <strong>not medical advice</strong>. All clinical information must be
        independently verified against primary sources before any use in
        patient care.
      </div>
      <p>
        Content quoted/referenced under fair use for educational summary
        purposes. To request removal of any item,
        contact the curator{curatorHandle ? <> at <a href={`https://x.com/${curatorHandle.replace(/^@/, '')}`} target="_blank" rel="noopener">{curatorHandle}</a></> : ''}.
      </p>
      <p>
        <a href="/api">API &amp; RSS</a>
        {' · '}
        <a href="/feed.xml">RSS feed</a>
        {' · '}
        <a href={`mailto:${contactEmail}?subject=${encodeURIComponent('oncbrain for my subspecialty')}`}>Curating another subspecialty? Get in touch</a>
      </p>
    </footer>
    <script is:inline>
      // Triage-first is the base design: depth folds render collapsed; on desktop
      // there's room, so auto-expand the narrative depth + CONSORT. Mobile stays
      // collapsed for the 90-second scan.
      //
      // Figure galleries are different: "+N more figures" stays CLOSED by default
      // and only auto-opens (two-column desktop only) when expanding it does NOT
      // make the card taller — i.e. the figure column has spare vertical room
      // beside a taller narrative. Measured per card, and re-checked as lazy
      // images load (they change the column heights).
      (function () {
        var mqDesktop = window.matchMedia('(min-width: 1024px)');
        var mqTwoCol = window.matchMedia('(min-width: 1200px)');
        var measuring = false;
        // Cards the reader has manually toggled — never auto-decide these again,
        // or the observer would fight the click (slam an opened gallery shut).
        var userTouched = new WeakSet();
        var ro = 'ResizeObserver' in window ? new ResizeObserver(function (entries) {
          if (measuring) return;
          for (var i = 0; i < entries.length; i++) decideFigures(entries[i].target);
        }) : null;

        function syncDepth() {
          var ds = document.querySelectorAll('details.study-depth, details.consort');
          for (var i = 0; i < ds.length; i++) ds[i].open = mqDesktop.matches;
        }

        function decideFigures(card) {
          if (userTouched.has(card)) return; // reader is in control of this card
          var mf = card.querySelector('details.more-figures');
          if (!mf) return;
          if (!mqTwoCol.matches) { mf.open = false; return; }
          measuring = true;
          mf.open = false;
          var closedH = card.offsetHeight;
          mf.open = true;
          var openH = card.offsetHeight;
          // Keep open only if it didn't grow the card (figure column still fits
          // within the narrative height). +4px tolerance for sub-pixel rounding.
          mf.open = openH <= closedH + 4;
          measuring = false;
        }

        function syncFigures() {
          var cards = document.querySelectorAll('.study.has-figures');
          for (var i = 0; i < cards.length; i++) decideFigures(cards[i]);
        }

        // A manual toggle (one we didn't make) hands that card to the reader:
        // mark it touched and stop observing it so auto-decide can't override.
        function wireManualOptOut() {
          var mfs = document.querySelectorAll('.study.has-figures details.more-figures');
          for (var i = 0; i < mfs.length; i++) {
            mfs[i].addEventListener('toggle', function () {
              if (measuring) return;
              var card = this.closest('.study.has-figures');
              if (card) { userTouched.add(card); if (ro) ro.unobserve(card); }
            });
          }
        }

        function observeAll() {
          if (!ro) return;
          var cards = document.querySelectorAll('.study.has-figures');
          for (var i = 0; i < cards.length; i++) ro.observe(cards[i]);
        }

        syncDepth();
        wireManualOptOut();
        // Defer the figure decision until images have dimensions.
        window.addEventListener('load', syncFigures);
        observeAll();

        function onChange() {
          // A breakpoint cross is a real layout change — re-apply defaults to all
          // cards (including ones toggled at the previous width) and re-observe.
          userTouched = new WeakSet();
          observeAll();
          syncDepth();
          syncFigures();
        }
        if (mqDesktop.addEventListener) {
          mqDesktop.addEventListener('change', onChange);
          mqTwoCol.addEventListener('change', onChange);
        } else if (mqDesktop.addListener) {
          mqDesktop.addListener(onChange);
          mqTwoCol.addListener(onChange);
        }
      })();
    </script>
    <script is:inline>
      // Figure lightbox: one shared overlay, lazily created. Delegated click on
      // any img.study-zoom opens it full-screen; click/Esc closes.
      (function () {
        var overlay = null;
        function close() { if (overlay) overlay.classList.remove('open'); }
        function open(src, alt) {
          if (!overlay) {
            overlay = document.createElement('div');
            overlay.className = 'lightbox-overlay';
            var img = document.createElement('img');
            var btn = document.createElement('button');
            btn.className = 'lightbox-close';
            btn.setAttribute('aria-label', 'Close');
            btn.textContent = '×';
            overlay.appendChild(img);
            overlay.appendChild(btn);
            overlay.addEventListener('click', function (e) {
              if (e.target === overlay || e.target === btn) close();
            });
            document.body.appendChild(overlay);
          }
          var image = overlay.querySelector('img');
          image.src = src;
          image.alt = alt || '';
          overlay.classList.add('open');
        }
        document.addEventListener('click', function (e) {
          var t = e.target;
          if (t && t.tagName === 'IMG' && t.classList.contains('study-zoom')) {
            open(t.currentSrc || t.src, t.alt);
          }
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') close();
        });
      })();
    </script>
    <!-- v0.15.2: PWA update toast. Hidden until a new service worker is waiting. -->
    <div id="pwa-update-toast" class="pwa-toast" role="status" aria-live="polite" hidden>
      <span>New version available</span>
      <button id="pwa-update-refresh" type="button" class="pwa-toast-btn">Refresh</button>
      <button id="pwa-update-dismiss" type="button" class="pwa-toast-dismiss" aria-label="Dismiss">×</button>
    </div>
    <script is:inline>
      // Register the @vite-pwa/astro-generated service worker. The integration's
      // auto-registration doesn't fire under Astro 6, so we wire it manually.
      // v0.15.2: prompt-to-update. The SW now WAITS instead of skipping; on a new
      // deploy we surface a "New version - Refresh" toast and skipWaiting only when
      // the reader taps, so nobody is reloaded mid-scroll. is:inline keeps it
      // verbatim on every page; the .catch swallows the dev 404 (the SW is only
      // emitted by `astro build`, not `astro dev`).
      if ('serviceWorker' in navigator) {
        var pwaRefreshing = false;
        navigator.serviceWorker.addEventListener('controllerchange', function () {
          if (pwaRefreshing) return; // guard against reload loops
          pwaRefreshing = true;
          window.location.reload();
        });
        var showPwaToast = function (reg) {
          var toast = document.getElementById('pwa-update-toast');
          if (!toast || toast.dataset.shown === '1') return;
          toast.dataset.shown = '1';
          toast.hidden = false;
          document.getElementById('pwa-update-refresh').addEventListener('click', function (e) {
            e.currentTarget.disabled = true;
            if (reg.waiting) reg.waiting.postMessage({ type: 'SKIP_WAITING' });
            else window.location.reload();
          });
          document.getElementById('pwa-update-dismiss').addEventListener('click', function () {
            toast.hidden = true;
          });
        };
        window.addEventListener('load', function () {
          navigator.serviceWorker
            // updateViaCache:'none' so the worker script (and its imports) are
            // always byte-checked against the network, never served from the
            // HTTP/CDN cache (the SW ships with s-maxage=86400 at the edge).
            .register('/pwa-sw.js', { scope: '/', updateViaCache: 'none' })
            .then(function (reg) {
              // Prompt only on an UPDATE (a controller already runs this page),
              // never on first install.
              var maybePrompt = function () {
                if (navigator.serviceWorker.controller && reg.waiting) showPwaToast(reg);
              };
              if (reg.waiting) maybePrompt();
              reg.addEventListener('updatefound', function () {
                var installing = reg.installing;
                if (!installing) return;
                installing.addEventListener('statechange', function () {
                  if (installing.state === 'installed') maybePrompt();
                });
              });
              // v0.19.2: a home-screen PWA is RESUMED, not reloaded, so the
              // `load` handler's one-shot update check never re-fires and a new
              // deploy stays invisible until a rare full reload. Re-check for a
              // new SW whenever the app is brought to the foreground, and hourly
              // while it stays open. Both feed the updatefound -> toast flow
              // above; nothing reloads until the reader taps Refresh.
              var checkForUpdate = function () {
                if (document.visibilityState !== 'visible') return;
                try { reg.update(); } catch (e) { /* update() can throw if the SW is unregistering */ }
              };
              document.addEventListener('visibilitychange', checkForUpdate);
              setInterval(checkForUpdate, 60 * 60 * 1000);
            })
            .catch(function () {});
        });
      }
    </script>
  </body>
</html>
