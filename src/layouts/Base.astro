---
import SearchBox from '../components/SearchBox.astro';
interface Props {
  title: string;
  description?: string;
  // v0.10: study-bearing pages (date, by-site) widen the reading column on
  // desktop so each card can carry a figure column on the right. Content pages
  // (home, about) leave this off and stay at the 700px reading width.
  wide?: boolean;
}
const { title, description, wide = false } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'onc brain';
const curatorName = import.meta.env.PUBLIC_CURATOR_NAME || '';
const curatorHandle = import.meta.env.PUBLIC_CURATOR_HANDLE || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS feed`} href="/feed.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500&display=swap" />
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
    <style is:global>
      :root {
        color-scheme: light dark;
        --fg: #1a1a1a;
        --fg-muted: #555;
        --bg: #f7f5f0;
        --bg-card: #fffdf8;
        --border: #e3ddd0;
        --accent: #0a4b8a;
        --accent-bg: #e8f1fa;
        --citation-bg: #f1ede1;
        --font-serif: 'Newsreader', 'Source Serif Pro', Charter, Georgia, 'Times New Roman', serif;
        --font-sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #ece8de;
          --fg-muted: #9d978a;
          --bg: #14130f;
          --bg-card: #1d1c17;
          --border: #2f2d27;
          --accent: #6fb0ff;
          --accent-bg: #14253c;
          --citation-bg: #23211c;
        }
      }
      * { box-sizing: border-box; }
      body {
        font-family: var(--font-serif);
        font-feature-settings: 'kern', 'liga', 'onum';
        max-width: 700px;
        margin: 0 auto;
        padding: 1.75rem 1.25rem 4rem;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.55;
        font-size: 18px;
      }
      header {
        margin-bottom: 1.5rem;
        padding-bottom: 0.9rem;
        border-bottom: 1px solid var(--border);
      }
      header h1 {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        flex: 0 0 auto;
      }
      header h1 a { color: inherit; text-decoration: none; }
      /* Title left, search right; wraps to a full-width search below the title
         when the row is too narrow (mobile). */
      .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem 1rem;
        flex-wrap: wrap;
      }
      .header-title { flex: 0 1 auto; min-width: 0; }
      .header-search {
        flex: 1 1 220px;
        max-width: 340px;
        position: relative;
      }
      @media (max-width: 600px) {
        .header-search { flex-basis: 100%; max-width: none; }
      }
      /* About + curator on one compact line, directly under the title. */
      header .header-sub {
        margin-top: 0.15rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        letter-spacing: 0.02em;
        line-height: 1.4;
        color: var(--fg-muted);
      }
      header .header-sub a { color: var(--accent); }
      h1, h2, h3 { line-height: 1.25; font-family: var(--font-serif); }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .citation {
        display: inline-block;
        padding: 0.05rem 0.4rem;
        background: var(--citation-bg);
        border-radius: 4px;
        font-size: 0.85em;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        text-decoration: none;
        color: var(--accent);
        border: 1px solid var(--border);
      }
      .citation:hover { background: var(--accent-bg); text-decoration: none; }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.825rem;
        color: var(--fg-muted);
      }
      footer p { margin: 0.5rem 0; }
      footer a { color: var(--fg-muted); }
      .disclaimer {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: var(--bg-card);
        border-left: 3px solid var(--accent);
        border-radius: 4px;
        font-size: 0.85rem;
        color: var(--fg-muted);
      }
      @media (max-width: 600px) {
        body { padding: 1.25rem 1rem 3rem; font-size: 16px; }
      }
      /* v0.10: study pages widen on desktop to fit a per-card figure column.
         Below 1024px the cards stay single-column, so the body stays 700px to
         keep body text from running too wide on tablets. */
      @media (min-width: 1024px) {
        body.wide { max-width: 940px; }
      }
    </style>
  </head>
  <body class:list={[wide && 'wide']}>
    <header>
      <div class="header-top">
        <div class="header-title">
          <h1><a href="/">{siteName}</a></h1>
          <div class="header-sub">
            <a href="/about">About</a>
            {curatorName && (
              <>
                {' · curated by '}{curatorName}
                {curatorHandle && (
                  <>
                    {' · '}
                    <a href={`https://x.com/${curatorHandle.replace(/^@/, '')}`} target="_blank" rel="noopener">{curatorHandle}</a>
                  </>
                )}
              </>
            )}
          </div>
        </div>
        <div class="header-search"><SearchBox /></div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="disclaimer">
        <strong>Disclaimer:</strong> This digest contains AI-generated summaries
        of publicly posted social media content from oncology meetings. It is
        <strong>not medical advice</strong>. All clinical information must be
        independently verified against primary sources before any use in
        patient care.
      </div>
      <p>
        Content quoted/referenced under fair use for educational summary
        purposes. To request removal of any item,
        contact the curator{curatorHandle ? <> at <a href={`https://x.com/${curatorHandle.replace(/^@/, '')}`} target="_blank" rel="noopener">{curatorHandle}</a></> : ''}.
      </p>
      <p>
        <a href="/api">API &amp; RSS</a>
        {' · '}
        <a href="/feed.xml">RSS feed</a>
      </p>
    </footer>
    <script is:inline>
      // Triage-first is the base design: study depth folds (details.study-depth)
      // render collapsed. On desktop there's room, so auto-expand them. Mobile
      // stays collapsed for the 90-second scan. Re-syncs when crossing the
      // breakpoint; a manual toggle persists until the next crossing.
      (function () {
        var mq = window.matchMedia('(min-width: 1024px)');
        function sync() {
          var ds = document.querySelectorAll('details.study-depth, details.consort, details.more-figures');
          for (var i = 0; i < ds.length; i++) ds[i].open = mq.matches;
        }
        sync();
        if (mq.addEventListener) mq.addEventListener('change', sync);
        else if (mq.addListener) mq.addListener(sync);
      })();
    </script>
  </body>
</html>
