---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Oncology Meeting Digest';
const curatorName = import.meta.env.PUBLIC_CURATOR_NAME || '';
const curatorHandle = import.meta.env.PUBLIC_CURATOR_HANDLE || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: light dark;
        --fg: #1a1a1a;
        --fg-muted: #555;
        --bg: #fafafa;
        --bg-card: #fff;
        --border: #e5e5e5;
        --accent: #0a4b8a;
        --accent-bg: #e8f1fa;
        --citation-bg: #f4f4f5;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #f1f1f1;
          --fg-muted: #a8a8a8;
          --bg: #0e0e10;
          --bg-card: #18181b;
          --border: #2a2a2e;
          --accent: #6fb0ff;
          --accent-bg: #14253c;
          --citation-bg: #1f1f23;
        }
      }
      * { box-sizing: border-box; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        max-width: 760px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.6;
        font-size: 17px;
      }
      header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
      }
      header h1 {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 600;
      }
      header h1 a { color: inherit; text-decoration: none; }
      header .curator {
        margin-top: 0.25rem;
        font-size: 0.875rem;
        color: var(--fg-muted);
      }
      header .curator a { color: inherit; }
      h1, h2, h3 { line-height: 1.25; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .citation {
        display: inline-block;
        padding: 0.05rem 0.4rem;
        background: var(--citation-bg);
        border-radius: 4px;
        font-size: 0.85em;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        text-decoration: none;
        color: var(--accent);
        border: 1px solid var(--border);
      }
      .citation:hover { background: var(--accent-bg); text-decoration: none; }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.825rem;
        color: var(--fg-muted);
      }
      footer p { margin: 0.5rem 0; }
      footer a { color: var(--fg-muted); }
      .disclaimer {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: var(--bg-card);
        border-left: 3px solid var(--accent);
        border-radius: 4px;
        font-size: 0.85rem;
        color: var(--fg-muted);
      }
      @media (max-width: 600px) {
        body { padding: 1.25rem 1rem 3rem; font-size: 16px; }
      }
    </style>
  </head>
  <body>
    <header>
      <h1><a href="/">{siteName}</a></h1>
      {curatorName && (
        <div class="curator">
          curated by {curatorName}
          {curatorHandle && (
            <>
              {' · '}
              <a href={`https://x.com/${curatorHandle.replace(/^@/, '')}`} target="_blank" rel="noopener">{curatorHandle}</a>
            </>
          )}
          {' · '}
          <a href="/about">about</a>
        </div>
      )}
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="disclaimer">
        <strong>Disclaimer:</strong> This digest contains AI-generated summaries
        of publicly posted social media content from oncology meetings. It is
        <strong>not medical advice</strong>. All clinical information must be
        independently verified against primary sources before any use in
        patient care.
      </div>
      <p>
        Content quoted/referenced under fair use for educational summary
        purposes. To request removal of any item,
        contact the curator{curatorHandle ? <> at <a href={`https://x.com/${curatorHandle.replace(/^@/, '')}`} target="_blank" rel="noopener">{curatorHandle}</a></> : ''}.
      </p>
    </footer>
  </body>
</html>
