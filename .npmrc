# @vite-pwa/astro@1.2.0 has not bumped its peer range to Astro 6 yet (it lists
# astro ^1–^5), so a strict `npm install`/`npm ci` aborts with ERESOLVE — which
# is what the DigitalOcean build runner does. The integration works fine on
# Astro 6 (its build hooks are stable); accept the conservative peer range.
# Remove this once @vite-pwa/astro declares Astro 6 support.
legacy-peer-deps=true
