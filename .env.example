# LLM backend: 'api' (default, paid) or 'claude-cli' (your Claude Code subscription)
LLM_BACKEND=api

# Required when LLM_BACKEND=api. Get one at console.anthropic.com.
# Unused when LLM_BACKEND=claude-cli — that path uses your authenticated `claude` CLI instead.
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token from @BotFather. Used by `npm run pull:telegram` to ingest
# tweet URLs you DM the bot or post in a private channel where the bot is admin.
TELEGRAM_BOT_TOKEN=

# T5 distribution: post each day's digest to a PUBLIC Telegram channel.
# Setup: (1) create a channel, (2) add your bot (@oncbrain_bot) as an ADMIN with
# "Post messages" permission, (3) set this to the channel's @username (public)
# or numeric id (private, e.g. -1001234567890). Unset → the daily cron's
# `notify:channel` step self-skips, so the channel post stays dormant.
TELEGRAM_CHANNEL_ID=

DB_PATH=./oncbrain.db
ADMIN_PORT=3001
PUBLIC_SITE_NAME=Oncology Meeting Digest
PUBLIC_SITE_URL=https://oncbrain.oncologytoolkit.com
PUBLIC_CURATOR_NAME=Your Name, MD
PUBLIC_CURATOR_HANDLE=@yourhandle
